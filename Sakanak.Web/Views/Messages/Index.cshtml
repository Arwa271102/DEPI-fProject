@model IReadOnlyList<Sakanak.BLL.DTOs.Messages.ConversationDto>
@{
    ViewData["Title"] = "Messages";

    // Option B: set role-aware layout
    if (User.IsInRole("Student"))      { Layout = "_TailwindStudentLayout"; }
    else if (User.IsInRole("Landlord")){ Layout = "_TailwindLandlordLayout"; }
    else                               { Layout = "_TailwindAdminLayout"; }

    var messages       = ViewBag.Messages as IReadOnlyList<Sakanak.BLL.DTOs.Messages.MessageDto>
                         ?? Array.Empty<Sakanak.BLL.DTOs.Messages.MessageDto>();
    Guid? selectedId   = ViewBag.SelectedUserId as Guid?;
    var selected       = Model.FirstOrDefault(c => c.OtherUserId == selectedId);
    var pinned         = Model.Where(c => c.IsAdminConversation).ToList();
    var regular        = Model.Where(c => !c.IsAdminConversation).ToList();
}

@* ── helper ── *@
@{
    string Initials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 1 ? name[0].ToString().ToUpper() : "?";
    }

    string RelTime(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes  < 1)  return "just now";
        if (diff.TotalMinutes  < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours    < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays     < 7)  return utc.ToLocalTime().ToString("ddd");
        return utc.ToLocalTime().ToString("MMM d");
    }
}

@* ─────────────────────── STYLES ─────────────────────── *@
@section Styles {
<style>
    .msg-sidebar      { height: calc(100vh - 4rem); display:flex; flex-direction:column; }
    .msg-main         { height: calc(100vh - 4rem); display:flex; flex-direction:column; }
    .conv-scroll      { flex:1; overflow-y:auto; }
    .chat-scroll      { flex:1; overflow-y:auto; padding:1.5rem; }
    .conv-scroll::-webkit-scrollbar,
    .chat-scroll::-webkit-scrollbar { width:4px; }
    .conv-scroll::-webkit-scrollbar-thumb,
    .chat-scroll::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:4px; }
    .sent-bubble  { background:#0D5C63; color:#fff; border-radius:18px 18px 4px 18px; }
    .recv-bubble  { background:#fff; color:#191c1d; border-radius:18px 18px 18px 4px;
                    border:1px solid #e2e8f0; }
    .conv-active  { background:#f0fdfa !important; border-left:3px solid #0D5C63; }
</style>
}

@* ─────────────────────── VIEW ─────────────────────── *@
<div class="flex h-[calc(100vh-4rem)] -mt-4 -mx-4 sm:-mx-6 lg:-mx-8 overflow-hidden animate-slide-up">

    @* ══════════ LEFT SIDEBAR ══════════ *@
    <aside class="msg-sidebar w-full lg:w-[340px] xl:w-[380px] flex-shrink-0 border-r border-slate-200 bg-white">

        @* Header *@
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <h2 class="text-xl font-black text-on-surface m-0">Messages</h2>
            <span class="material-symbols-outlined text-slate-400 text-[22px]">edit_square</span>
        </div>

        <div class="conv-scroll">
            @if (!Model.Any())
            {
                <div class="px-5 py-10 text-center text-slate-400">
                    <span class="material-symbols-outlined text-4xl mb-2 block">forum</span>
                    <p class="text-sm m-0">No conversations yet.</p>
                </div>
            }
            else
            {
                @* ── PINNED (Admin) ── *@
                @if (pinned.Any())
                {
                    <div class="px-5 pt-4 pb-1">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Pinned</p>
                    </div>
                    @foreach (var c in pinned)
                    {
                        bool isActive = c.OtherUserId == selectedId;
                        <a asp-action="Index" asp-route-otherUserId="@c.OtherUserId"
                           class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition-colors cursor-pointer no-underline @(isActive ? "conv-active" : "")">
                            <div class="w-11 h-11 rounded-full bg-deep-teal flex items-center justify-center text-white font-bold text-sm flex-shrink-0 shadow-sm">
                                <span class="material-symbols-outlined text-[20px]" style="font-variation-settings:'FILL' 1;">shield</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between">
                                    <span class="font-bold text-sm text-on-surface truncate">@c.OtherUserName</span>
                                    <span class="text-[11px] text-slate-400 flex-shrink-0 ml-2">
                                        @(c.LastMessageAt == DateTime.MinValue ? "" : RelTime(c.LastMessageAt))
                                    </span>
                                </div>
                                <div class="flex items-center justify-between mt-0.5">
                                    <span class="inline-flex items-center gap-1 text-[10px] font-bold text-deep-teal bg-deep-teal/10 px-2 py-0.5 rounded-full">
                                        <span class="material-symbols-outlined text-[11px]">verified_user</span> ADMIN
                                    </span>
                                    @if (c.UnreadCount > 0)
                                    {
                                        <span class="bg-danger-red text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center">@c.UnreadCount</span>
                                    }
                                </div>
                                <p class="text-xs text-slate-500 truncate m-0 mt-1">@c.LastMessagePreview</p>
                            </div>
                        </a>
                    }
                    <div class="mx-5 border-t border-slate-100 my-2"></div>
                }

                @* ── Regular Conversations ── *@
                @foreach (var c in regular)
                {
                    bool isActive = c.OtherUserId == selectedId;
                    <a asp-action="Index" asp-route-otherUserId="@c.OtherUserId"
                       class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition-colors cursor-pointer no-underline @(isActive ? "conv-active" : "")">
                        <div class="relative w-11 h-11 rounded-full bg-gradient-to-br from-deep-teal/70 to-deep-teal flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                            @Initials(c.OtherUserName)
                            <span class="absolute bottom-0 right-0 w-3 h-3 bg-success-green border-2 border-white rounded-full"></span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between">
                                <span class="font-bold text-sm text-on-surface truncate">@c.OtherUserName</span>
                                <span class="text-[11px] text-slate-400 flex-shrink-0 ml-2">@RelTime(c.LastMessageAt)</span>
                            </div>
                            <p class="text-xs text-slate-500 truncate m-0 mt-0.5">@c.LastMessagePreview</p>
                        </div>
                        @if (c.UnreadCount > 0)
                        {
                            <span class="bg-deep-teal text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0">@c.UnreadCount</span>
                        }
                    </a>
                }
            }
        </div>
    </aside>

    @* ══════════ CHAT PANEL ══════════ *@
    <main class="msg-main flex-1 bg-slate-50 hidden lg:flex flex-col">

        @if (!selectedId.HasValue || selected == null)
        {
            <div class="flex-1 flex flex-col items-center justify-center text-slate-400 gap-4">
                <div class="w-20 h-20 rounded-full bg-slate-200 flex items-center justify-center">
                    <span class="material-symbols-outlined text-4xl text-slate-400">chat_bubble_outline</span>
                </div>
                <p class="font-semibold text-slate-500">Select a conversation to start messaging</p>
            </div>
        }
        else
        {
            @* ── Chat Header ── *@
            <div class="flex items-center justify-between px-6 py-3 bg-white border-b border-slate-200 flex-shrink-0 shadow-sm">
                <div class="flex items-center gap-3">
                    @if (selected.IsAdminConversation)
                    {
                        <div class="w-10 h-10 rounded-full bg-deep-teal flex items-center justify-center text-white">
                            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings:'FILL' 1;">shield</span>
                        </div>
                    }
                    else
                    {
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-deep-teal/70 to-deep-teal flex items-center justify-center text-white font-bold">
                            @Initials(selected.OtherUserName)
                        </div>
                    }
                    <div>
                        <p class="font-black text-on-surface text-sm m-0">@selected.OtherUserName</p>
                        <p class="text-[11px] font-bold text-success-green m-0 flex items-center gap-1">
                            <span class="w-1.5 h-1.5 bg-success-green rounded-full inline-block"></span>
                            @(selected.IsAdminConversation ? "ADMIN" : "Active")
                        </p>
                    </div>
                </div>
            </div>

            @* ── Messages ── *@
            <div class="chat-scroll" id="chatScroll">
                @if (!messages.Any())
                {
                    <div class="flex flex-col items-center justify-center h-full text-slate-400 gap-3">
                        <span class="material-symbols-outlined text-4xl">waving_hand</span>
                        <p class="text-sm font-semibold">Say hello and start the conversation!</p>
                    </div>
                }
                else
                {
                    DateTime? lastDate = null;
                    var today     = DateTime.UtcNow.Date;
                    var yesterday = today.AddDays(-1);
                    @foreach (var msg in messages)
                    {
                        var msgDate = msg.SentAt.ToLocalTime().Date;
                        if (lastDate == null || lastDate != msgDate)
                        {
                            string label = msgDate == today ? "TODAY"
                                         : msgDate == yesterday ? "YESTERDAY"
                                         : msgDate.ToString("MMMM d, yyyy").ToUpper();
                            <div class="flex items-center gap-3 my-4">
                                <div class="flex-1 h-px bg-slate-200"></div>
                                <span class="text-[11px] font-black text-slate-400 tracking-widest">@label</span>
                                <div class="flex-1 h-px bg-slate-200"></div>
                            </div>
                            lastDate = msgDate;
                        }

                        if (msg.IsMine)
                        {
                            <div class="flex justify-end items-end gap-2 mb-3">
                                <div class="max-w-[72%]">
                                    <div class="sent-bubble px-4 py-3 text-sm leading-relaxed">@msg.MessageText</div>
                                    <p class="text-[11px] text-slate-400 text-right mt-1 m-0">
                                        @msg.SentAt.ToLocalTime().ToString("h:mm tt")
                                        <span class="material-symbols-outlined text-[12px] align-middle text-deep-teal/60">done_all</span>
                                    </p>
                                </div>
                                <div class="w-8 h-8 rounded-full bg-deep-teal flex items-center justify-center text-white text-xs font-bold flex-shrink-0 self-end">
                                    Me
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="flex justify-start items-end gap-2 mb-3">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-deep-teal/70 to-deep-teal flex items-center justify-center text-white text-xs font-bold flex-shrink-0 self-end">
                                    @Initials(msg.SenderName)
                                </div>
                                <div class="max-w-[72%]">
                                    <div class="recv-bubble px-4 py-3 text-sm leading-relaxed shadow-sm">@msg.MessageText</div>
                                    <p class="text-[11px] text-slate-400 mt-1 m-0">@msg.SentAt.ToLocalTime().ToString("h:mm tt")</p>
                                </div>
                            </div>
                        }
                    }
                }
            </div>

            @* ── Send Form ── *@
            <div class="flex-shrink-0 bg-white border-t border-slate-200 px-6 py-4">
                <form asp-action="Send" method="post" class="flex items-end gap-3" id="sendForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recipientUserId" value="@selectedId" />
                    <div class="flex-1 bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 focus-within:border-deep-teal transition-all outline-none" style="outline:none !important;">
                        <textarea name="messageText" id="msgInput" rows="1" maxlength="1000" placeholder="Type your message..."
                                  class="w-full bg-transparent border-none outline-none resize-none text-sm text-on-surface placeholder-slate-400 max-h-32 overflow-y-auto"
                                  style="outline:none !important; box-shadow:none !important;"
                                  required></textarea>
                    </div>
                    <button type="submit"
                            class="w-11 h-11 rounded-full bg-deep-teal text-white flex items-center justify-center flex-shrink-0 hover:bg-deep-teal/90 active:scale-95 transition-all shadow-md border-0 cursor-pointer">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings:'FILL' 1;">send</span>
                    </button>
                </form>
                <p class="text-[11px] text-slate-400 mt-2 m-0 text-center">PRESS ENTER TO SEND, SHIFT + ENTER FOR NEW LINE</p>
            </div>
        }
    </main>
</div>

@* ─────────────────────── SCRIPTS ─────────────────────── *@
@section Scripts {
<script>
    // Auto-scroll chat to bottom
    const chatScroll = document.getElementById('chatScroll');
    if (chatScroll) chatScroll.scrollTop = chatScroll.scrollHeight;

    // Enter to send, Shift+Enter for newline
    const msgInput = document.getElementById('msgInput');
    const sendForm = document.getElementById('sendForm');
    if (msgInput && sendForm) {
        msgInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                if (this.value.trim()) sendForm.submit();
            }
        });
        // Auto-grow textarea
        msgInput.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 128) + 'px';
        });
    }
</script>
}
