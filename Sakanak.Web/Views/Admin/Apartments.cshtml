@model Sakanak.Web.Models.ViewModels.Admin.AdminApartmentsViewModel
@{
    ViewData["Title"] = "Apartments";
}

@await Html.PartialAsync("_AlertMessagesPartial")

@functions {
    private string SortArrow(string sortBy)
    {
        if (!Model.SortBy.Equals(sortBy, StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }
        return Model.Descending ? "↓" : "↑";
    }
}

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Admin Inventory</p>
        <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">All Apartments</h2>
        <p class="text-slate-500 font-body-base m-0 mt-1">Search across listings, inspect quality, and manage visibility.</p>
    </div>
    <a asp-action="Dashboard" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Dashboard
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm animate-slide-up" style="animation-delay: 0.1s">
    <div class="p-4 border-b border-slate-200 bg-slate-50">
        <form method="get" class="flex flex-col md:flex-row gap-4 items-end">
            <div class="flex-1 md:flex-none md:w-48">
                <label class="block text-xs font-bold text-slate-500 mb-1">City</label>
                <input type="text" name="city" value="@Model.CityFilter" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="City" />
            </div>
            <div class="flex-1 md:flex-none md:w-48">
                <label class="block text-xs font-bold text-slate-500 mb-1">Landlord</label>
                <input type="text" name="landlord" value="@Model.LandlordFilter" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Name or email" />
            </div>
            <div class="flex-1 md:flex-none md:w-48">
                <label class="block text-xs font-bold text-slate-500 mb-1">Status</label>
                <select name="status" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none">
                    <option value="">All statuses</option>
                    <option value="Active" selected="@(Model.StatusFilter == "Active" ? "selected" : null)">Active</option>
                    <option value="Inactive" selected="@(Model.StatusFilter == "Inactive" ? "selected" : null)">Inactive</option>
                </select>
            </div>
            <div class="flex gap-2">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="desc" value="@Model.Descending.ToString().ToLowerInvariant()" />
                <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                <button type="submit" class="bg-deep-teal text-white px-6 py-2 rounded-lg font-bold text-sm hover:opacity-90 transition-opacity border-0 cursor-pointer">Filter</button>
                <a asp-action="Apartments" class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-slate-50 transition-colors no-underline flex items-center justify-center">Clear</a>
            </div>
        </form>
    </div>

    <div class="overflow-x-auto">
        @if (Model.Apartments.Count == 0)
        {
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl mb-2 opacity-50">search_off</span>
                <p class="m-0">No apartments match the current filters.</p>
            </div>
        }
        else
        {
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500 font-bold border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="Apartments" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="address" asp-route-desc="@(Model.SortBy.Equals("address", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Address <span class="text-deep-teal">@Html.Raw(SortArrow("address"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="Apartments" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="city" asp-route-desc="@(Model.SortBy.Equals("city", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                City <span class="text-deep-teal">@Html.Raw(SortArrow("city"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="Apartments" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="landlord" asp-route-desc="@(Model.SortBy.Equals("landlord", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Landlord <span class="text-deep-teal">@Html.Raw(SortArrow("landlord"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="Apartments" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="price" asp-route-desc="@(Model.SortBy.Equals("price", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Price <span class="text-deep-teal">@Html.Raw(SortArrow("price"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="Apartments" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="status" asp-route-desc="@(Model.SortBy.Equals("status", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Status <span class="text-deep-teal">@Html.Raw(SortArrow("status"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var apartment in Model.Apartments)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(apartment.PrimaryPhotoUrl))
                                {
                                    <img src="@Url.Content(apartment.PrimaryPhotoUrl)" alt="Thumbnail" class="w-12 h-12 rounded-lg object-cover flex-shrink-0" />
                                }
                                else
                                {
                                    <div class="w-12 h-12 rounded-lg bg-slate-100 flex items-center justify-center text-slate-400 flex-shrink-0">
                                        <span class="material-symbols-outlined">image</span>
                                    </div>
                                }
                                <div>
                                    <div class="font-bold text-on-surface line-clamp-1">@apartment.Address</div>
                                    <div class="text-[10px] text-slate-500 font-bold uppercase tracking-wider">@apartment.TotalSeats SEATS</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 font-semibold text-slate-600">@apartment.City</td>
                        <td class="px-6 py-4">
                            <div class="font-bold text-on-surface">@apartment.LandlordName</div>
                            <div class="text-[10px] text-slate-500 line-clamp-1">@apartment.LandlordEmail</div>
                        </td>
                        <td class="px-6 py-4 font-bold text-on-surface">
                            @apartment.PricePerMonth.ToString("C0")
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col gap-1 items-start">
                                <span class="px-2 py-1 rounded-full text-[10px] font-bold @(apartment.IsActive ? "bg-success-green/10 text-success-green" : "bg-slate-200 text-slate-600")">
                                    @(apartment.IsActive ? "Active" : "Inactive")
                                </span>
                                @if (apartment.LatestRequestStatus != "Approved")
                                {
                                    <div class="text-[10px] scale-90 origin-left">
                                        @await Html.PartialAsync("_StatusBadgePartial", apartment.LatestRequestStatus)
                                    </div>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="ApartmentDetails" asp-route-id="@apartment.ApartmentId" class="text-deep-teal bg-deep-teal/10 px-4 py-2 rounded-lg text-sm font-bold no-underline hover:bg-deep-teal/20 transition-colors inline-block">View Details</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
    
    @if (Model.Apartments.Count > 0)
    {
        <div class="p-4 border-t border-slate-200 bg-slate-50">
            <partial name="_PaginationPartial" model="Model.Pagination" />
        </div>
    }
</div>
