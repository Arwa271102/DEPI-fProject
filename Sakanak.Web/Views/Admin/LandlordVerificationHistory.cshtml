@model Sakanak.BLL.DTOs.Common.PagedResult<Sakanak.BLL.DTOs.Admin.LandlordVerificationRequestDto>
@{
    ViewData["Title"] = "Landlord Verification History";
    var statusFilter = ViewBag.StatusFilter as string;
}

@await Html.PartialAsync("_AlertMessagesPartial")

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Audit Trail</p>
        <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">Landlord Verification History</h2>
        <p class="text-slate-500 font-body-base m-0 mt-1">Full history of all landlord verification requests — @Model.TotalCount total.</p>
    </div>
    <a asp-action="Dashboard" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Dashboard
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm animate-slide-up" style="animation-delay: 0.1s">
    @* Filter Bar *@
    <div class="p-4 border-b border-slate-200 bg-slate-50">
        <form method="get" class="flex flex-wrap gap-4 items-end">
            <div class="flex-1 min-w-[150px] max-w-[200px]">
                <label class="block text-xs font-bold text-slate-500 mb-1">Status</label>
                <select name="status" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none">
                    <option value="">All statuses</option>
                    <option value="Pending" selected="@(statusFilter == "Pending" ? "selected" : null)">Pending</option>
                    <option value="Approved" selected="@(statusFilter == "Approved" ? "selected" : null)">Approved</option>
                    <option value="Rejected" selected="@(statusFilter == "Rejected" ? "selected" : null)">Rejected</option>
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="bg-deep-teal text-white px-6 py-2 rounded-lg font-bold text-sm hover:opacity-90 transition-opacity border-0 cursor-pointer">Filter</button>
                <a asp-action="LandlordVerificationHistory" class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-slate-50 transition-colors no-underline flex items-center justify-center">Clear</a>
            </div>
        </form>
    </div>

    <div class="overflow-x-auto">
        @if (Model.Items.Count == 0)
        {
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl mb-2 opacity-50">history</span>
                <p class="m-0">No verification requests match the filter.</p>
            </div>
        }
        else
        {
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50/50 text-slate-500 font-bold border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-3 font-semibold">Landlord</th>
                        <th class="px-6 py-3 font-semibold">Contact</th>
                        <th class="px-6 py-3 font-semibold">Submitted</th>
                        <th class="px-6 py-3 font-semibold">Status</th>
                        <th class="px-6 py-3 font-semibold">Rejection Reason</th>
                        <th class="px-6 py-3 font-semibold text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var request in Model.Items)
                {
                    string verStatus = request.Status;
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 flex-shrink-0">
                                    <span class="material-symbols-outlined">person</span>
                                </div>
                                <span class="font-bold text-on-surface">@request.LandlordName</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-slate-500">@request.Email</td>
                        <td class="px-6 py-4 text-slate-500 text-xs">@(request.VerificationRequestedAt?.ToLocalTime().ToString("dd MMM yyyy") ?? "—")</td>
                        <td class="px-6 py-4">
                            @await Html.PartialAsync("_StatusBadgePartial", verStatus)
                        </td>
                        <td class="px-6 py-4 text-slate-500 text-xs italic max-w-[200px] truncate">
                            @(string.IsNullOrWhiteSpace(request.RejectionReason) ? "—" : request.RejectionReason)
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="ReviewLandlord" asp-route-id="@request.LandlordId"
                               class="text-deep-teal bg-deep-teal/10 px-4 py-2 rounded-lg text-sm font-bold no-underline hover:bg-deep-teal/20 transition-colors inline-block">View</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    @if (Model.Items.Count > 0)
    {
        <div class="p-4 border-t border-slate-200 bg-slate-50">
            <partial name="_PaginationPartial" model="@(new Sakanak.Web.Models.ViewModels.Shared.PaginationViewModel
            {
                PageNumber   = Model.PageNumber,
                TotalPages   = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize),
                TotalCount   = Model.TotalCount,
                PageSize     = Model.PageSize,
                HasPrevious  = Model.PageNumber > 1,
                HasNext      = Model.PageNumber < (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize),
                Action       = "LandlordVerificationHistory",
                Controller   = "Admin",
                RouteValues  = new Dictionary<string, string?> { ["status"] = statusFilter, ["pageSize"] = Model.PageSize.ToString() }
            })" />
        </div>
    }
</div>
