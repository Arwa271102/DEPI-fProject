@model IReadOnlyList<Sakanak.BLL.DTOs.Apartment.ApartmentOccupancyDto>
@{
    ViewData["Title"] = "Apartments Occupancy";
    var totalSeats = Model.Sum(item => item.TotalSeats);
    var occupiedSeats = Model.Sum(item => item.OccupiedSeats);
    var occupancyRate = totalSeats > 0 ? Math.Round((decimal)occupiedSeats / totalSeats * 100, 1) : 0;
}

@await Html.PartialAsync("_AlertMessagesPartial")

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Platform Occupancy</p>
        <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">Apartments & Occupancy</h2>
        <p class="text-slate-500 font-body-base m-0 mt-1">@occupiedSeats / @totalSeats seats occupied (@occupancyRate%)</p>
    </div>
    <a asp-action="Dashboard" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Dashboard
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm animate-slide-up" style="animation-delay: 0.1s">
    <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
        <h3 class="font-headline-md text-lg font-bold text-on-surface m-0">Occupancy Breakdown</h3>
    </div>
    
    <div class="overflow-x-auto">
        @if (Model.Count == 0)
        {
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl mb-2 opacity-50">meeting_room</span>
                <p class="m-0">No apartments found on the platform.</p>
            </div>
        }
        else
        {
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500 font-bold border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-3 font-semibold">Apartment</th>
                        <th class="px-6 py-3 font-semibold">Landlord</th>
                        <th class="px-6 py-3 font-semibold min-w-[200px]">Occupancy</th>
                        <th class="px-6 py-3 font-semibold">Status</th>
                        <th class="px-6 py-3 font-semibold">Monthly Revenue</th>
                        <th class="px-6 py-3 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var apartment in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="font-bold text-on-surface line-clamp-1">@apartment.Address</div>
                            <div class="text-xs text-slate-500">@apartment.City</div>
                        </td>
                        <td class="px-6 py-4 font-semibold text-slate-600">@apartment.LandlordName</td>
                        <td class="px-6 py-4">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-xs font-bold text-slate-700">@apartment.OccupiedSeats / @apartment.TotalSeats seats</span>
                                <span class="text-xs font-bold text-slate-500">@(Math.Round(apartment.OccupancyRate))%</span>
                            </div>
                            <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                                <div class="bg-success-green h-full rounded-full transition-all duration-500" style="width: @apartment.OccupancyRate%"></div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 rounded-full text-[10px] font-bold @(apartment.IsActive ? "bg-success-green/10 text-success-green" : "bg-slate-200 text-slate-600")">
                                @(apartment.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="px-6 py-4 font-bold text-on-surface">@apartment.MonthlyRevenue.ToString("C0")</td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="ApartmentOccupancyDetails" asp-route-id="@apartment.ApartmentId" class="text-deep-teal font-semibold hover:underline text-sm no-underline inline-flex items-center gap-1">
                                View Members <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
