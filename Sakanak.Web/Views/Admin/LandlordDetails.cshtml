@using Sakanak.Domain.Enums
@model Sakanak.Web.Models.ViewModels.Admin.LandlordDetailsViewModel
@{
    ViewData["Title"] = "Landlord Details";
    var isSuspended = Model.Status.Equals(UserStatus.Suspended.ToString(), StringComparison.OrdinalIgnoreCase);
}

@await Html.PartialAsync("_AlertMessagesPartial")

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Landlord Profile</p>
        <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">@Model.Name</h2>
        <p class="text-slate-500 font-body-base m-0 mt-1">Review landlord details, apartment portfolio, and moderation status.</p>
    </div>
    <div class="flex gap-2">
        <a asp-action="Landlords" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back
        </a>
        
        @if (isSuspended)
        {
            <form asp-action="ReactivateLandlord" asp-route-id="@Model.LandlordId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="bg-success-green text-white px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:opacity-90 transition-opacity shadow-sm border-0 cursor-pointer">
                    <span class="material-symbols-outlined text-[18px]">how_to_reg</span> Reactivate
                </button>
            </form>
        }
        else
        {
            <button type="button" onclick="document.getElementById('suspendModal').classList.remove('hidden'); document.getElementById('suspendModal').classList.add('flex');" class="bg-danger-red text-white px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:opacity-90 transition-opacity shadow-sm border-0 cursor-pointer">
                <span class="material-symbols-outlined text-[18px]">person_off</span> Suspend
            </button>
        }
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 animate-slide-up" style="animation-delay: 0.1s">
    <!-- Left Column: Stats & Info -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
            <div class="p-6 flex flex-col items-center border-b border-slate-100">
                <div class="w-20 h-20 bg-deep-teal text-white rounded-full flex items-center justify-center font-headline-h1 text-2xl mb-4 shadow-inner">
                    @Model.Name.Substring(0, 1)
                </div>
                <h3 class="font-headline-md text-lg font-bold text-on-surface m-0 text-center">@Model.Name</h3>
                <p class="text-sm text-slate-500 m-0 mb-3">@Model.Email</p>
                @await Html.PartialAsync("_StatusBadgePartial", Model.Status)
            </div>
            
            <div class="p-6 space-y-4 bg-slate-50/50">
                <div class="flex justify-between items-center pb-3 border-b border-slate-200 border-dashed">
                    <span class="text-xs font-bold text-slate-500">Phone</span>
                    <span class="text-sm font-semibold text-on-surface">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</span>
                </div>
                <div class="flex justify-between items-center pb-3 border-b border-slate-200 border-dashed">
                    <span class="text-xs font-bold text-slate-500">Age</span>
                    <span class="text-sm font-semibold text-on-surface">@Model.Age yrs</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-xs font-bold text-slate-500">Identity Verification</span>
                    @await Html.PartialAsync("_StatusBadgePartial", Model.VerificationStatus ? "Approved" : "Pending")
                </div>
            </div>
        </div>
        
        <div class="bg-deep-teal/5 border border-deep-teal/10 rounded-xl p-6 shadow-sm">
            <h4 class="font-headline-md text-sm font-bold text-deep-teal m-0 mb-4 uppercase tracking-wider">Portfolio Overview</h4>
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-white p-4 rounded-lg border border-slate-200 text-center">
                    <p class="text-2xl font-black text-on-surface m-0">@Model.TotalApartments</p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase m-0 mt-1">Total</p>
                </div>
                <div class="bg-white p-4 rounded-lg border border-slate-200 text-center">
                    <p class="text-2xl font-black text-success-green m-0">@Model.ActiveApartments</p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase m-0 mt-1">Active</p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Column: Apartments -->
    <div class="lg:col-span-2">
        <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm h-full">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                <h3 class="font-headline-md text-lg font-bold text-on-surface m-0">Apartment Portfolio</h3>
            </div>
            
            @if (Model.Apartments.Count == 0)
            {
                <div class="p-8 text-center text-slate-500">
                    <span class="material-symbols-outlined text-4xl mb-2 opacity-50">apartment</span>
                    <p class="m-0">This landlord has no apartments yet.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-slate-50/50 text-slate-500 font-bold border-b border-slate-200">
                            <tr>
                                <th class="px-6 py-3 font-semibold">Address</th>
                                <th class="px-6 py-3 font-semibold">Price</th>
                                <th class="px-6 py-3 font-semibold">Listing</th>
                                <th class="px-6 py-3 font-semibold">Approval</th>
                                <th class="px-6 py-3 font-semibold text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                        @foreach (var apartment in Model.Apartments)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-on-surface line-clamp-1">@apartment.Address</div>
                                    <div class="text-xs text-slate-500">@apartment.City</div>
                                </td>
                                <td class="px-6 py-4 font-semibold text-on-surface">@apartment.PricePerMonth.ToString("C0")</td>
                                <td class="px-6 py-4">
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold @(apartment.IsActive ? "bg-success-green/10 text-success-green" : "bg-slate-200 text-slate-600")">
                                        @(apartment.IsActive ? "Active" : "Hidden")
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @await Html.PartialAsync("_StatusBadgePartial", apartment.RequestStatus)
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a asp-action="ApartmentDetails" asp-route-id="@apartment.ApartmentId" class="text-deep-teal font-semibold hover:underline text-sm no-underline inline-flex items-center gap-1">
                                        View <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@if (!isSuspended)
{
    <!-- Tailwind Modal for Suspend -->
    <div id="suspendModal" class="fixed inset-0 z-[100] bg-slate-900/50 backdrop-blur-sm hidden items-center justify-center">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 overflow-hidden animate-slide-up">
            <form asp-action="SuspendLandlord" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="SuspendLandlord.LandlordId" type="hidden" />
                
                <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
                    <h2 class="font-headline-md text-xl font-bold text-on-surface m-0">Suspend Landlord</h2>
                    <button type="button" onclick="document.getElementById('suspendModal').classList.add('hidden'); document.getElementById('suspendModal').classList.remove('flex');" class="text-slate-400 hover:text-slate-600 border-0 bg-transparent cursor-pointer">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                
                <div class="p-6">
                    <div class="bg-danger-red/10 border border-danger-red/20 text-danger-red p-4 rounded-xl text-sm font-semibold flex gap-3 mb-6">
                        <span class="material-symbols-outlined shrink-0 text-danger-red">warning</span>
                        <p class="m-0">Suspending this account will hide all their active apartments and prevent them from logging in.</p>
                    </div>
                
                    <label asp-for="SuspendLandlord.Reason" class="block text-sm font-bold text-on-surface mb-2">Suspension Reason</label>
                    <textarea asp-for="SuspendLandlord.Reason" class="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-danger-red focus:border-danger-red outline-none text-sm transition-all" rows="4" placeholder="Explain why this account is being suspended..."></textarea>
                    <span asp-validation-for="SuspendLandlord.Reason" class="text-danger-red text-xs mt-1 block"></span>
                </div>
                
                <div class="px-6 py-4 border-t border-slate-200 bg-slate-50 flex justify-end gap-3">
                    <button type="button" onclick="document.getElementById('suspendModal').classList.add('hidden'); document.getElementById('suspendModal').classList.remove('flex');" class="px-4 py-2 bg-white border border-slate-300 text-slate-700 rounded-lg font-bold hover:bg-slate-50 cursor-pointer">Cancel</button>
                    <button type="submit" class="px-4 py-2 bg-danger-red text-white rounded-lg font-bold hover:bg-danger-red/90 border-0 cursor-pointer">Suspend Account</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
