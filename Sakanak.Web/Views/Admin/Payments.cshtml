@model Sakanak.BLL.DTOs.Common.PagedResult<Sakanak.BLL.DTOs.Payment.PaymentDto>
@using Sakanak.Domain.Enums
@{
    ViewData["Title"] = "Payments";
    var statusFilter = ViewBag.StatusFilter as PaymentStatus?;
}

@await Html.PartialAsync("_AlertMessagesPartial")

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Payment Monitoring</p>
        <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">Payments</h2>
        <p class="text-slate-500 font-body-base m-0 mt-1">Review all transactions across the platform.</p>
    </div>
    <a asp-action="Dashboard" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Dashboard
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm animate-slide-up" style="animation-delay: 0.1s">
    <div class="p-4 border-b border-slate-200 bg-slate-50">
        <form method="get" class="flex flex-col md:flex-row gap-4 items-end">
            <div class="flex-1 md:flex-none md:w-64">
                <label class="block text-xs font-bold text-slate-500 mb-1">Status</label>
                <select name="status" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none">
                    <option value="">All statuses</option>
                    @foreach (var status in Enum.GetValues<PaymentStatus>())
                    {
                        <option value="@status" selected="@(statusFilter == status)">@status</option>
                    }
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="bg-deep-teal text-white px-6 py-2 rounded-lg font-bold text-sm hover:opacity-90 transition-opacity border-0 cursor-pointer">Filter</button>
                <a asp-action="Payments" class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-slate-50 transition-colors no-underline flex items-center justify-center">Clear</a>
            </div>
        </form>
    </div>

    <div class="overflow-x-auto">
        @if (Model.Items.Count == 0)
        {
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl mb-2 opacity-50">payments</span>
                <p class="m-0">No payments found.</p>
            </div>
        }
        else
        {
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500 font-bold border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-3 font-semibold">ID</th>
                        <th class="px-6 py-3 font-semibold">Student</th>
                        <th class="px-6 py-3 font-semibold">Landlord</th>
                        <th class="px-6 py-3 font-semibold">Apartment</th>
                        <th class="px-6 py-3 font-semibold">Amount</th>
                        <th class="px-6 py-3 font-semibold">Status</th>
                        <th class="px-6 py-3 font-semibold">Paid At</th>
                        <th class="px-6 py-3 font-semibold text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var payment in Model.Items)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 font-mono text-xs text-slate-500">
                            #@(payment.PaymentId.ToString().Length > 8 ? payment.PaymentId.ToString().Substring(0, 8) : payment.PaymentId.ToString())
                        </td>
                        <td class="px-6 py-4 font-bold text-on-surface">@payment.StudentName</td>
                        <td class="px-6 py-4 text-slate-600">@payment.LandlordName</td>
                        <td class="px-6 py-4 text-slate-600 line-clamp-1" title="@payment.ApartmentAddress">@payment.ApartmentAddress</td>
                        <td class="px-6 py-4 font-bold text-on-surface">@payment.Amount.ToString("C0")</td>
                        <td class="px-6 py-4">@await Html.PartialAsync("_StatusBadgePartial", payment.Status)</td>
                        <td class="px-6 py-4 text-slate-500 text-xs">@(payment.PaidAt?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="PaymentDetails" asp-route-id="@payment.PaymentId" class="text-deep-teal font-semibold hover:underline text-sm no-underline inline-flex items-center gap-1">
                                Details <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
    
    @if (Model.Items.Count > 0)
    {
        <div class="p-4 border-t border-slate-200 bg-slate-50">
            @await Html.PartialAsync("_PaginationPartial", new Sakanak.Web.Models.ViewModels.Shared.PaginationViewModel
            {
                PageNumber = Model.PageNumber,
                PageSize = Model.PageSize,
                TotalCount = Model.TotalCount,
                TotalPages = Model.TotalPages,
                HasPrevious = Model.HasPrevious,
                HasNext = Model.HasNext,
                Action = "Payments",
                Controller = "Admin",
                RouteValues = new Dictionary<string, string?> { ["status"] = statusFilter?.ToString() }
            })
        </div>
    }
</div>
