@model Sakanak.BLL.DTOs.Payment.PaymentDetailsDto
@{
    ViewData["Title"] = "Payment Details";
}

@await Html.PartialAsync("_AlertMessagesPartial")

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Payment Audit</p>
        <div class="flex items-center gap-3">
            <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">Payment #@(Model.PaymentId.ToString().Length > 8 ? Model.PaymentId.ToString().Substring(0, 8) : Model.PaymentId.ToString())...</h2>
            @await Html.PartialAsync("_StatusBadgePartial", Model.Status)
        </div>
    </div>
    <a asp-action="Payments" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Payments
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm animate-slide-up max-w-4xl" style="animation-delay: 0.1s">
    <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
        <h3 class="font-headline-md text-lg font-bold text-on-surface m-0">Transaction Details</h3>
    </div>
    
    <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-8">
            <div class="space-y-6">
                <div>
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">People</h4>
                    <div class="bg-slate-50/50 border border-slate-200 rounded-lg p-4 space-y-3">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-slate-500">Student</span>
                            <span class="font-semibold text-on-surface">@Model.StudentName</span>
                            <span class="text-xs text-slate-500">@Model.StudentEmail</span>
                        </div>
                        <hr class="border-t border-slate-200 border-dashed m-0" />
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-slate-500">Landlord</span>
                            <span class="font-semibold text-on-surface">@Model.LandlordName</span>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">Property</h4>
                    <div class="bg-slate-50/50 border border-slate-200 rounded-lg p-4 space-y-3">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-slate-500">Apartment</span>
                            <span class="font-semibold text-on-surface">@Model.ApartmentAddress</span>
                            <span class="text-xs text-slate-500">@Model.ApartmentCity</span>
                        </div>
                        <hr class="border-t border-slate-200 border-dashed m-0" />
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-slate-500">Contract</span>
                            <span class="font-semibold text-on-surface text-sm">#@Model.ContractId</span>
                            <span class="text-xs text-slate-500">@Model.ContractStartDate.ToString("dd MMM yyyy") - @Model.ContractEndDate.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="space-y-6">
                <div>
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">Financials</h4>
                    <div class="bg-slate-50/50 border border-slate-200 rounded-lg p-4 space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-bold text-slate-500">Monthly Rate</span>
                            <span class="font-semibold text-on-surface">@Model.MonthlyRate.ToString("C0")</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-bold text-slate-500">Billing Months</span>
                            <span class="font-semibold text-on-surface">@Model.BillingMonths</span>
                        </div>
                        <hr class="border-t border-slate-200 border-dashed m-0" />
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-bold text-slate-800 uppercase tracking-wider">Total Amount</span>
                            <span class="font-black text-xl text-deep-teal">@Model.Amount.ToString("C0")</span>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">Timeline & Processing</h4>
                    <div class="bg-slate-50/50 border border-slate-200 rounded-lg p-4 space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-xs font-bold text-slate-500">Due Date</span>
                            <span class="font-semibold text-on-surface text-sm">@Model.DueDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-xs font-bold text-slate-500">Paid At</span>
                            <span class="font-semibold text-on-surface text-sm">@(Model.PaidAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</span>
                        </div>
                        <hr class="border-t border-slate-200 border-dashed m-0" />
                        <div class="flex flex-col gap-1">
                            <span class="text-xs font-bold text-slate-500">Stripe Session</span>
                            <span class="font-mono text-xs text-slate-600 bg-slate-200 px-2 py-1 rounded w-fit break-all">@(Model.StripeSessionId ?? "—")</span>
                        </div>
                        <div class="flex flex-col gap-1">
                            <span class="text-xs font-bold text-slate-500">Stripe Payment Intent</span>
                            <span class="font-mono text-xs text-slate-600 bg-slate-200 px-2 py-1 rounded w-fit break-all">@(Model.StripePaymentIntentId ?? "—")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
