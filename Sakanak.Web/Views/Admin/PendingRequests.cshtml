@model Sakanak.Web.Models.ViewModels.Admin.PendingRequestsListViewModel
@{
    ViewData["Title"] = "Pending Requests";
}

@await Html.PartialAsync("_AlertMessagesPartial")

@functions {
    private string SortArrow(string sortBy)
    {
        if (!Model.SortBy.Equals(sortBy, StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        return Model.Descending ? "↓" : "↑";
    }
}

<div class="mb-8 flex justify-between items-end animate-slide-up">
    <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Approval Queue</p>
        <h2 class="font-headline-h1 text-headline-h1 text-on-surface m-0">Pending Apartment Requests</h2>
        <p class="text-slate-500 font-body-base m-0 mt-1">Each request stays hidden from students until you approve it.</p>
    </div>
    <a asp-action="Dashboard" class="bg-white border border-slate-200 text-deep-teal px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 hover:bg-slate-50 transition-colors shadow-sm no-underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Dashboard
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm animate-slide-up" style="animation-delay: 0.1s">
    <div class="p-4 border-b border-slate-200 bg-slate-50">
        <form method="get" class="flex flex-col md:flex-row gap-4 items-end">
            <div class="flex-1">
                <label class="block text-xs font-bold text-slate-500 mb-1">City</label>
                <input type="text" name="city" value="@Model.CityFilter" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Filter by city" />
            </div>
            <div class="flex-1">
                <label class="block text-xs font-bold text-slate-500 mb-1">Landlord</label>
                <input type="text" name="landlord" value="@Model.LandlordFilter" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Filter by landlord" />
            </div>
            <div class="flex gap-2">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="desc" value="@Model.Descending.ToString().ToLowerInvariant()" />
                <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                <button type="submit" class="bg-deep-teal text-white px-6 py-2 rounded-lg font-bold text-sm hover:opacity-90 transition-opacity border-0">Filter</button>
                <a asp-action="PendingRequests" class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-slate-50 transition-colors no-underline flex items-center justify-center">Clear</a>
            </div>
        </form>
    </div>

    <div class="overflow-x-auto">
        @if (Model.Requests.Count == 0)
        {
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl mb-2 opacity-50">done_all</span>
                <p class="m-0">No pending requests to review.</p>
            </div>
        }
        else
        {
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500 font-bold border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="PendingRequests" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="apartment" asp-route-desc="@(Model.SortBy.Equals("apartment", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Apartment <span class="text-deep-teal">@Html.Raw(SortArrow("apartment"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold">Type</th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="PendingRequests" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="landlord" asp-route-desc="@(Model.SortBy.Equals("landlord", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Landlord <span class="text-deep-teal">@Html.Raw(SortArrow("landlord"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="PendingRequests" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="createdat" asp-route-desc="@(Model.SortBy.Equals("createdat", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Submitted <span class="text-deep-teal">@Html.Raw(SortArrow("createdat"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold whitespace-nowrap">
                            <a class="text-slate-500 no-underline hover:text-deep-teal flex items-center gap-1" asp-action="PendingRequests" asp-route-city="@Model.CityFilter" asp-route-landlord="@Model.LandlordFilter" asp-route-pageSize="@Model.Pagination.PageSize" asp-route-page="1" asp-route-sortBy="status" asp-route-desc="@(Model.SortBy.Equals("status", StringComparison.OrdinalIgnoreCase) ? !Model.Descending : false)">
                                Status <span class="text-deep-teal">@Html.Raw(SortArrow("status"))</span>
                            </a>
                        </th>
                        <th class="px-6 py-3 font-semibold text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                @foreach (var request in Model.Requests)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(request.ThumbnailUrl))
                                {
                                    <img src="@Url.Content(request.ThumbnailUrl)" alt="Thumbnail" class="w-12 h-12 rounded-lg object-cover flex-shrink-0" />
                                }
                                else
                                {
                                    <div class="w-12 h-12 rounded-lg bg-slate-100 flex items-center justify-center text-slate-400 flex-shrink-0">
                                        <span class="material-symbols-outlined">image</span>
                                    </div>
                                }
                                <div>
                                    <div class="font-bold text-on-surface line-clamp-1">@request.ApartmentAddress</div>
                                    <div class="text-xs text-slate-500">@request.City</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 rounded-full text-[10px] font-bold @(request.Type == "ApartmentEdit" ? "bg-info-blue/10 text-info-blue" : "bg-slate-200 text-slate-600")">
                                @request.Type
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="font-bold text-on-surface text-xs">@request.LandlordName</div>
                            <div class="text-xs text-slate-500 line-clamp-1">@request.LandlordEmail</div>
                        </td>
                        <td class="px-6 py-4 text-slate-500 text-xs">
                            @request.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                        </td>
                        <td class="px-6 py-4">
                            @await Html.PartialAsync("_StatusBadgePartial", request.Status)
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="ReviewRequest" asp-route-id="@request.RequestId" class="text-deep-teal bg-deep-teal/10 px-4 py-2 rounded-lg text-sm font-bold no-underline hover:bg-deep-teal/20 transition-colors inline-block">Review</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
    
    @if (Model.Requests.Count > 0)
    {
        <div class="p-4 border-t border-slate-200 bg-slate-50">
            <partial name="_PaginationPartial" model="Model.Pagination" />
        </div>
    }
</div>
