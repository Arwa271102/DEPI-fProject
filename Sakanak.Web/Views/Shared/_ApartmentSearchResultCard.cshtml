@model Sakanak.BLL.DTOs.Search.ApartmentListItemDto

<article class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group border border-slate-100 flex flex-col h-full animate-slide-up">
    <div class="relative h-48 sm:h-56 overflow-hidden bg-slate-100">
        @if (!string.IsNullOrWhiteSpace(Model.PrimaryPhotoUrl))
        {
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@Url.Content(Model.PrimaryPhotoUrl)" alt="Apartment photo" loading="lazy" />
        }
        else
        {
            <div class="w-full h-full flex flex-col items-center justify-center text-slate-400">
                <span class="material-symbols-outlined text-[48px] mb-2 opacity-50">imagesmode</span>
                <span class="text-xs font-medium">No Photo</span>
            </div>
        }
        
        <div class="absolute bottom-4 left-4 bg-primary text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full shadow-sm">
            @Model.TotalSeats Seats Total
        </div>
    </div>
    
    <div class="p-5 flex flex-col flex-grow">
        <div class="flex justify-between items-start mb-2">
            <div>
                <h3 class="font-headline-h2 text-lg text-deep-teal mb-1 line-clamp-1" title="@Model.Address">@Model.Address</h3>
                <div class="flex items-center gap-1.5 text-slate-gray">
                    <span class="material-symbols-outlined text-[14px]">location_on</span>
                    <span class="text-xs font-medium line-clamp-1">@Model.City</span>
                </div>
            </div>
            <div class="text-right flex-shrink-0 ml-2">
                <p class="text-xl font-black text-deep-teal m-0">@Model.PricePerMonth.ToString("C0")<span class="text-[10px] font-medium text-slate-400">/mo</span></p>
            </div>
        </div>
        
        <div class="flex items-center gap-4 py-3 border-y border-slate-50 mb-4 mt-auto">
            <div class="flex items-center gap-1.5 text-slate-600">
                <span class="material-symbols-outlined text-[16px] text-slate-400">person</span>
                <span class="text-xs font-medium">Landlord: @Model.LandlordName</span>
            </div>
        </div>
        
        <div class="flex items-center gap-1 flex-wrap mb-4 h-12 overflow-hidden">
            @foreach (var amenity in Model.Amenities.Take(4))
            {
                <span class="px-2 py-1 bg-surface-container-low text-on-surface-variant rounded-md text-[10px] font-medium border border-slate-100">@amenity</span>
            }
            @if (Model.Amenities.Count > 4)
            {
                <span class="px-2 py-1 bg-surface-container-low text-on-surface-variant rounded-md text-[10px] font-medium border border-slate-100">+@(Model.Amenities.Count - 4)</span>
            }
        </div>
        
        <div class="mt-auto">
            <a asp-controller="Student" asp-action="ApartmentDetails" asp-route-id="@Model.ApartmentId" class="block w-full text-center px-6 py-2.5 bg-surface-container-low text-deep-teal font-bold rounded-xl hover:bg-deep-teal hover:text-white transition-all no-underline btn-interact border border-transparent hover:shadow-lg">
                View Details
            </a>
        </div>
    </div>
</article>
