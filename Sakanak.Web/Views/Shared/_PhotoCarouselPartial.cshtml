@model IReadOnlyList<Sakanak.Web.Models.ViewModels.Landlord.ApartmentPhotoViewModel>
@{
    var carouselId = $"carousel-{Guid.NewGuid():N}";
}

@if (Model.Count == 0)
{
    <div class="border rounded-3 p-4 text-muted bg-light">No photos uploaded yet.</div>
}
else
{
    <div id="@carouselId" class="carousel slide photo-carousel" data-bs-ride="false">
        <div class="carousel-inner">
            @for (var i = 0; i < Model.Count; i++)
            {
                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                    <a href="@Url.Content(Model[i].Url)" target="_blank" rel="noreferrer">
                        <img src="@Url.Content(Model[i].Url)" class="d-block w-100 photo-carousel-image" alt="Apartment photo" loading="lazy" />
                    </a>
                    <div class="photo-counter">@(i + 1) / @Model.Count</div>
                </div>
            }
        </div>

        @if (Model.Count > 1)
        {
            <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
            <div class="photo-thumbnail-strip">
                @for (var i = 0; i < Model.Count; i++)
                {
                    <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i" class="photo-thumbnail-button @(i == 0 ? "active" : string.Empty)">
                        <img src="@Url.Content(Model[i].Url)" alt="Photo thumbnail" loading="lazy" />
                    </button>
                }
            </div>
        }
    </div>
}
