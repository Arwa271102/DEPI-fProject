@inject Sakanak.DAL.UnitOfWork.IUnitOfWork UnitOfWork
@inject Microsoft.AspNetCore.Identity.UserManager<Sakanak.Domain.Entities.ApplicationUser> UserManager
@inject Sakanak.BLL.Interfaces.INotificationService NotificationService
@inject Sakanak.BLL.Interfaces.IMessageService MessageService
@using Microsoft.EntityFrameworkCore
@{
    string? userPhotoUrl = null;
    string studentName = User.Identity?.Name ?? "Student";
    string studentMajor = "";
    int unreadNotificationsCount = 0;
    int unreadMessagesCount = 0;
    IReadOnlyList<Sakanak.BLL.DTOs.Notifications.NotificationDto> recentNotifications = Array.Empty<Sakanak.BLL.DTOs.Notifications.NotificationDto>();
    
    if (User.Identity?.IsAuthenticated == true)
    {
        var userIdValue = UserManager.GetUserId(User);
        if (Guid.TryParse(userIdValue, out var userId))
        {
            unreadNotificationsCount = await NotificationService.GetUnreadCountAsync(userId);
            unreadMessagesCount = await MessageService.GetUnreadMessageCountAsync(userId);
            var notificationsResult = await NotificationService.GetRecentNotificationsAsync(userId, 5);
            if (notificationsResult.Succeeded)
            {
                recentNotifications = notificationsResult.Data!;
            }

            if (User.IsInRole("Student"))
            {
                var student = await UnitOfWork.Students.GetByUserIdAsync(userId);
                if (student is not null)
                {
                    studentMajor = student.Faculty ?? "";
                    var media = await UnitOfWork.Media.GetImagesByEntityAsync("Student", student.StudentId);
                    userPhotoUrl = media.FirstOrDefault()?.Url;
                }
            }
        }
    }

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

    bool IsActive(string action) => currentAction.Equals(action, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sakanak</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-fixed-dim": "#8fd1d9",
                        "on-primary-container": "#90d2da",
                        "error": "#ba1a1a",
                        "success-green": "#10B981",
                        "on-tertiary": "#ffffff",
                        "primary-fixed": "#abeef6",
                        "inverse-surface": "#2e3131",
                        "on-error-container": "#93000a",
                        "deep-teal": "#0D5C63",
                        "outline": "#6f797a",
                        "sand-light": "#F4F1EA",
                        "tertiary-fixed": "#ffdcc6",
                        "surface-container": "#eceeee",
                        "surface-container-low": "#f2f4f4",
                        "inverse-primary": "#8fd1d9",
                        "surface-landlord": "#F8FAFC",
                        "on-background": "#191c1d",
                        "error-container": "#ffdad6",
                        "surface-variant": "#e1e3e3",
                        "on-secondary": "#ffffff",
                        "secondary-fixed": "#e5e2db",
                        "on-error": "#ffffff",
                        "on-tertiary-container": "#fcb88a",
                        "on-primary-fixed": "#002023",
                        "surface-admin": "#F1F5F9",
                        "tertiary-container": "#784722",
                        "primary": "#004349",
                        "surface-tint": "#20686f",
                        "secondary": "#5f5e59",
                        "outline-variant": "#bfc8c9",
                        "danger-red": "#EF4444",
                        "background": "#f8fafa",
                        "surface-bright": "#f8fafa",
                        "on-tertiary-fixed-variant": "#693b17",
                        "surface-container-lowest": "#ffffff",
                        "warning-amber": "#F59E0B",
                        "surface-container-high": "#e6e8e8",
                        "primary-container": "#0d5c63",
                        "surface-student": "#FFFFFF",
                        "secondary-fixed-dim": "#c9c6c0",
                        "surface": "#f8fafa",
                        "on-secondary-fixed": "#1c1c18",
                        "slate-gray": "#475569",
                        "on-primary-fixed-variant": "#004f55",
                        "tertiary-fixed-dim": "#fcb889",
                        "on-secondary-fixed-variant": "#474742",
                        "on-secondary-container": "#65645f",
                        "on-surface-variant": "#3f484a",
                        "secondary-container": "#e5e2db",
                        "inverse-on-surface": "#eff1f1",
                        "tertiary": "#5c310d",
                        "surface-dim": "#d8dada",
                        "surface-container-highest": "#e1e3e3",
                        "on-tertiary-fixed": "#301400",
                        "on-primary": "#ffffff",
                        "on-surface": "#191c1d",
                        "info-blue": "#3B82F6"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "section-gap": "80px",
                        "stack-lg": "32px",
                        "container-max": "1280px",
                        "margin-mobile": "16px",
                        "card-padding": "24px",
                        "stack-md": "16px",
                        "stack-sm": "8px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "display-hero": ["Manrope"],
                        "status-chip": ["Work Sans"],
                        "headline-h2": ["Manrope"],
                        "body-lg": ["Work Sans"],
                        "body-base": ["Work Sans"],
                        "headline-h1": ["Manrope"],
                        "label-sm": ["Work Sans"]
                    },
                    "fontSize": {
                        "display-hero": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "800"}],
                        "status-chip": ["12px", {"lineHeight": "1", "letterSpacing": "0.03em", "fontWeight": "600"}],
                        "headline-h2": ["24px", {"lineHeight": "1.4", "fontWeight": "600"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "body-base": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "headline-h1": ["32px", {"lineHeight": "1.3", "fontWeight": "700"}],
                        "label-sm": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500"}]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        .sidebar-item-transition { transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 24px;
        }
        .bento-card {
            background: #ffffff;
            border-radius: 1rem;
            padding: 24px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .bento-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        /* Mobile menu overlay */
        #mobile-menu { display: none; }
        #mobile-menu.open { display: block; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background font-body-base text-on-surface">
    
    <!-- Mobile Menu Button & Logo -->
    <div class="lg:hidden fixed top-0 left-0 w-full h-16 bg-surface-student border-b border-outline-variant z-40 flex justify-between items-center px-4">
        <h1 class="text-headline-h2 font-headline-h1 text-deep-teal m-0">Sakanak</h1>
        <button id="mobile-menu-btn" class="p-2 text-on-surface-variant focus:outline-none">
            <span class="material-symbols-outlined">menu</span>
        </button>
    </div>

    <!-- Mobile Overlay -->
    <div id="mobile-overlay" class="fixed inset-0 bg-on-surface/50 z-40 hidden lg:hidden"></div>

    <!-- Fixed Side Navigation -->
    <aside id="sidebar" class="fixed left-0 top-0 h-screen w-[280px] bg-surface-student shadow-sm flex flex-col border-r border-outline-variant p-gutter z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-300">
        
        <div class="mb-stack-lg hidden lg:block">
            <h1 class="text-headline-h1 font-headline-h1 text-deep-teal m-0">Sakanak</h1>
            <p class="text-label-sm font-label-sm text-outline m-0">Student Portal</p>
        </div>

        <!-- Mobile close button -->
        <div class="flex justify-end lg:hidden mb-4">
            <button id="close-sidebar-btn" class="text-on-surface-variant p-2">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <nav class="flex-grow flex flex-col gap-stack-sm overflow-y-auto">
            <!-- Active Navigation -->
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("Dashboard") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="Dashboard">
                <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
                <span class="font-label-sm">Dashboard</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("SearchApartments") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="SearchApartments">
                <span class="material-symbols-outlined" data-icon="search">search</span>
                <span class="font-label-sm">Browse Apartments</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("FindRoommates") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="FindRoommates">
                <span class="material-symbols-outlined" data-icon="diversity_3">diversity_3</span>
                <span class="font-label-sm">Find Roommates</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("MyApartment") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="MyApartment">
                <span class="material-symbols-outlined" data-icon="home_work">home_work</span>
                <span class="font-label-sm">My Apartment</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("MyBookings") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="MyBookings">
                <span class="material-symbols-outlined" data-icon="calendar_today">calendar_today</span>
                <span class="font-label-sm">My Bookings</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("MyContracts") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="MyContracts">
                <span class="material-symbols-outlined" data-icon="description">description</span>
                <span class="font-label-sm">Contracts</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("MyPayments") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="MyPayments">
                <span class="material-symbols-outlined" data-icon="payments">payments</span>
                <span class="font-label-sm">Payments</span>
            </a>
            <a class="flex items-center gap-stack-md px-4 py-3 rounded-lg sidebar-item-transition active:scale-[0.98] @(IsActive("Profile") || IsActive("Questionnaire") ? "bg-primary-container text-white" : "text-on-surface-variant hover:bg-surface-container-low")" asp-controller="Student" asp-action="Profile">
                <span class="material-symbols-outlined" data-icon="person">person</span>
                <span class="font-label-sm">Profile</span>
            </a>
            
            <div class="mt-4 pt-4 border-t border-outline-variant">
                <a asp-controller="Account" asp-action="Settings" class="w-full flex items-center gap-stack-md px-4 py-3 text-on-surface-variant hover:bg-surface-container-low rounded-lg sidebar-item-transition active:scale-[0.98] no-underline mb-1">
                    <span class="material-symbols-outlined" data-icon="settings">settings</span>
                    <span class="font-label-sm">Settings</span>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full flex items-center gap-stack-md px-4 py-3 text-danger-red hover:bg-error-container/50 rounded-lg sidebar-item-transition active:scale-[0.98] text-left border-0 bg-transparent">
                        <span class="material-symbols-outlined" data-icon="logout">logout</span>
                        <span class="font-label-sm">Logout</span>
                    </button>
                </form>
            </div>
        </nav>

        <div class="mt-auto pt-stack-md border-t border-outline-variant">
            <div class="flex items-center gap-stack-md px-2">
                <div class="w-10 h-10 rounded-full bg-primary-fixed-dim flex items-center justify-center text-primary overflow-hidden shadow-sm">
                    @if (!string.IsNullOrEmpty(userPhotoUrl))
                    {
                        <img class="w-full h-full object-cover" src="@Url.Content(userPhotoUrl)" alt="@studentName" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-[20px]">person</span>
                    }
                </div>
                <div class="flex flex-col">
                    <span class="font-label-sm font-bold text-on-surface line-clamp-1">@studentName</span>
                    <span class="text-[12px] text-outline line-clamp-1">@(string.IsNullOrEmpty(studentMajor) ? "Student" : studentMajor)</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="lg:ml-[280px] min-h-screen pt-16 lg:pt-0 flex flex-col">
        <!-- Top Nav Bar (Desktop only) -->
        <header class="hidden lg:flex fixed top-0 right-0 w-[calc(100%-280px)] h-16 bg-surface-student/90 backdrop-blur-md border-b border-outline-variant z-10 justify-between items-center px-gutter">
            <div class="flex items-center gap-stack-md w-1/3">
                <form asp-controller="Student" asp-action="SearchApartments" method="get" class="relative w-full max-w-sm">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">search</span>
                    <input name="city" class="w-full pl-10 pr-4 py-2 bg-surface-container-low border-transparent focus:border-deep-teal rounded-lg text-label-sm focus:ring-2 focus:ring-deep-teal/20 outline-none transition-all" placeholder="Search apartments by city..." type="text"/>
                </form>
            </div>
            
            <div class="flex items-center gap-gutter relative">
                
                <!-- Notifications Dropdown -->
                <div class="relative group">
                    <button class="relative p-2 text-on-surface-variant hover:bg-surface-container-low rounded-full transition-colors outline-none focus:ring-2 focus:ring-deep-teal/20">
                        <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
                        @if (unreadNotificationsCount > 0)
                        {
                            <span class="absolute top-1 right-1 w-2 h-2 bg-danger-red rounded-full"></span>
                        }
                    </button>
                    
                    <!-- Dropdown Panel -->
                    <div class="absolute right-0 mt-2 w-80 bg-surface-student rounded-xl shadow-lg border border-outline-variant/30 overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                        <div class="px-4 py-3 border-b border-outline-variant/30 flex justify-between items-center bg-surface-variant/20">
                            <h4 class="font-bold text-label-sm m-0">Notifications</h4>
                            <a asp-controller="Notifications" asp-action="Index" class="text-[12px] text-deep-teal font-medium hover:underline">View All</a>
                        </div>
                        <div class="max-h-[300px] overflow-y-auto">
                            @if (recentNotifications.Count == 0)
                            {
                                <div class="px-4 py-6 text-center text-outline text-label-sm">No new notifications.</div>
                            }
                            else
                            {
                                @foreach (var notification in recentNotifications)
                                {
                                    <a asp-controller="Notifications" asp-action="Open" asp-route-id="@notification.NotificationId" class="block px-4 py-3 hover:bg-surface-container-low transition-colors border-b border-outline-variant/10 last:border-0 @(notification.IsRead ? "opacity-70" : "")">
                                        <div class="flex gap-3">
                                            <div class="w-8 h-8 rounded-full bg-primary-fixed/30 text-deep-teal flex items-center justify-center flex-shrink-0 mt-0.5">
                                                <span class="material-symbols-outlined text-[16px]">notifications</span>
                                            </div>
                                            <div>
                                                <p class="text-label-sm font-bold text-on-surface mb-0.5 leading-tight @(notification.IsRead ? "font-medium" : "font-bold")">@notification.Title</p>
                                                <p class="text-[12px] text-outline line-clamp-2 leading-tight">@notification.Message</p>
                                            </div>
                                        </div>
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Messages Button -->
                <a asp-controller="Messages" asp-action="Index" class="relative p-2 text-on-surface-variant hover:bg-surface-container-low rounded-full transition-colors">
                    <span class="material-symbols-outlined" data-icon="chat_bubble">chat_bubble</span>
                    @if (unreadMessagesCount > 0)
                    {
                        <span class="absolute -top-1 -right-1 bg-deep-teal text-white text-[10px] w-4 h-4 flex items-center justify-center rounded-full font-bold">@unreadMessagesCount</span>
                    }
                </a>


            </div>
        </header>

        <!-- Dynamic Content -->
        <div class="flex-grow pt-4 lg:pt-24 px-4 sm:px-6 lg:px-gutter pb-gutter relative">
            @await Html.PartialAsync("_AlertMessagesPartial")
            
            @RenderBody()
        </div>
        
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        // Mobile Sidebar Toggle
        $(document).ready(function() {
            const sidebar = $('#sidebar');
            const overlay = $('#mobile-overlay');
            const toggleBtn = $('#mobile-menu-btn');
            const closeBtn = $('#close-sidebar-btn');

            function toggleSidebar() {
                sidebar.toggleClass('-translate-x-full');
                overlay.toggleClass('hidden');
            }

            toggleBtn.on('click', toggleSidebar);
            closeBtn.on('click', toggleSidebar);
            overlay.on('click', toggleSidebar);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
