@model Sakanak.Web.Models.ViewModels.Student.ApartmentSearchViewModel

<form method="get" class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24 space-y-6">
    <div>
        <h4 class="text-sm font-bold text-deep-teal uppercase tracking-wider mb-4">Location</h4>
        <select name="city" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-600 focus:ring-2 focus:ring-deep-teal outline-none transition-all">
            <option value="">Any city</option>
            @foreach (var city in Model.AvailableCities)
            {
                <option value="@city" selected="@(Model.Search.City == city ? "selected" : null)">@city</option>
            }
        </select>
    </div>

    <div>
        <h4 class="text-sm font-bold text-deep-teal uppercase tracking-wider mb-4">Price Range</h4>
        <div class="flex items-center gap-2 mb-2">
            <div class="flex-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase">Min</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs">$</span>
                    <input type="number" name="minPrice" value="@Model.Search.MinPrice" class="w-full pl-7 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Min" min="0" />
                </div>
            </div>
            <div class="flex-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase">Max</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs">$</span>
                    <input type="number" name="maxPrice" value="@Model.Search.MaxPrice" class="w-full pl-7 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Max" min="0" />
                </div>
            </div>
        </div>
    </div>

    <div>
        <h4 class="text-sm font-bold text-deep-teal uppercase tracking-wider mb-4">Seats Count</h4>
        <div class="flex items-center gap-2">
            <div class="flex-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase">Min</label>
                <input type="number" name="minSeats" value="@Model.Search.MinSeats" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Min" min="1" />
            </div>
            <div class="flex-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase">Max</label>
                <input type="number" name="maxSeats" value="@Model.Search.MaxSeats" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-deep-teal outline-none" placeholder="Max" min="1" />
            </div>
        </div>
    </div>

    <div>
        <h4 class="text-sm font-bold text-deep-teal uppercase tracking-wider mb-4">Available From</h4>
        <input type="date" name="availableFrom" value="@Model.Search.AvailableFrom?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-deep-teal outline-none text-slate-600" />
    </div>

    <div>
        <h4 class="text-sm font-bold text-deep-teal uppercase tracking-wider mb-4">Amenities</h4>
        <div class="space-y-3 max-h-[200px] overflow-y-auto pr-2 custom-scrollbar">
            @foreach (var amenity in Model.AvailableAmenities)
            {
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input class="w-5 h-5 rounded border-slate-300 text-deep-teal focus:ring-deep-teal transition-colors" type="checkbox" name="amenities" value="@amenity" @(Model.Search.Amenities.Contains(amenity, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                    <span class="text-sm text-slate-600 group-hover:text-deep-teal transition-colors">@amenity</span>
                </label>
            }
        </div>
    </div>

    <div class="pt-4 border-t border-slate-100 flex flex-col gap-2">
        <button type="submit" class="w-full py-3 bg-deep-teal text-white font-bold rounded-xl hover:bg-primary transition-colors btn-interact">
            Apply Filters
        </button>
        <a asp-controller="Student" asp-action="SearchApartments" class="w-full py-3 bg-slate-50 text-deep-teal font-bold rounded-xl hover:bg-slate-100 transition-colors text-center no-underline btn-interact">
            Reset Filters
        </a>
    </div>
    
    <!-- Preserve sorting -->
    <input type="hidden" name="sortBy" value="@Model.Search.SortBy" />
    <input type="hidden" name="desc" value="@Model.Search.Descending.ToString().ToLowerInvariant()" />
    <input type="hidden" name="pageSize" value="@Model.Search.PageSize" />
</form>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 4px;
    }
</style>
