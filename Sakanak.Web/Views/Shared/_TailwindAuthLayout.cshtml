<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sakanak</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary-container": "#90d2da",
                        "primary": "#004349",
                        "warning-amber": "#F59E0B",
                        "tertiary": "#5c310d",
                        "primary-fixed-dim": "#8fd1d9",
                        "info-blue": "#3B82F6",
                        "on-tertiary-fixed-variant": "#693b17",
                        "secondary-container": "#e5e2db",
                        "on-secondary": "#ffffff",
                        "surface-student": "#FFFFFF",
                        "outline": "#6f797a",
                        "slate-gray": "#475569",
                        "surface-landlord": "#F8FAFC",
                        "on-surface-variant": "#3f484a",
                        "surface-container-highest": "#e1e3e3",
                        "danger-red": "#EF4444",
                        "inverse-surface": "#2e3131",
                        "inverse-on-surface": "#eff1f1",
                        "success-green": "#10B981",
                        "on-primary-fixed": "#002023",
                        "surface-dim": "#d8dada",
                        "secondary-fixed-dim": "#c9c6c0",
                        "on-surface": "#191c1d",
                        "on-tertiary": "#ffffff",
                        "sand-light": "#F4F1EA",
                        "surface-variant": "#e1e3e3",
                        "tertiary-fixed": "#ffdcc6",
                        "deep-teal": "#0D5C63",
                        "error": "#ba1a1a",
                        "secondary": "#5f5e59",
                        "surface-container-high": "#e6e8e8",
                        "surface-container-lowest": "#ffffff",
                        "background": "#f8fafa",
                        "on-secondary-fixed-variant": "#474742",
                        "tertiary-container": "#784722",
                        "on-tertiary-container": "#fcb88a",
                        "on-primary": "#ffffff",
                        "primary-container": "#0d5c63",
                        "on-error": "#ffffff",
                        "on-secondary-fixed": "#1c1c18",
                        "surface-container": "#eceeee",
                        "surface-admin": "#F1F5F9",
                        "surface-container-low": "#f2f4f4",
                        "surface-bright": "#f8fafa",
                        "outline-variant": "#bfc8c9",
                        "on-tertiary-fixed": "#301400",
                        "on-background": "#191c1d",
                        "error-container": "#ffdad6",
                        "primary-fixed": "#abeef6",
                        "surface": "#f8fafa",
                        "secondary-fixed": "#e5e2db",
                        "tertiary-fixed-dim": "#fcb889",
                        "on-primary-fixed-variant": "#004f55",
                        "inverse-primary": "#8fd1d9",
                        "on-secondary-container": "#65645f",
                        "surface-tint": "#20686f",
                        "on-error-container": "#93000a"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "stack-lg": "32px",
                        "margin-mobile": "16px",
                        "card-padding": "24px",
                        "stack-sm": "8px",
                        "gutter": "24px",
                        "container-max": "1280px",
                        "stack-md": "16px",
                        "section-gap": "80px"
                    },
                    "fontFamily": {
                        "label-sm": ["Work Sans"],
                        "headline-h1": ["Manrope"],
                        "body-lg": ["Work Sans"],
                        "status-chip": ["Work Sans"],
                        "body-base": ["Work Sans"],
                        "headline-h2": ["Manrope"],
                        "display-hero": ["Manrope"]
                    },
                    "fontSize": {
                        "label-sm": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500"}],
                        "headline-h1": ["32px", {"lineHeight": "1.3", "fontWeight": "700"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "status-chip": ["12px", {"lineHeight": "1", "letterSpacing": "0.03em", "fontWeight": "600"}],
                        "body-base": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "headline-h2": ["24px", {"lineHeight": "1.4", "fontWeight": "600"}],
                        "display-hero": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "800"}]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        .float-animation {
            animation: float 6s ease-in-out infinite;
        }
        .animate-float { 
            animation: float 4s ease-in-out infinite; 
        }
        .glass-card, .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .form-input-focus:focus-within {
            box-shadow: 0 0 0 2px rgba(13, 92, 99, 0.1);
            border-color: #0D5C63;
        }
        .btn-interact:active {
            transform: scale(0.98);
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background text-on-background min-h-screen font-body-base flex flex-col">
    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
