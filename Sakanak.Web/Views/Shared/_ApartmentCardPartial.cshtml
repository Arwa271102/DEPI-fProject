@model Sakanak.Web.Models.ViewModels.Landlord.ApartmentListItemViewModel

<div class="card border-0 shadow-sm h-100 property-card">
    <div class="property-card-image-wrapper">
        @if (!string.IsNullOrWhiteSpace(Model.PrimaryPhotoUrl))
        {
            <img src="@Url.Content(Model.PrimaryPhotoUrl)" alt="Apartment cover" class="card-img-top property-card-image" />
        }
        else
        {
            <div class="property-card-placeholder d-flex align-items-center justify-content-center">No photo</div>
        }
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-2">
            <div>
                <h5 class="card-title mb-1">@Model.Address</h5>
                <p class="text-muted small mb-2">@Model.City</p>
            </div>
            @await Html.PartialAsync("_StatusBadgePartial", Model.LatestRequestStatus)
        </div>
        <div class="small text-muted d-flex gap-3 mb-3">
            <span>@Model.PricePerMonth.ToString("C0") / month</span>
            <span>@Model.TotalSeats seats</span>
        </div>
        <a asp-controller="Landlord" asp-action="ApartmentDetails" asp-route-id="@Model.ApartmentId" class="btn btn-outline-dark btn-sm">View Details</a>
    </div>
</div>
