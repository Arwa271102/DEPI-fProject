@inject Sakanak.DAL.UnitOfWork.IUnitOfWork UnitOfWork
@inject Microsoft.AspNetCore.Identity.UserManager<Sakanak.Domain.Entities.ApplicationUser> UserManager
@inject Sakanak.BLL.Interfaces.INotificationService NotificationService
@inject Sakanak.BLL.Interfaces.IMessageService MessageService
@using Microsoft.EntityFrameworkCore
@{
    string? userPhotoUrl = null;
    int pendingLandlordsCount = 0;
    int pendingApartmentsCount = 0;
    int pendingBookingRequestsCount = 0;
    int unreadNotificationsCount = 0;
    int unreadMessagesCount = 0;
    IReadOnlyList<Sakanak.BLL.DTOs.Notifications.NotificationDto> recentNotifications = Array.Empty<Sakanak.BLL.DTOs.Notifications.NotificationDto>();
    if (User.Identity?.IsAuthenticated == true)
    {
        var userIdValue = UserManager.GetUserId(User);
        if (Guid.TryParse(userIdValue, out var userId))
        {
            unreadNotificationsCount = await NotificationService.GetUnreadCountAsync(userId);
            unreadMessagesCount = await MessageService.GetUnreadMessageCountAsync(userId);
            var notificationsResult = await NotificationService.GetRecentNotificationsAsync(userId, 5);
            if (notificationsResult.Succeeded)
            {
                recentNotifications = notificationsResult.Data!;
            }

            if (User.IsInRole("Student"))
            {
                var student = await UnitOfWork.Students.GetByUserIdAsync(userId);
                if (student is not null)
                {
                    var media = await UnitOfWork.Media.GetImagesByEntityAsync("Student", student.StudentId);
                    userPhotoUrl = media.FirstOrDefault()?.Url;
                }
            }
            else if (User.IsInRole("Landlord"))
            {
                var landlord = await UnitOfWork.Landlords.GetByUserIdAsync(userId);
                if (landlord is not null)
                {
                    var media = await UnitOfWork.Media.GetImagesByEntityAsync("Landlord", landlord.LandlordId);
                    userPhotoUrl = media.FirstOrDefault()?.Url;
                    var bookings = await UnitOfWork.Bookings.GetBookingsByLandlordIdAsync(landlord.LandlordId);
                    pendingBookingRequestsCount = bookings.Count(b => b.Status == Sakanak.Domain.Enums.BookingStatus.Pending);
                }
            }
            else if (User.IsInRole("Admin"))
            {
                pendingLandlordsCount = await UnitOfWork.Landlords.GetLandlordsWithDetailsQuery()
                    .AsNoTracking()
                    .CountAsync(l => !l.VerificationStatus && l.VerificationRequestedAt != null && l.RejectionReason == null);
                pendingApartmentsCount = await UnitOfWork.Requests.GetRequestsWithDetailsQuery()
                    .AsNoTracking()
                    .CountAsync(r => r.Status == Sakanak.Domain.Enums.RequestStatus.Pending);
            }
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sakanak</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sakanak-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sakanak.Web.styles.css" asp-append-version="true" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light navbar-stitch">
            <div class="container-fluid max-w-7xl">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Sakanak
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-stitch" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-stitch" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Admin" asp-action="PendingRequests">
                                        Pending Requests
                                        @if (pendingApartmentsCount > 0)
                                        {
                                            <span class="badge rounded-pill bg-danger" style="font-size: 0.7rem; padding: 0.25em 0.5em;">@pendingApartmentsCount</span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Admin" asp-action="PendingContracts">Contracts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Admin" asp-action="PendingLandlordVerifications">
                                        Verifications
                                        @if (pendingLandlordsCount > 0)
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark" style="font-size: 0.7rem; padding: 0.25em 0.5em;">@pendingLandlordsCount</span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Admin" asp-action="Landlords">Landlords</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Admin" asp-action="Apartments">Apartments</a>
                                </li>
                            }

                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="SearchApartments">Search Apartments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="FindRoommates">Find Roommates</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="Profile">My Profile</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="Questionnaire">Questionnaire</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="MyBookings">My Bookings</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="MyContracts">My Contracts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="MyRoommates">My Roommates</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Student" asp-action="MyApartment">My Apartment</a>
                                </li>
                            }

                            @if (User.IsInRole("Landlord"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Landlord" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Landlord" asp-action="BookingRequests">
                                        Booking Requests
                                        @if (pendingBookingRequestsCount > 0)
                                        {
                                            <span class="badge rounded-pill bg-danger" style="font-size: 0.7rem; padding: 0.25em 0.5em;">@pendingBookingRequestsCount</span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Landlord" asp-action="Contracts">Contracts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-stitch" asp-controller="Landlord" asp-action="MyApartments">Occupancy</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-sm-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown me-2">
                                <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                    <i class="bi bi-bell"></i>
                                    @if (unreadNotificationsCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@unreadNotificationsCount</span>
                                    }
                                </a>
                                <div class="dropdown-menu dropdown-menu-end p-2 shadow" style="min-width: 320px;">
                                    <div class="d-flex justify-content-between align-items-center px-2 mb-2">
                                        <strong>Notifications</strong>
                                        <a asp-controller="Notifications" asp-action="Index" class="small">View all</a>
                                    </div>
                                    @if (recentNotifications.Count == 0)
                                    {
                                        <div class="dropdown-item text-muted">No notifications yet.</div>
                                    }
                                    else
                                    {
                                        @foreach (var notification in recentNotifications)
                                        {
                                            <a asp-controller="Notifications" asp-action="Open" asp-route-id="@notification.NotificationId" class="dropdown-item rounded-3 @(notification.IsRead ? "" : "fw-semibold")">
                                                <div>@notification.Title</div>
                                                <div class="small text-muted text-wrap">@notification.Message</div>
                                            </a>
                                        }
                                    }
                                </div>
                            </li>
                            <li class="nav-item me-2">
                                <a class="nav-link position-relative" asp-controller="Messages" asp-action="Index" title="Messages">
                                    <i class="bi bi-chat-dots"></i>
                                    @if (unreadMessagesCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@unreadMessagesCount</span>
                                    }
                                </a>
                            </li>

                            @if (!string.IsNullOrWhiteSpace(userPhotoUrl))
                            {
                                <li class="nav-item me-2">
                                    <img src="@Url.Content(userPhotoUrl)" alt="Profile photo" class="nav-profile-photo" />
                                </li>
                            }
                            <li class="nav-item">
                                <span class="nav-link text-muted">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-stitch" asp-controller="Account" asp-action="Settings">Settings</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link nav-link-stitch">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-stitch" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (ViewData["IsHomePage"] != null && (bool)ViewData["IsHomePage"] == true)
    {
        <main role="main" class="flex-grow-1">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container flex-grow-1">
            <main role="main" class="pb-3 pt-4">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="bg-white border-top py-5 mt-auto">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div class="mb-3 mb-md-0 text-center text-md-start">
                <div class="fs-5 font-manrope fw-bold text-deep-teal mb-1">Sakanak</div>
                <p class="font-manrope small text-muted mb-0">© 2024 Sakanak Student Housing. All rights reserved.</p>
            </div>
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a class="font-manrope small text-muted text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                <a class="font-manrope small text-muted text-decoration-none" href="#">Terms of Service</a>
                <a class="font-manrope small text-muted text-decoration-none" href="#">Cookie Policy</a>
                <a class="font-manrope small text-muted text-decoration-none" href="#">Contact Support</a>
            </div>
            <div class="d-flex gap-3 mt-3 mt-md-0">
                <a class="text-muted text-decoration-none" href="#"><span class="material-symbols-outlined">language</span></a>
                <a class="text-muted text-decoration-none" href="#"><span class="material-symbols-outlined">public</span></a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 800,
            once: true,
            offset: 50
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
