@{
    ViewData["Title"] = "Error";
    Layout = "_TailwindAuthLayout";
}

<!-- Main Container -->
<div class="min-h-screen flex items-center justify-center relative overflow-hidden bg-surface-student py-12 px-4 sm:px-6 lg:px-8">
    
    <!-- Abstract Background Elements -->
    <div class="absolute top-0 left-0 w-72 h-72 bg-error/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-primary-container/5 rounded-full translate-x-1/3 translate-y-1/3 blur-3xl"></div>
    
    <!-- Error Card -->
    <div class="w-full max-w-md bg-surface-student rounded-xl shadow-[0_10px_40px_-15px_rgba(13,92,99,0.1)] p-8 border border-error/20 relative z-10 text-center animate-slide-up">
        
        <!-- Icon -->
        <div class="w-20 h-20 bg-error/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-error">error</span>
        </div>

        <h2 class="text-2xl font-headline-h2 text-deep-teal font-bold mb-4">Oops! Something went wrong.</h2>
        
        <div class="bg-error/10 text-error font-medium p-4 rounded-lg mb-6 text-left text-sm border border-error/20">
            <p>We couldn't confirm your email. The link might be invalid or has expired.</p>
        </div>

        <a asp-controller="Home" asp-action="Index" class="w-full bg-deep-teal text-white py-3 px-4 rounded-lg hover:bg-deep-teal/90 transition-all font-medium flex items-center justify-center group focus:ring-4 focus:ring-deep-teal/20 outline-none">
            <span class="material-symbols-outlined mr-2 group-hover:-translate-x-1 transition-transform">arrow_back</span>
            Return to Home
        </a>
    </div>
</div>
