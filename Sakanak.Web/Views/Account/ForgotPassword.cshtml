@model Sakanak.Web.Models.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_TailwindAuthLayout";
}

<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center p-gutter relative overflow-hidden mt-12">
    <!-- Atmospheric Background Element -->
    <div class="absolute inset-0 z-0 opacity-40 pointer-events-none">
    </div>
    
    <!-- Forgot Password Card -->
    <div class="z-10 w-full max-w-[480px]">
        <div class="glass-card rounded-xl p-card-padding flex flex-col gap-stack-lg border border-white">
            
            <!-- Branding/Icon Section -->
            <div class="flex flex-col items-center text-center gap-stack-sm">
                <div class="w-16 h-16 bg-primary-container/10 rounded-full flex items-center justify-center text-deep-teal mb-2">
                    <span class="material-symbols-outlined !text-4xl" style="font-variation-settings: 'FILL' 0;">lock_reset</span>
                </div>
                <h1 class="font-headline-h1 text-headline-h1 text-deep-teal">Forgot Password?</h1>
                <p class="font-body-base text-body-base text-slate-gray max-w-[320px]">
                    Enter your email address and we'll send you a link to reset your password.
                </p>
            </div>
            
            <!-- Form Section -->
            <form asp-action="ForgotPassword" method="post" class="flex flex-col gap-stack-md">
                <div asp-validation-summary="ModelOnly" class="text-danger-red text-sm font-medium"></div>

                <div class="flex flex-col gap-1.5">
                    <label asp-for="Email" class="font-label-sm text-label-sm text-deep-teal ml-1"></label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-deep-teal transition-colors">mail</span>
                        <input asp-for="Email" class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-deep-teal focus:border-deep-teal outline-none transition-all font-body-base text-on-surface" placeholder="name@university.edu" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger-red text-xs mt-1 ml-1 block"></span>
                </div>
                
                <button type="submit" class="w-full bg-deep-teal text-white font-label-sm text-label-sm py-4 rounded-lg shadow-lg hover:bg-primary transition-all btn-interact flex items-center justify-center gap-2 mt-2">
                    Send Reset Link
                    <span class="material-symbols-outlined !text-lg">arrow_forward</span>
                </button>
            </form>
            
            <!-- Navigation Back -->
            <div class="flex flex-col items-center gap-stack-md pt-2 border-t border-slate-100">
                <a asp-action="Login" class="group flex items-center gap-2 font-label-sm text-label-sm text-deep-teal hover:text-primary transition-colors">
                    <span class="material-symbols-outlined !text-lg group-hover:-translate-x-1 transition-transform">arrow_back</span>
                    Back to Sign In
                </a>
            </div>
        </div>
        
        <!-- Contextual Help / Info -->
        <div class="mt-8 flex flex-col gap-4 text-center">
            <div class="inline-flex items-center justify-center gap-3 px-6 py-3 bg-white/60 backdrop-blur-sm rounded-full border border-slate-200 self-center">
                <div class="flex -space-x-2">
                    <div class="w-6 h-6 rounded-full border-2 border-white bg-slate-300"></div>
                    <div class="w-6 h-6 rounded-full border-2 border-white bg-slate-400"></div>
                </div>
                <p class="text-[13px] font-medium text-slate-600">Need help? <a href="#" class="text-deep-teal underline decoration-teal-500/30">Contact support</a></p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
