@model Sakanak.Web.Models.ViewModels.Account.ExternalRegisterViewModel
@{
    ViewData["Title"] = "Complete Registration";
    Layout = "_TailwindAuthLayout";
}

<!-- Main Container -->
<div class="min-h-screen flex items-center justify-center relative overflow-hidden bg-surface-student py-12 px-4 sm:px-6 lg:px-8">
    
    <!-- Abstract Background Elements -->
    <div class="absolute top-0 left-0 w-72 h-72 bg-deep-teal/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-primary-container/5 rounded-full translate-x-1/3 translate-y-1/3 blur-3xl"></div>
    
    <!-- Registration Card -->
    <div class="w-full max-w-2xl bg-surface-student rounded-xl shadow-[0_10px_40px_-15px_rgba(13,92,99,0.1)] p-8 border border-outline-variant/30 relative z-10 animate-slide-up">
        
        <div class="text-center mb-8">
            <h2 class="text-2xl font-headline-h2 text-deep-teal font-bold">One last step!</h2>
            <p class="text-on-surface-variant font-body-base mt-2">Complete your @Model.Role profile to get started</p>
        </div>

        <form asp-action="ExternalRegistration" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-error text-sm mb-4"></div>
            
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Role" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <!-- Read-only info -->
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Email Address</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">mail</span>
                        </span>
                        <input class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface-variant text-on-surface-variant outline-none" value="@Model.Email" readonly />
                    </div>
                </div>

                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-on-surface mb-2"></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">person</span>
                        </span>
                        <input asp-for="Name" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" placeholder="Enter your full name" />
                    </div>
                    <span asp-validation-for="Name" class="text-error text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Username" class="block text-sm font-medium text-on-surface mb-2"></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">alternate_email</span>
                        </span>
                        <input asp-for="Username" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" placeholder="Choose a username" />
                    </div>
                    <span asp-validation-for="Username" class="text-error text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-medium text-on-surface mb-2"></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">phone</span>
                        </span>
                        <input asp-for="PhoneNumber" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" placeholder="e.g. +201234567890" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-error text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Age" class="block text-sm font-medium text-on-surface mb-2"></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">calendar_today</span>
                        </span>
                        <input asp-for="Age" type="number" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" />
                    </div>
                    <span asp-validation-for="Age" class="text-error text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-on-surface mb-2"></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">key</span>
                        </span>
                        <input asp-for="Password" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" />
                    </div>
                    <span asp-validation-for="Password" class="text-error text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-medium text-on-surface mb-2"></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                            <span class="material-symbols-outlined text-lg">password</span>
                        </span>
                        <input asp-for="ConfirmPassword" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-error text-xs mt-1 block"></span>
                </div>

                @if (Model.Role == "Student")
                {
                    <!-- Student Specific Fields -->
                    <div>
                        <label asp-for="University" class="block text-sm font-medium text-on-surface mb-2"></label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                                <span class="material-symbols-outlined text-lg">school</span>
                            </span>
                            <input asp-for="University" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" placeholder="e.g. Cairo University" />
                        </div>
                        <span asp-validation-for="University" class="text-error text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Faculty" class="block text-sm font-medium text-on-surface mb-2"></label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-outline-variant">
                                <span class="material-symbols-outlined text-lg">menu_book</span>
                            </span>
                            <input asp-for="Faculty" class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface focus:ring-2 focus:ring-deep-teal/20 focus:border-deep-teal transition-all outline-none" placeholder="e.g. Engineering" />
                        </div>
                        <span asp-validation-for="Faculty" class="text-error text-xs mt-1 block"></span>
                    </div>
                }
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full bg-deep-teal text-white py-3 px-4 rounded-lg hover:bg-deep-teal/90 transition-all font-medium focus:ring-4 focus:ring-deep-teal/20 outline-none shadow-md">
                    Complete Registration
                </button>
                <div class="text-center mt-4">
                    <a asp-action="SelectRole" class="text-deep-teal hover:text-primary-container text-sm font-medium transition-colors flex items-center justify-center">
                        <span class="material-symbols-outlined text-sm mr-1">arrow_back</span>
                        Back to Role Selection
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
