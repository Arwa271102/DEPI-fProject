@{
    ViewData["Title"] = "Select Your Role";
    Layout = "_TailwindAuthLayout";
}

<!-- Main Container -->
<div class="min-h-screen flex items-center justify-center relative overflow-hidden bg-surface-student py-12 px-4 sm:px-6 lg:px-8">
    
    <!-- Abstract Background Elements -->
    <div class="absolute top-0 left-0 w-72 h-72 bg-deep-teal/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-primary-container/5 rounded-full translate-x-1/3 translate-y-1/3 blur-3xl"></div>
    
    <!-- Selection Card -->
    <div class="w-full max-w-lg bg-surface-student rounded-xl shadow-[0_10px_40px_-15px_rgba(13,92,99,0.1)] p-8 border border-outline-variant/30 relative z-10 animate-slide-up">
        
        <div class="text-center mb-8">
            <h2 class="text-3xl font-headline-h2 text-deep-teal font-bold">Welcome to Sakanak!</h2>
            <p class="text-on-surface-variant font-body-base mt-2">You've successfully signed in. Before we continue, please choose your account type:</p>
        </div>

        <form asp-action="SelectRole" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-error text-sm mb-4 text-center"></div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                
                <!-- Student Option -->
                <button type="submit" name="role" value="Student" class="group relative bg-surface border-2 border-outline-variant/50 rounded-xl p-6 hover:border-primary-container hover:bg-primary-container/5 hover:shadow-lg transition-all duration-300 flex flex-col items-center justify-center gap-3 text-center outline-none focus:ring-4 focus:ring-primary-container/30 overflow-hidden hover:-translate-y-1">
                    <div class="absolute inset-0 bg-primary-container/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out z-0"></div>
                    <span class="material-symbols-outlined text-5xl text-primary-container relative z-10">school</span>
                    <div class="relative z-10">
                        <span class="block text-xl font-bold text-deep-teal mb-1">Student</span>
                        <span class="block text-sm text-on-surface-variant font-medium">Looking for housing</span>
                    </div>
                </button>

                <!-- Landlord Option -->
                <button type="submit" name="role" value="Landlord" class="group relative bg-surface border-2 border-outline-variant/50 rounded-xl p-6 hover:border-deep-teal hover:bg-deep-teal/5 hover:shadow-lg transition-all duration-300 flex flex-col items-center justify-center gap-3 text-center outline-none focus:ring-4 focus:ring-deep-teal/30 overflow-hidden hover:-translate-y-1">
                    <div class="absolute inset-0 bg-deep-teal/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out z-0"></div>
                    <span class="material-symbols-outlined text-5xl text-deep-teal relative z-10">real_estate_agent</span>
                    <div class="relative z-10">
                        <span class="block text-xl font-bold text-deep-teal mb-1">Landlord</span>
                        <span class="block text-sm text-on-surface-variant font-medium">Offering properties</span>
                    </div>
                </button>

            </div>
        </form>
    </div>
</div>
