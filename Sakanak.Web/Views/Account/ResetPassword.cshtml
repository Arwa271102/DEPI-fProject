@model Sakanak.Web.Models.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_TailwindAuthLayout";
}

<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center p-gutter relative overflow-hidden mt-12">
    <!-- Atmospheric Background Element -->
    <div class="absolute inset-0 z-0 opacity-40 pointer-events-none"></div>
    
    <!-- Reset Password Card -->
    <div class="z-10 w-full max-w-[480px]">
        <div class="glass-card rounded-xl p-card-padding flex flex-col gap-stack-lg border border-white">
            
            <!-- Branding/Icon Section -->
            <div class="flex flex-col items-center text-center gap-stack-sm">
                <div class="w-16 h-16 bg-primary-container/10 rounded-full flex items-center justify-center text-deep-teal mb-2">
                    <span class="material-symbols-outlined !text-4xl" style="font-variation-settings: 'FILL' 0;">password</span>
                </div>
                <h1 class="font-headline-h1 text-headline-h1 text-deep-teal">Reset Password</h1>
                <p class="font-body-base text-body-base text-slate-gray max-w-[320px]">
                    Please enter your new password below.
                </p>
            </div>
            
            <!-- Form Section -->
            <form asp-action="ResetPassword" method="post" class="flex flex-col gap-stack-md">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Token" />
                
                <div asp-validation-summary="ModelOnly" class="text-danger-red text-sm font-medium"></div>

                <div class="flex flex-col gap-1.5">
                    <label asp-for="NewPassword" class="font-label-sm text-label-sm text-deep-teal ml-1"></label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-deep-teal transition-colors">lock</span>
                        <input asp-for="NewPassword" class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-deep-teal focus:border-deep-teal outline-none transition-all font-body-base text-on-surface" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger-red text-xs mt-1 ml-1 block"></span>
                </div>
                
                <div class="flex flex-col gap-1.5">
                    <label asp-for="ConfirmPassword" class="font-label-sm text-label-sm text-deep-teal ml-1"></label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-deep-teal transition-colors">lock_reset</span>
                        <input asp-for="ConfirmPassword" class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-deep-teal focus:border-deep-teal outline-none transition-all font-body-base text-on-surface" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger-red text-xs mt-1 ml-1 block"></span>
                </div>
                
                <button type="submit" class="w-full bg-deep-teal text-white font-label-sm text-label-sm py-4 rounded-lg shadow-lg hover:bg-primary transition-all btn-interact flex items-center justify-center gap-2 mt-2">
                    Reset Password
                    <span class="material-symbols-outlined !text-lg">check_circle</span>
                </button>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
