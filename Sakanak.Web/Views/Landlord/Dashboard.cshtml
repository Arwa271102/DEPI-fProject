@model Sakanak.Web.Models.ViewModels.Landlord.LandlordDashboardViewModel
@{
    Layout = "_TailwindLandlordLayout";
    ViewData["Title"] = "Landlord Dashboard";
}

<div class="mb-10">
    <h2 class="font-display-lg text-display-lg text-on-surface">Overview</h2>
    <p class="text-on-surface-variant">Track your property performance and management requests.</p>
</div>

@if (Model.AdminUserId.HasValue)
{
    <div class="mb-10 bg-primary-container/10 border border-primary-container/20 p-6 rounded-xl shadow-sm flex items-center justify-between animate-slide-up">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white">
                <span class="material-symbols-outlined">support_agent</span>
            </div>
            <div>
                <h3 class="font-display-lg text-lg text-primary m-0">Contact Platform Admin</h3>
                <p class="text-body-sm text-on-surface-variant m-0">Need help with your account or property verification?</p>
            </div>
        </div>
        <a asp-controller="Messages" asp-action="Index" asp-route-otherUserId="@Model.AdminUserId" class="bg-primary text-white px-6 py-2.5 rounded-lg hover:opacity-90 transition-opacity font-bold no-underline flex items-center gap-2">
            <span class="material-symbols-outlined">chat</span>
            Message Admin
        </a>
    </div>
}

<!-- KPI Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
    <!-- Payments Overview -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm hover:shadow-md transition-shadow">
        <div class="flex justify-between items-start mb-4">
            <span class="p-2 bg-primary-container/10 rounded-lg">
                <span class="material-symbols-outlined text-primary" data-icon="payments">payments</span>
            </span>
            <span class="text-xs font-label-caps text-on-surface-variant uppercase">Payments</span>
        </div>
        <div class="space-y-1">
            <div class="flex items-baseline justify-between">
                <p class="text-on-surface-variant text-body-sm">Paid</p>
                <p class="font-data-mono text-primary font-bold text-lg">@Model.TotalPaidAmount.ToString("C0")</p>
            </div>
            <div class="flex items-baseline justify-between">
                <p class="text-on-surface-variant text-body-sm">Pending</p>
                <p class="font-data-mono text-error font-bold text-lg">@Model.PendingPaymentAmount.ToString("C0")</p>
            </div>
        </div>
    </div>

    <!-- Contracts -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
        <div class="flex justify-between items-start mb-4">
            <span class="p-2 bg-secondary-container/20 rounded-lg">
                <span class="material-symbols-outlined text-secondary" data-icon="description">description</span>
            </span>
            <span class="text-xs font-label-caps text-on-surface-variant uppercase">Contracts</span>
        </div>
        <div class="space-y-1">
            <div class="flex items-baseline justify-between">
                <p class="text-on-surface-variant text-body-sm">Pending</p>
                <p class="font-data-mono text-on-surface font-bold text-lg">@Model.PendingContracts</p>
            </div>
            <div class="flex items-baseline justify-between">
                <p class="text-on-surface-variant text-body-sm">Approved</p>
                <p class="font-data-mono text-on-surface font-bold text-lg">@Model.ApprovedContracts</p>
            </div>
        </div>
    </div>

    <!-- Occupied Apartments -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm relative overflow-hidden">
        <div class="flex justify-between items-start mb-4">
            <span class="p-2 bg-primary-container/10 rounded-lg">
                <span class="material-symbols-outlined text-primary" data-icon="group">group</span>
            </span>
            <div class="flex items-center bg-primary/10 px-2 py-1 rounded">
                <div class="w-2 h-2 rounded-full bg-primary mr-1 animate-pulse"></div>
                <span class="text-[10px] font-label-caps text-primary uppercase">Live</span>
            </div>
        </div>
        <h3 class="text-on-surface-variant font-label-caps mb-1 uppercase">Occupancy Rate</h3>
        <p class="font-display-lg text-display-lg text-on-surface">@Model.OccupancyRate%</p>
        <div class="mt-4 h-1 w-full bg-outline-variant rounded-full overflow-hidden">
            <div class="h-full bg-primary" style="width: @Model.OccupancyRate%"></div>
        </div>
        <p class="text-[11px] text-on-surface-variant mt-2">@Model.OccupiedSeats / @Model.TotalSeats seats occupied</p>
    </div>

    <!-- Total Listings -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
        <div class="flex justify-between items-start mb-4">
            <span class="p-2 bg-tertiary-fixed/30 rounded-lg">
                <span class="material-symbols-outlined text-tertiary" data-icon="home_work">home_work</span>
            </span>
            <span class="text-xs font-label-caps text-on-surface-variant uppercase">Your Listings</span>
        </div>
        <p class="font-display-lg text-display-lg text-on-surface mb-2">@Model.TotalApartments</p>
        <div class="flex gap-4">
            <div class="flex flex-col">
                <span class="text-[10px] font-label-caps text-on-surface-variant uppercase">Active</span>
                <span class="text-body-sm text-primary font-bold">@Model.ActiveApartments</span>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] font-label-caps text-on-surface-variant uppercase">Pending req</span>
                <span class="text-body-sm text-tertiary font-bold">@Model.PendingRequests</span>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] font-label-caps text-on-surface-variant uppercase">Bookings</span>
                <span class="text-body-sm text-error font-bold">@Model.PendingBookingRequests</span>
            </div>
        </div>
    </div>
</div>

<!-- Requests Grid Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
    <!-- Booking Requests -->
    <section class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden flex flex-col">
        <div class="px-6 py-5 border-b border-outline-variant flex justify-between items-center">
            <div>
                <h3 class="font-headline-md text-headline-md text-on-surface">Booking Requests</h3>
                <p class="text-body-sm text-on-surface-variant">New student applications to review</p>
            </div>
            <a asp-action="BookingRequests" class="text-primary font-title-sm hover:underline no-underline">View All</a>
        </div>
        <div class="flex-1 overflow-x-auto">
            @if (Model.RecentBookingRequests.Count == 0)
            {
                <div class="p-6 text-center text-on-surface-variant">No pending booking requests.</div>
            }
            else
            {
                <table class="w-full text-left">
                    <thead class="bg-surface-container-low border-b border-outline-variant">
                        <tr>
                            <th class="px-6 py-3 font-label-caps text-on-surface-variant">Student</th>
                            <th class="px-6 py-3 font-label-caps text-on-surface-variant">Apartment</th>
                            <th class="px-6 py-3 font-label-caps text-on-surface-variant">Date</th>
                            <th class="px-6 py-3 font-label-caps text-on-surface-variant text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @foreach (var booking in Model.RecentBookingRequests)
                        {
                            var initials = string.Join("", booking.StudentName.Split(' ').Select(s => s[0])).ToUpper();
                            <tr class="hover:bg-surface-container-low transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-8 h-8 bg-secondary-container rounded-full flex items-center justify-center text-on-secondary-container font-bold text-xs mr-3">@initials</div>
                                        <div>
                                            <p class="font-body-md text-on-surface leading-none mb-1">@booking.StudentName</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-body-sm text-on-surface font-medium">@booking.ApartmentAddress</td>
                                <td class="px-6 py-4 font-data-mono text-xs text-on-surface-variant">@booking.BookingDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4 text-right">
                                    <a asp-action="ReviewBooking" asp-route-id="@booking.BookingId" class="inline-block px-3 py-1 bg-primary/10 text-primary rounded font-title-sm text-sm hover:bg-primary hover:text-white transition-colors no-underline">Review</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>

    <!-- Admin Decisions Widget -->
    <section class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
        <div class="px-6 py-5 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
            <div>
                <h3 class="font-headline-md text-headline-md text-on-surface">Recent Requests</h3>
                <p class="text-body-sm text-on-surface-variant">Verification and listing approvals</p>
            </div>
            <a asp-action="MyRequests" class="text-primary font-title-sm hover:underline no-underline">See All</a>
        </div>
        <div class="p-6 space-y-6">
            @if (Model.RecentRequests.Count == 0)
            {
                <div class="text-center text-on-surface-variant">No requests submitted yet.</div>
            }
            else
            {
                @foreach (var request in Model.RecentRequests)
                {
                    <div class="flex items-start">
                        <div class="mr-4 mt-1">
                            @if (request.Status == "Approved")
                            {
                                <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">verified</span>
                            }
                            else if (request.Status == "Rejected")
                            {
                                <span class="material-symbols-outlined text-error" style="font-variation-settings: 'FILL' 1;">error</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-tertiary" style="font-variation-settings: 'FILL' 1;">pending</span>
                            }
                        </div>
                        <div class="flex-1">
                            <div class="flex justify-between items-center mb-1">
                                <h4 class="font-title-sm text-on-surface m-0">@request.ApartmentAddress</h4>
                                <span class="text-xs font-data-mono text-on-surface-variant">@request.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                            </div>
                            <p class="text-body-sm text-on-surface-variant mb-2">Request is currently @request.Status</p>
                            @await Html.PartialAsync("_StatusBadgePartial", request.Status)
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<!-- Contracts & Payments Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
    <!-- Contracts Card -->
    <section class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm flex flex-col">
        <div class="px-6 py-5 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
            <div>
                <h3 class="font-headline-md text-headline-md text-on-surface">Recent Contracts</h3>
                <p class="text-body-sm text-on-surface-variant">Your latest active and pending leases</p>
            </div>
            <a asp-action="Contracts" class="text-primary font-title-sm hover:underline no-underline">See All</a>
        </div>
        <div class="flex-1 overflow-x-auto">
            @if (Model.RecentContracts.Count == 0)
            {
                <div class="p-6 text-center text-on-surface-variant">No contracts found.</div>
            }
            else
            {
                <table class="w-full text-left">
                    <tbody class="divide-y divide-outline-variant">
                        @foreach (var contract in Model.RecentContracts.Take(4))
                        {
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="px-6 py-4">
                                    <p class="font-body-md text-on-surface leading-none mb-1">@contract.StudentName</p>
                                    <p class="text-xs text-on-surface-variant">@contract.ApartmentAddress</p>
                                </td>
                                <td class="px-6 py-4">
                                    @await Html.PartialAsync("_StatusBadgePartial", contract.Status)
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a asp-action="ContractDetails" asp-route-id="@contract.ContractId" class="text-primary hover:underline text-sm font-semibold">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>

    <!-- Payments & Total Revenue Card -->
    <section class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm flex flex-col">
        <div class="px-6 py-5 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
            <div>
                <h3 class="font-headline-md text-headline-md text-on-surface">Payments & Revenue</h3>
                <p class="text-body-sm text-on-surface-variant">Total revenue: <strong class="text-primary">@Model.TotalPaidAmount.ToString("C0")</strong></p>
            </div>
            <a asp-action="Payments" class="text-primary font-title-sm hover:underline no-underline">See All</a>
        </div>
        <div class="flex-1 overflow-x-auto">
            @if (Model.RecentPayments.Count == 0)
            {
                <div class="p-6 text-center text-on-surface-variant">No recent payments.</div>
            }
            else
            {
                <table class="w-full text-left">
                    <tbody class="divide-y divide-outline-variant">
                        @foreach (var payment in Model.RecentPayments.Take(4))
                        {
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="px-6 py-4">
                                    <p class="font-body-md text-on-surface font-bold leading-none mb-1">@payment.Amount.ToString("C0")</p>
                                    <p class="text-xs text-on-surface-variant">@(payment.PaymentDate?.ToString("MMM dd, yyyy") ?? payment.DueDate.ToString("MMM dd, yyyy"))</p>
                                </td>
                                <td class="px-6 py-4">
                                    @await Html.PartialAsync("_StatusBadgePartial", payment.Status)
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a asp-action="PaymentDetails" asp-route-id="@payment.PaymentId" class="text-primary hover:underline text-sm font-semibold">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>
</div>

<!-- Occupied Apartments Section -->
<section class="mb-10 bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="px-6 py-5 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
        <div>
            <h3 class="font-headline-md text-headline-md text-on-surface">Occupied Apartments</h3>
            <p class="text-body-sm text-on-surface-variant">Properties with active tenants</p>
        </div>
    </div>
    <div class="p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (Model.RecentOccupiedApartments.Count == 0)
        {
            <div class="col-span-full text-center text-on-surface-variant py-4">No occupied apartments.</div>
        }
        else
        {
            @foreach (var apt in Model.RecentOccupiedApartments)
            {
                <div class="border border-outline-variant rounded-lg p-4 flex flex-col hover:border-primary transition-colors">
                    <div class="flex justify-between items-start mb-2">
                        <h4 class="font-title-sm text-on-surface m-0 line-clamp-1 flex-1">@apt.Address, @apt.City</h4>
                        <span class="bg-[#10B981] text-white text-[10px] px-2 py-1 rounded-full font-bold ml-2 shrink-0">@apt.OccupiedSeats / @apt.TotalSeats Units</span>
                    </div>
                    <p class="text-body-sm text-on-surface-variant mb-4">@apt.MonthlyRevenue.ToString("C0") monthly revenue</p>
                    <a asp-action="ApartmentDetails" asp-route-id="@apt.ApartmentId" class="mt-auto text-primary text-sm font-semibold hover:underline flex items-center gap-1">
                        View Details <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
            }
        }
    </div>
</section>

<!-- Apartments Grid Header & Filters -->
<div class="mt-12 flex flex-col md:flex-row md:items-end justify-between gap-gutter mb-stack-lg">
    <div>
        <h2 class="font-headline-md text-headline-md text-on-surface mb-1">Your Apartments</h2>
        <p class="text-on-surface-variant m-0">A quick overview of all listings tied to your account.</p>
    </div>
    <div class="flex items-center gap-stack-md">
        <a asp-action="CreateApartment" class="flex items-center gap-2 bg-primary text-on-primary px-6 py-2.5 rounded-lg hover:bg-primary-container transition-all active:scale-95 no-underline">
            <span class="material-symbols-outlined">add_circle</span>
            <span class="font-title-sm">Add New Apartment</span>
        </a>
    </div>
</div>

<form method="get" class="flex flex-wrap items-center gap-4 mb-stack-lg p-4 bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm">
    <span class="text-on-surface-variant text-label-caps uppercase mr-2">Filters</span>
    <input type="text" name="city" value="@Model.CityFilter" placeholder="Filter by city..." class="bg-surface-container-low border-none rounded-lg text-body-sm py-2 px-4 focus:ring-primary outline-none" />
    
    <select name="requestStatus" class="bg-surface-container-low border-none rounded-lg text-body-sm py-2 px-4 focus:ring-primary cursor-pointer outline-none">
        <option value="">All statuses</option>
        <option value="Pending" selected="@(Model.RequestStatusFilter == "Pending" ? "selected" : null)">Pending</option>
        <option value="Approved" selected="@(Model.RequestStatusFilter == "Approved" ? "selected" : null)">Approved</option>
        <option value="Rejected" selected="@(Model.RequestStatusFilter == "Rejected" ? "selected" : null)">Rejected</option>
        <option value="Cancelled" selected="@(Model.RequestStatusFilter == "Cancelled" ? "selected" : null)">Cancelled</option>
    </select>

    <input type="hidden" name="sortBy" value="@Model.SortBy" />
    <input type="hidden" name="desc" value="@Model.Descending.ToString().ToLowerInvariant()" />
    <input type="hidden" name="pageSize" value="@Model.ApartmentsPagination.PageSize" />
    
    <button type="submit" class="bg-primary text-on-primary px-4 py-2 rounded-lg text-body-sm font-semibold hover:opacity-90 transition-colors">Apply</button>
    <a asp-action="Dashboard" class="text-on-surface-variant hover:text-on-surface text-body-sm no-underline ml-2">Clear</a>
</form>

<!-- Apartments Grid -->
@if (Model.Apartments.Count == 0)
{
    <div class="border-2 border-dashed border-outline-variant bg-surface-container-low/50 rounded-xl flex flex-col items-center justify-center p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-sm mb-4">
            <span class="material-symbols-outlined text-primary text-3xl">add_home</span>
        </div>
        <h4 class="font-title-sm text-on-surface">No apartments found</h4>
        <p class="text-body-sm text-on-surface-variant mt-2 max-w-[300px]">Create your first listing to start the approval process, or change your filters.</p>
        <a asp-action="CreateApartment" class="mt-6 px-6 py-2 bg-primary text-white rounded-lg font-title-sm text-sm hover:opacity-90 transition-colors no-underline">Create Apartment</a>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-gutter" id="apartments-container">
        @foreach (var apartment in Model.Apartments)
        {
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden group hover:shadow-xl transition-all duration-300 @(!apartment.IsActive ? "opacity-80" : "")">
                <div class="relative h-48 overflow-hidden @(!apartment.IsActive ? "grayscale" : "")">
                    @if (!string.IsNullOrWhiteSpace(apartment.PrimaryPhotoUrl))
                    {
                        <div class="w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-110" style="background-image: url('@Url.Content(apartment.PrimaryPhotoUrl)')"></div>
                    }
                    else
                    {
                        <div class="w-full h-full bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-transform duration-500 group-hover:scale-110">
                            <span class="material-symbols-outlined text-4xl">image</span>
                        </div>
                    }
                    
                    <div class="absolute top-4 left-4 flex gap-2">
                        @if (apartment.IsActive)
                        {
                            <span class="bg-primary-container text-on-primary-container text-label-caps px-3 py-1 rounded-full backdrop-blur-md bg-opacity-90">ACTIVE</span>
                        }
                        else
                        {
                            <span class="bg-outline-variant text-on-surface text-label-caps px-3 py-1 rounded-full backdrop-blur-md bg-opacity-90">INACTIVE</span>
                        }
                        @if (apartment.LatestRequestStatus == "Pending")
                        {
                            <span class="bg-tertiary-container text-on-tertiary-container text-label-caps px-3 py-1 rounded-full backdrop-blur-md bg-opacity-90">PENDING ADMIN</span>
                        }
                    </div>
                </div>
                
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-title-sm text-lg text-on-surface group-hover:text-primary transition-colors m-0">@apartment.Address</h3>
                        <p class="font-data-mono text-primary font-bold text-lg m-0">@apartment.PricePerMonth.ToString("C0")<span class="text-xs text-on-surface-variant font-normal">/mo</span></p>
                    </div>
                    <div class="flex items-center gap-2 text-on-surface-variant text-body-sm mb-4">
                        <span class="material-symbols-outlined text-sm">location_on</span>
                        <span>@apartment.City</span>
                    </div>
                    
                    <div class="space-y-4">
                        <!-- Occupancy -->
                        <div>
                            <div class="flex justify-between items-center text-label-caps text-on-surface-variant mb-1.5">
                                <span>OCCUPANCY</span>
                                <span class="text-on-surface font-bold">@apartment.OccupiedSeats/@apartment.TotalSeats Units</span>
                            </div>
                            <div class="h-2 w-full bg-surface-container-low rounded-full overflow-hidden">
                                @{ var width = apartment.TotalSeats > 0 ? (apartment.OccupiedSeats * 100 / apartment.TotalSeats) : 0; }
                                <div class="h-full @(width == 100 ? "bg-error" : "bg-primary")" style="width: @width%"></div>
                            </div>
                        </div>
                        
                        <!-- Card Footer Actions -->
                        <div class="pt-4 border-t border-outline-variant flex items-center justify-between">
                            <div class="flex gap-1">
                                <a asp-action="EditApartment" asp-route-id="@apartment.ApartmentId" class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container-low rounded-lg transition-all no-underline" title="Edit Property">
                                    <span class="material-symbols-outlined">edit</span>
                                </a>
                                
                                @{ var onsubmitWarning = apartment.IsActive && apartment.ActiveBookingCount > 0 && apartment.OccupiedSeats == 0 ? $"return confirm('Warning: Deactivating this apartment will cancel {apartment.ActiveBookingCount} pending/accepted bookings. Continue?');" : ""; }
                                <form asp-action="ToggleStatus" asp-route-id="@apartment.ApartmentId" method="post" class="m-0" onsubmit="@onsubmitWarning">
                                    @Html.AntiForgeryToken()
                                    @if (apartment.IsActive && apartment.OccupiedSeats > 0)
                                    {
                                        <button type="button" class="p-2 text-outline-variant rounded-lg transition-all" title="Cannot deactivate - students are currently renting" disabled>
                                            <span class="material-symbols-outlined">power_settings_new</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container-low rounded-lg transition-all" title="Toggle Status">
                                            <span class="material-symbols-outlined">power_settings_new</span>
                                        </button>
                                    }
                                </form>
                            </div>
                            <a asp-action="ApartmentDetails" asp-route-id="@apartment.ApartmentId" class="text-primary font-semibold text-body-sm flex items-center gap-1 hover:underline no-underline">
                                View Details
                                <span class="material-symbols-outlined text-sm">chevron_right</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-stack-lg bg-surface-container-lowest border border-outline-variant p-4 rounded-xl">
        <partial name="_PaginationPartial" model="Model.ApartmentsPagination" />
    </div>
}
