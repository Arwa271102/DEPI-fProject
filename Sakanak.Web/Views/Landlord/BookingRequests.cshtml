@using Sakanak.Domain.Enums
@model Sakanak.Web.Models.ViewModels.Landlord.BookingRequestsViewModel
@{
    Layout = "_TailwindLandlordLayout";
    ViewData["Title"] = "Booking Requests";
}

<div class="flex flex-col md:flex-row md:items-end justify-between gap-gutter mb-stack-lg">
    <div>
        <h2 class="font-display-lg text-display-lg text-on-surface m-0">Booking Requests</h2>
        <p class="text-on-surface-variant font-body-md text-body-md m-0">Manage and review incoming housing requests from verified students.</p>
    </div>
    
    <div class="flex gap-4">
        <!-- Pending Metric -->
        <div class="bg-surface-container-lowest p-4 border border-outline-variant rounded-xl flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-tertiary-fixed flex items-center justify-center text-on-tertiary-fixed">
                <span class="material-symbols-outlined">pending_actions</span>
            </div>
            <div>
                <p class="text-[11px] font-label-caps text-on-surface-variant m-0">PENDING</p>
                <p class="font-headline-md text-headline-md leading-none m-0">@Model.PendingCount</p>
            </div>
        </div>
        
        <!-- Accepted Metric -->
        <div class="bg-surface-container-lowest p-4 border border-outline-variant rounded-xl flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container">
                <span class="material-symbols-outlined">verified</span>
            </div>
            <div>
                <p class="text-[11px] font-label-caps text-on-surface-variant m-0">ACCEPTED</p>
                <p class="font-headline-md text-headline-md leading-none m-0">@Model.AcceptedCount</p>
            </div>
        </div>
        
        <!-- Rejected Metric -->
        <div class="bg-surface-container-lowest p-4 border border-outline-variant rounded-xl flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-error-container flex items-center justify-center text-on-error-container">
                <span class="material-symbols-outlined">cancel</span>
            </div>
            <div>
                <p class="text-[11px] font-label-caps text-on-surface-variant m-0">REJECTED</p>
                <p class="font-headline-md text-headline-md leading-none m-0">@Model.RejectedCount</p>
            </div>
        </div>
    </div>
</div>

<form method="get" class="flex flex-wrap items-center justify-between bg-surface-container-lowest p-2 border border-outline-variant rounded-xl mb-gutter">
    <div class="flex items-center gap-2 w-full md:w-auto">
        <select name="status" class="bg-surface-container-low border-none rounded-lg text-body-sm py-2 px-4 focus:ring-primary cursor-pointer outline-none" onchange="this.form.submit()">
            <option value="">All statuses</option>
            @foreach (var status in Enum.GetValues<BookingStatus>())
            {
                <option value="@status" selected="@(Model.StatusFilter == status ? "selected" : null)">@status</option>
            }
        </select>
        
        <select name="apartmentId" class="bg-surface-container-low border-none rounded-lg text-body-sm py-2 px-4 focus:ring-primary cursor-pointer outline-none" onchange="this.form.submit()">
            <option value="">All apartments</option>
            @foreach (var apartment in Model.Apartments)
            {
                <option value="@apartment.ApartmentId" selected="@(Model.ApartmentId == apartment.ApartmentId ? "selected" : null)">@apartment.Address</option>
            }
        </select>
    </div>
</form>

<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        @if (Model.Bookings.Count == 0)
        {
            <div class="flex flex-col items-center justify-center py-20 px-6 text-center">
                <div class="w-24 h-24 rounded-full bg-surface-container-low flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-[48px] text-outline-variant">event_busy</span>
                </div>
                <h3 class="font-headline-md text-headline-md text-on-surface mb-2">No requests found</h3>
                <p class="text-on-surface-variant font-body-md text-body-md max-w-sm m-0">We couldn't find any booking requests matching your current filters.</p>
                @if (Model.StatusFilter != null || Model.ApartmentId.HasValue)
                {
                    <a asp-action="BookingRequests" class="mt-8 text-primary font-title-sm text-title-sm underline decoration-2 underline-offset-4 no-underline hover:text-primary-container">Reset all filters</a>
                }
            </div>
        }
        else
        {
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-outline-variant bg-surface-container-low/50">
                        <th class="px-6 py-4 font-label-caps text-[11px] text-on-surface-variant tracking-widest uppercase">Student Name</th>
                        <th class="px-6 py-4 font-label-caps text-[11px] text-on-surface-variant tracking-widest uppercase">Apartment</th>
                        <th class="px-6 py-4 font-label-caps text-[11px] text-on-surface-variant tracking-widest uppercase">Requested Dates</th>
                        <th class="px-6 py-4 font-label-caps text-[11px] text-on-surface-variant tracking-widest uppercase">Booking Date</th>
                        <th class="px-6 py-4 font-label-caps text-[11px] text-on-surface-variant tracking-widest uppercase">Status</th>
                        <th class="px-6 py-4 font-label-caps text-[11px] text-on-surface-variant tracking-widest uppercase text-right">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings)
                    {
                        <tr class="border-b border-outline-variant hover:bg-primary/5 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(booking.StudentPhotoUrl))
                                    {
                                        <img src="@Url.Content(booking.StudentPhotoUrl)" alt="Student photo" class="w-8 h-8 rounded-full object-cover" />
                                    }
                                    else
                                    {
                                        var initials = string.Join("", booking.StudentName.Split(' ').Select(s => s[0])).ToUpper();
                                        <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface font-bold text-xs">@initials</div>
                                    }
                                    <span class="font-body-md text-body-md text-on-surface font-semibold">@booking.StudentName</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-on-surface font-body-sm text-body-sm">@booking.ApartmentAddress</div>
                                <div class="text-on-surface-variant text-xs mt-1">@booking.ApartmentCity</div>
                            </td>
                            <td class="px-6 py-4 font-data-mono text-xs">@booking.RequestedStartDate.ToString("dd MMM yyyy") - @booking.RequestedEndDate.ToString("dd MMM yyyy")</td>
                            <td class="px-6 py-4 font-data-mono text-xs text-on-surface-variant">@booking.BookingDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="px-6 py-4">
                                @await Html.PartialAsync("_StatusBadgePartial", booking.Status)
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="ReviewBooking" asp-route-id="@booking.BookingId" class="inline-block bg-primary text-on-primary px-4 py-1.5 rounded-lg font-title-sm text-sm hover:opacity-90 transition-all active:scale-95 shadow-sm no-underline">Review</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
