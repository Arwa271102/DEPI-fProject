@model IReadOnlyList<Sakanak.BLL.DTOs.Payment.PaymentDto>
@{
    Layout = "_TailwindLandlordLayout";
    ViewData["Title"] = "Payments";
    var paidTotal = Model.Where(item => item.Status == "Paid").Sum(item => item.Amount);
    var pendingTotal = Model.Where(item => item.Status == "Pending").Sum(item => item.Amount);
}

<div class="flex flex-col md:flex-row md:items-end justify-between gap-gutter mb-stack-lg">
    <div>
        <p class="text-on-surface-variant text-label-caps uppercase mb-1">Payment Tracking</p>
        <h2 class="font-display-lg text-display-lg text-on-surface m-0">Payments</h2>
        <p class="text-on-surface-variant m-0">Track student payments for your apartments.</p>
    </div>
    <div class="flex items-center gap-stack-md">
        <a asp-action="Dashboard" class="flex items-center gap-2 bg-surface-container-lowest border border-outline-variant text-on-surface px-6 py-2.5 rounded-lg hover:bg-surface-container-low transition-all active:scale-95 no-underline">
            <span class="font-title-sm">Back to Dashboard</span>
        </a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-stack-lg">
    <!-- Total Earnings -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
        <div class="flex items-center gap-4 mb-2">
            <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                <span class="material-symbols-outlined">account_balance_wallet</span>
            </div>
            <p class="text-xs font-label-caps text-on-surface-variant uppercase m-0">Total Earnings</p>
        </div>
        <h2 class="font-data-mono text-3xl font-bold text-primary m-0">@paidTotal.ToString("C0")</h2>
    </div>

    <!-- Pending Payments -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
        <div class="flex items-center gap-4 mb-2">
            <div class="w-10 h-10 rounded-full bg-tertiary-fixed text-on-tertiary-fixed flex items-center justify-center">
                <span class="material-symbols-outlined">hourglass_empty</span>
            </div>
            <p class="text-xs font-label-caps text-on-surface-variant uppercase m-0">Pending Payments</p>
        </div>
        <h2 class="font-data-mono text-3xl font-bold text-on-surface m-0">@pendingTotal.ToString("C0")</h2>
    </div>

    <!-- Paid Contracts -->
    <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
        <div class="flex items-center gap-4 mb-2">
            <div class="w-10 h-10 rounded-full bg-surface-container-low text-on-surface-variant flex items-center justify-center">
                <span class="material-symbols-outlined">receipt_long</span>
            </div>
            <p class="text-xs font-label-caps text-on-surface-variant uppercase m-0">Paid Contracts</p>
        </div>
        <h2 class="font-headline-md text-3xl font-bold text-on-surface m-0">@Model.Count(item => item.Status == "Paid")</h2>
    </div>
</div>

<section class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden flex flex-col shadow-sm">
    <div class="px-6 py-5 border-b border-outline-variant bg-surface-container-low/50">
        <h3 class="font-headline-md text-headline-md text-on-surface m-0">All Payments</h3>
    </div>
    <div class="flex-1 overflow-x-auto">
        @if (Model.Count == 0)
        {
            <div class="p-12 text-center">
                <div class="w-16 h-16 rounded-full bg-surface-container-low flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-on-surface-variant text-3xl">payments</span>
                </div>
                <p class="text-on-surface font-title-sm m-0">No payments yet</p>
                <p class="text-on-surface-variant text-body-sm mt-1">Payments from students will appear here.</p>
            </div>
        }
        else
        {
            <table class="w-full text-left border-collapse">
                <thead class="bg-surface-container-low border-b border-outline-variant">
                    <tr>
                        <th class="px-6 py-3 font-label-caps text-on-surface-variant uppercase tracking-widest text-[11px]">Student</th>
                        <th class="px-6 py-3 font-label-caps text-on-surface-variant uppercase tracking-widest text-[11px]">Apartment</th>
                        <th class="px-6 py-3 font-label-caps text-on-surface-variant uppercase tracking-widest text-[11px]">Amount</th>
                        <th class="px-6 py-3 font-label-caps text-on-surface-variant uppercase tracking-widest text-[11px]">Status</th>
                        <th class="px-6 py-3 font-label-caps text-on-surface-variant uppercase tracking-widest text-[11px]">Paid At</th>
                        <th class="px-6 py-3 font-label-caps text-on-surface-variant uppercase tracking-widest text-[11px] text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @foreach (var payment in Model)
                    {
                        var initials = string.Join("", payment.StudentName.Split(' ').Select(s => s[0])).ToUpper();
                        <tr class="hover:bg-surface-container-low transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center">
                                    <div class="w-8 h-8 bg-secondary-container rounded-full flex items-center justify-center text-on-secondary-container font-bold text-xs mr-3 shrink-0">@initials</div>
                                    <div>
                                        <p class="font-body-md text-on-surface leading-none m-0">@payment.StudentName</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-body-sm text-on-surface font-medium">@payment.ApartmentAddress</td>
                            <td class="px-6 py-4 font-data-mono text-on-surface font-bold">@payment.Amount.ToString("C0")</td>
                            <td class="px-6 py-4">
                                @await Html.PartialAsync("_StatusBadgePartial", payment.Status)
                            </td>
                            <td class="px-6 py-4 font-data-mono text-xs text-on-surface-variant">@(payment.PaidAt?.ToString("dd MMM yyyy") ?? "-")</td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="PaymentDetails" asp-route-id="@payment.PaymentId" class="inline-block px-4 py-1.5 bg-surface-container-lowest border border-outline-variant text-on-surface rounded-lg font-title-sm text-sm hover:bg-surface-container-low active:scale-95 transition-all no-underline">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</section>
