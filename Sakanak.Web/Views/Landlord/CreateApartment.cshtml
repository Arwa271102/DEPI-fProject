@model Sakanak.Web.Models.ViewModels.Landlord.CreateApartmentViewModel
@{
    Layout = "_TailwindLandlordLayout";
    ViewData["Title"] = "Create Apartment";
}

<div class="mb-stack-lg">
    <h2 class="font-display-lg text-display-lg text-on-surface mb-1">Create an apartment listing.</h2>
    <p class="text-on-surface-variant font-body-md max-w-2xl">Add photos and details. The listing stays hidden until an admin approves it.</p>
</div>

<form asp-action="CreateApartment" method="post" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <div asp-validation-summary="ModelOnly" class="text-error mb-3 lg:col-span-12"></div>
    
    <!-- Left Column: Form Details -->
    <div class="lg:col-span-8 space-y-gutter">
        <!-- Basic Information Card -->
        <section class="bg-surface-container-lowest p-stack-lg rounded-xl border border-outline-variant">
            <h3 class="font-title-sm text-primary mb-stack-md flex items-center gap-2">
                <span class="material-symbols-outlined">info</span>
                General Details
            </h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
                <div class="md:col-span-2">
                    <label asp-for="Address" class="block font-label-caps text-on-surface-variant mb-1 ml-1 uppercase"></label>
                    <input asp-for="Address" class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-3 focus:border-primary transition-colors text-body-md placeholder:text-outline" placeholder="e.g. 123 Property Lane" />
                    <span asp-validation-for="Address" class="text-error text-xs mt-1 block"></span>
                </div>
                
                <div>
                    <label asp-for="City" class="block font-label-caps text-on-surface-variant mb-1 ml-1 uppercase"></label>
                    <input asp-for="City" class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-3 focus:border-primary transition-colors text-body-md placeholder:text-outline" placeholder="e.g. Riyadh" />
                    <span asp-validation-for="City" class="text-error text-xs mt-1 block"></span>
                </div>
                
                <div>
                    <label asp-for="PricePerMonth" class="block font-label-caps text-on-surface-variant mb-1 ml-1 uppercase"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 font-data-mono text-primary">$</span>
                        <input asp-for="PricePerMonth" class="w-full bg-surface-container-low border border-outline-variant rounded-lg pl-8 pr-4 py-3 focus:border-primary transition-colors text-data-mono placeholder:text-outline" placeholder="0.00" type="number" step="0.01" />
                    </div>
                    <span asp-validation-for="PricePerMonth" class="text-error text-xs mt-1 block"></span>
                </div>
                
                <div>
                    <label asp-for="TotalSeats" class="block font-label-caps text-on-surface-variant mb-1 ml-1 uppercase"></label>
                    <input asp-for="TotalSeats" class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-3 focus:border-primary transition-colors text-body-md placeholder:text-outline" placeholder="e.g. 3" type="number" />
                    <span asp-validation-for="TotalSeats" class="text-error text-xs mt-1 block"></span>
                </div>
                
                <div>
                    <label asp-for="VirtualTourUrl" class="block font-label-caps text-on-surface-variant mb-1 ml-1 uppercase"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline-variant text-[20px]">360</span>
                        <input asp-for="VirtualTourUrl" class="w-full bg-surface-container-low border border-outline-variant rounded-lg pl-11 pr-4 py-3 focus:border-primary transition-colors text-body-md placeholder:text-outline" placeholder="https://example.com/tour" type="url" />
                    </div>
                    <span asp-validation-for="VirtualTourUrl" class="text-error text-xs mt-1 block"></span>
                </div>
            </div>
        </section>

        <!-- Amenities Section -->
        <section class="bg-surface-container-lowest p-stack-lg rounded-xl border border-outline-variant">
            <h3 class="font-title-sm text-primary mb-stack-md flex items-center gap-2">
                <span class="material-symbols-outlined">checklist</span>
                Amenities
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                @foreach (var amenity in Model.AvailableAmenities)
                {
                    <div class="flex items-center space-x-3 group cursor-pointer">
                        <input class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary/20" type="checkbox" name="Amenities" value="@amenity" id="amenity-@amenity.Replace(" ", "-")" @(Model.Amenities.Contains(amenity) ? "checked" : null) />
                        <label class="text-body-md text-on-surface-variant group-hover:text-primary transition-colors cursor-pointer m-0" for="amenity-@amenity.Replace(" ", "-")">@amenity</label>
                    </div>
                }
            </div>
        </section>
    </div>

    <!-- Right Column: Uploads & Actions -->
    <div class="lg:col-span-4 space-y-gutter">
        <!-- Photo Upload Card -->
        <section class="bg-surface-container-lowest p-stack-lg rounded-xl border border-outline-variant">
            <h3 class="font-title-sm text-primary mb-stack-md flex items-center gap-2 m-0">
                <span class="material-symbols-outlined">photo_library</span>
                Apartment Photos
            </h3>
            
            <div class="mb-4">
                <label asp-for="Photos" class="block font-label-caps text-on-surface-variant mb-1 uppercase"></label>
                <input asp-for="Photos" id="photoInput" class="w-full text-body-sm text-on-surface-variant file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 transition-colors" type="file" multiple accept=".jpg,.jpeg,.png" />
                <span asp-validation-for="Photos" class="text-error text-xs mt-1 block"></span>
                <p class="text-xs text-on-surface-variant mt-2">JPEG/PNG only, max 5MB each, up to 10 photos.</p>
            </div>
            
            <div id="photoPreview" class="grid grid-cols-3 gap-2 mt-stack-md"></div>
        </section>

        <!-- Status Indicator -->
        <section class="bg-primary-container/10 p-stack-lg rounded-xl border border-primary-container/20 border-dashed">
            <div class="flex items-start space-x-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-primary">visibility_off</span>
                </div>
                <div>
                    <h4 class="font-title-sm text-primary m-0">Listing Visibility</h4>
                    <p class="text-body-sm text-on-primary-container/80 mt-1 m-0">Your listing will be saved and sent for verification. You'll receive a notification once an admin approves it.</p>
                </div>
            </div>
        </section>

        <!-- Form Actions -->
        <div class="flex flex-col space-y-3">
            <button type="submit" class="w-full bg-primary text-on-primary py-4 px-6 rounded-xl font-title-sm shadow-md active:scale-95 transition-all flex items-center justify-center space-x-2 border-0 cursor-pointer">
                <span class="material-symbols-outlined">send</span>
                <span>Submit for Approval</span>
            </button>
            <a asp-action="Dashboard" class="w-full border border-error/30 text-error py-4 px-6 rounded-xl font-title-sm hover:bg-error/5 active:scale-95 transition-all text-center no-underline cursor-pointer">
                Cancel &amp; Discard
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const photoInput = document.getElementById('photoInput');
        const photoPreview = document.getElementById('photoPreview');

        photoInput?.addEventListener('change', function (event) {
            photoPreview.innerHTML = '';
            Array.from(event.target.files).forEach((file, index) => {
                if (file.size > 5 * 1024 * 1024) {
                    alert(`File too large: ${file.name}`);
                    return;
                }

                const card = document.createElement('div');
                card.className = 'relative group aspect-square rounded-lg overflow-hidden border border-outline-variant';

                const reader = new FileReader();
                reader.onload = function (e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.alt = file.name;
                    img.className = 'w-full h-full object-cover';
                    card.appendChild(img);
                    
                    if (index === 0) {
                        const badge = document.createElement('div');
                        badge.className = 'absolute top-1 left-1 bg-primary text-on-primary font-label-caps px-1.5 py-0.5 rounded text-[10px]';
                        badge.textContent = 'PRIMARY';
                        card.appendChild(badge);
                    }
                };

                reader.readAsDataURL(file);
                photoPreview.appendChild(card);
            });
        });
    </script>
}
