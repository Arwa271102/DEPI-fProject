@model IReadOnlyList<Sakanak.BLL.DTOs.Apartment.ApartmentOccupancyDto>
@{
    Layout = "_TailwindLandlordLayout";
    ViewData["Title"] = "My Apartments Occupancy";
}

<div class="flex flex-col md:flex-row md:items-end justify-between gap-gutter mb-stack-lg">
    <div>
        <p class="text-on-surface-variant text-label-caps uppercase mb-1">Occupancy</p>
        <h2 class="font-headline-md text-headline-md text-on-surface m-0">My Apartments</h2>
    </div>
    <div class="flex items-center gap-stack-md">
        <a asp-action="Dashboard" class="flex items-center gap-2 bg-surface-container-lowest border border-outline-variant text-on-surface px-6 py-2.5 rounded-lg hover:bg-surface-container-low transition-all active:scale-95 no-underline">
            <span class="font-title-sm">Back to Dashboard</span>
        </a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="border-2 border-dashed border-outline-variant bg-surface-container-low/50 rounded-xl flex flex-col items-center justify-center p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-sm mb-4">
            <span class="material-symbols-outlined text-primary text-3xl">home_work</span>
        </div>
        <h4 class="font-title-sm text-on-surface">No occupied apartments</h4>
        <p class="text-body-sm text-on-surface-variant mt-2 max-w-[300px]">You don't have any apartments with active tenants yet.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-gutter">
        @foreach (var apartment in Model)
        {
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden group hover:shadow-xl transition-all duration-300">
                <div class="relative h-48 overflow-hidden">
                    @if (!string.IsNullOrWhiteSpace(apartment.PrimaryPhotoUrl))
                    {
                        <div class="w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-110" style="background-image: url('@Url.Content(apartment.PrimaryPhotoUrl)')"></div>
                    }
                    else
                    {
                        <div class="w-full h-full bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-transform duration-500 group-hover:scale-110">
                            <span class="material-symbols-outlined text-4xl">image</span>
                        </div>
                    }
                    <div class="absolute top-4 left-4">
                        <span class="bg-primary-container text-on-primary-container text-label-caps px-3 py-1 rounded-full backdrop-blur-md bg-opacity-90">OCCUPIED</span>
                    </div>
                </div>
                
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-title-sm text-lg text-on-surface group-hover:text-primary transition-colors m-0">@apartment.Address</h3>
                    </div>
                    <div class="flex items-center gap-2 text-on-surface-variant text-body-sm mb-4">
                        <span class="material-symbols-outlined text-sm">location_on</span>
                        <span>@apartment.City</span>
                    </div>
                    
                    <div class="space-y-4">
                        <!-- Revenue -->
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-on-surface-variant">Monthly Revenue</span>
                            <span class="font-data-mono text-primary font-bold">@apartment.MonthlyRevenue.ToString("C0")</span>
                        </div>

                        <!-- Occupancy -->
                        <div>
                            <div class="flex justify-between items-center text-label-caps text-on-surface-variant mb-1.5">
                                <span>OCCUPANCY</span>
                                <span class="text-on-surface font-bold">@apartment.OccupiedSeats / @apartment.TotalSeats Units</span>
                            </div>
                            <div class="h-2 w-full bg-surface-container-low rounded-full overflow-hidden">
                                <div class="h-full bg-primary" style="width: @apartment.OccupancyRate%"></div>
                            </div>
                        </div>
                        
                        <!-- Card Footer Actions -->
                        <div class="pt-4 border-t border-outline-variant flex items-center justify-end">
                            <a asp-action="ApartmentTenants" asp-route-apartmentId="@apartment.ApartmentId" class="text-primary font-semibold text-body-sm flex items-center gap-1 hover:underline no-underline">
                                View Tenants
                                <span class="material-symbols-outlined text-sm">group</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
