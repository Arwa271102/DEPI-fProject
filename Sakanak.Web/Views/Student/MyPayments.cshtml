@using Sakanak.Domain.Enums
@model IReadOnlyList<Sakanak.BLL.DTOs.Payment.PaymentDto>
@{
    ViewData["Title"] = "My Payments";
    Layout = "_TailwindStudentLayout";
}

<div class="animate-slide-up">
    <!-- Page Header -->
    <div class="mb-stack-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <div>
            <h2 class="font-headline-h1 text-headline-h1 text-primary m-0">My Payments</h2>
            <p class="font-body-base text-on-surface-variant mt-1 m-0">Track your rent payments and transaction history.</p>
        </div>
        <a asp-action="MyContracts" class="bg-surface-container-high text-on-surface px-gutter py-3 rounded-lg font-label-sm hover:bg-surface-variant transition-colors flex items-center gap-2 shadow-sm no-underline btn-interact">
            <span class="material-symbols-outlined text-[20px]">description</span>
            My Contracts
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-20 text-center animate-fade-in bg-white rounded-3xl border border-slate-100 shadow-sm">
            <div class="w-24 h-24 bg-surface-container-high rounded-full flex items-center justify-center mb-6 text-deep-teal">
                <span class="material-symbols-outlined text-5xl">payments</span>
            </div>
            <h3 class="text-headline-h2 text-primary m-0 mb-2">No payments found</h3>
            <p class="text-on-surface-variant max-w-sm mx-auto m-0 mb-8">You don't have any payment history yet. Payments will appear here once you have an active contract.</p>
        </div>
    }
    else
    {
        <!-- Desktop Table View -->
        <div class="hidden md:block bg-surface-student rounded-xl shadow-sm border border-outline-variant/50 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low border-b border-outline-variant/50">
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">Apartment</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">Amount</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">Due Date</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/30">
                    @foreach (var payment in Model)
                    {
                        var isPaid = payment.Status == PaymentStatus.Paid.ToString();
                        var isPending = payment.Status == PaymentStatus.Pending.ToString();
                        var isFailed = payment.Status == PaymentStatus.Failed.ToString();
                        var isRefunded = payment.Status == PaymentStatus.Refunded.ToString();

                        var statusColorClass = isPaid ? "text-success-green bg-success-green bg-opacity-10" :
                                               isFailed ? "text-danger-red bg-danger-red bg-opacity-10" :
                                               isPending ? "text-warning-amber bg-warning-amber bg-opacity-10" :
                                               "text-slate-gray bg-slate-gray bg-opacity-10";
                                               
                        var statusIcon = isPaid ? "check_circle" :
                                         isFailed ? "error" :
                                         isPending ? "hourglass_empty" :
                                         "currency_exchange";

                        <tr class="hover:bg-surface-container-lowest transition-colors group">
                            <td class="py-4 px-6">
                                <p class="font-bold text-primary m-0 line-clamp-1" title="@payment.ApartmentAddress">@payment.ApartmentAddress</p>
                            </td>
                            <td class="py-4 px-6">
                                <p class="font-bold text-deep-teal m-0">@payment.Amount.ToString("C0")</p>
                            </td>
                            <td class="py-4 px-6 text-sm text-on-surface-variant">
                                @payment.DueDate.ToString("MMM dd, yyyy")
                            </td>
                            <td class="py-4 px-6">
                                <div class="inline-flex items-center gap-1 px-3 py-1 @statusColorClass rounded-full text-[10px] font-bold tracking-wider uppercase">
                                    <span class="material-symbols-outlined text-[14px]">@statusIcon</span>
                                    @payment.Status
                                </div>
                            </td>
                            <td class="py-4 px-6 text-right space-x-2">
                                @if (payment.CanPay)
                                {
                                    <a asp-action="PayContract" asp-route-contractId="@payment.ContractId" class="inline-flex items-center justify-center px-4 py-2 bg-deep-teal text-white rounded-lg text-sm font-bold hover:opacity-90 transition-opacity no-underline shadow-sm btn-interact">
                                        Pay Now
                                    </a>
                                }
                                <a asp-action="PaymentDetails" asp-route-id="@payment.PaymentId" class="inline-flex items-center justify-center px-4 py-2 border border-outline-variant text-on-surface-variant rounded-lg text-sm font-bold hover:bg-surface-container-low transition-colors no-underline">
                                    Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Card View -->
        <div class="md:hidden space-y-4">
            @foreach (var payment in Model)
            {
                var isPaid = payment.Status == PaymentStatus.Paid.ToString();
                var isPending = payment.Status == PaymentStatus.Pending.ToString();
                var isFailed = payment.Status == PaymentStatus.Failed.ToString();

                var statusColorClass = isPaid ? "text-success-green bg-success-green bg-opacity-10" :
                                       isFailed ? "text-danger-red bg-danger-red bg-opacity-10" :
                                       isPending ? "text-warning-amber bg-warning-amber bg-opacity-10" :
                                       "text-slate-gray bg-slate-gray bg-opacity-10";
                                       
                var statusIcon = isPaid ? "check_circle" :
                                 isFailed ? "error" :
                                 isPending ? "hourglass_empty" :
                                 "currency_exchange";

                <div class="bg-white rounded-xl border border-outline-variant/50 p-4 shadow-sm flex flex-col gap-4">
                    <div class="flex justify-between items-start gap-2">
                        <p class="font-bold text-primary m-0 line-clamp-2">@payment.ApartmentAddress</p>
                        <div class="inline-flex items-center gap-1 px-2 py-0.5 @statusColorClass rounded-full text-[10px] font-bold tracking-wider uppercase shrink-0">
                            <span class="material-symbols-outlined text-[12px]">@statusIcon</span>
                            @payment.Status
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-2 text-sm bg-surface-container-lowest p-3 rounded-lg border border-outline-variant/30">
                        <div>
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant m-0">Amount</p>
                            <p class="font-bold text-deep-teal m-0">@payment.Amount.ToString("C0")</p>
                        </div>
                        <div>
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant m-0">Due Date</p>
                            <p class="font-medium text-on-surface m-0">@payment.DueDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>

                    <div class="flex gap-2">
                        @if (payment.CanPay)
                        {
                            <a asp-action="PayContract" asp-route-contractId="@payment.ContractId" class="flex-1 text-center py-2 bg-deep-teal text-white rounded-lg text-sm font-bold hover:opacity-90 transition-opacity no-underline shadow-sm btn-interact">
                                Pay Now
                            </a>
                        }
                        <a asp-action="PaymentDetails" asp-route-id="@payment.PaymentId" class="flex-1 text-center py-2 border border-outline-variant text-on-surface-variant rounded-lg text-sm font-bold hover:bg-surface-container-low transition-colors no-underline">
                            Details
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
