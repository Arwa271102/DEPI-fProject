@using Sakanak.Domain.Enums
@model Sakanak.BLL.DTOs.Payment.PaymentDetailsDto
@{
    ViewData["Title"] = "Payment Receipt";
    Layout = "_TailwindStudentLayout";

    var isPaid = Model.Status == PaymentStatus.Paid.ToString();
    var isPending = Model.Status == PaymentStatus.Pending.ToString();
    var isFailed = Model.Status == PaymentStatus.Failed.ToString();
    var isRefunded = Model.Status == PaymentStatus.Refunded.ToString();

    var statusColorClass = isPaid ? "text-success-green bg-success-green bg-opacity-10 border-success-green/20" :
                           isFailed ? "text-danger-red bg-danger-red bg-opacity-10 border-danger-red/20" :
                           isPending ? "text-warning-amber bg-warning-amber bg-opacity-10 border-warning-amber/20" :
                           "text-slate-gray bg-slate-gray bg-opacity-10 border-slate-gray/20";
                           
    var statusIcon = isPaid ? "check_circle" :
                     isFailed ? "error" :
                     isPending ? "hourglass_empty" :
                     "currency_exchange";
}

<div class="animate-slide-up flex flex-col items-center">
    <!-- Header Section -->
    <div class="w-full max-w-2xl mb-stack-lg flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
            <a asp-action="MyPayments" class="flex items-center gap-1 text-on-surface-variant hover:text-deep-teal mb-2 transition-colors no-underline">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                <span class="text-label-sm font-label-sm">Back to My Payments</span>
            </a>
            <h2 class="text-headline-h1 font-headline-h1 text-on-surface m-0">Payment Receipt</h2>
        </div>
        <button onclick="window.print()" class="bg-surface-container-high text-on-surface px-gutter py-2.5 rounded-lg font-label-sm hover:bg-surface-variant transition-colors flex items-center justify-center gap-2 shadow-sm shrink-0 btn-interact">
            <span class="material-symbols-outlined text-[20px]">print</span>
            Print Receipt
        </button>
    </div>

    <!-- Receipt Card -->
    <div class="w-full max-w-2xl bg-surface-student rounded-2xl shadow-lg border border-outline-variant/50 overflow-hidden print:shadow-none print:border-none print:max-w-full print:w-full">
        <!-- Receipt Header -->
        <div class="bg-primary px-8 py-8 text-white relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-white opacity-5 rounded-full blur-xl"></div>
            <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-white opacity-5 rounded-full blur-xl"></div>
            
            <div class="relative z-10 flex justify-between items-start">
                <div>
                    <h3 class="font-headline-h2 text-2xl font-bold m-0 mb-1">Sakanak</h3>
                    <p class="text-primary-fixed-dim text-sm m-0 opacity-80">Official Payment Receipt</p>
                </div>
                <div class="text-right">
                    <p class="text-sm font-bold opacity-80 uppercase tracking-wider m-0 mb-1">Total Amount</p>
                    <p class="font-headline-h1 text-3xl font-extrabold m-0">@Model.Amount.ToString("C0")</p>
                </div>
            </div>
        </div>

        <!-- Receipt Body -->
        <div class="p-8 space-y-8 bg-white">
            
            <!-- Status Badge -->
            <div class="flex justify-between items-center pb-6 border-b border-outline-variant/30 border-dashed">
                <div>
                    <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Receipt ID</p>
                    <p class="font-mono text-sm text-primary m-0">@Model.PaymentId.ToString().ToUpper()</p>
                </div>
                <div class="@statusColorClass border px-4 py-2 rounded-full flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px]">@statusIcon</span>
                    <span class="font-bold text-xs uppercase tracking-widest">@Model.Status</span>
                </div>
            </div>

            <!-- Details Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                    <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Date Paid</p>
                    <p class="text-body-base font-medium text-on-surface m-0">
                        @if (Model.PaidAt.HasValue)
                        {
                            @Model.PaidAt.Value.ToLocalTime().ToString("MMMM dd, yyyy h:mm tt")
                        }
                        else
                        {
                            <span class="text-slate-400 italic">Not paid yet</span>
                        }
                    </p>
                </div>
                <div>
                    <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Due Date</p>
                    <p class="text-body-base font-medium text-on-surface m-0">@Model.DueDate.ToString("MMMM dd, yyyy")</p>
                </div>
            </div>

            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/30 space-y-4">
                <div>
                    <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Property</p>
                    <p class="font-bold text-primary m-0">@Model.ApartmentAddress</p>
                    <p class="text-sm text-on-surface-variant m-0 mt-1">@Model.ApartmentCity</p>
                </div>
                
                <div class="pt-4 border-t border-outline-variant/30">
                    <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Lease Period</p>
                    <p class="text-sm font-medium text-on-surface m-0">@Model.ContractStartDate.ToString("MMM dd, yyyy") — @Model.ContractEndDate.ToString("MMM dd, yyyy")</p>
                </div>
            </div>

            <!-- Transaction Info -->
            <div class="pb-2">
                <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-2">Transaction Details</p>
                <div class="flex justify-between items-center text-sm py-2 border-b border-outline-variant/20">
                    <span class="text-on-surface-variant">Payment Method</span>
                    <span class="font-medium">Credit Card (Stripe)</span>
                </div>
                <div class="flex justify-between items-center text-sm py-2">
                    <span class="text-on-surface-variant">Transaction Ref</span>
                    <span class="font-mono text-xs text-on-surface">@(Model.StripePaymentIntentId ?? "-")</span>
                </div>
            </div>

            @if (isPending)
            {
                <div class="pt-4">
                    <a asp-action="PayContract" asp-route-contractId="@Model.ContractId" class="w-full bg-deep-teal text-white py-4 rounded-xl font-bold hover:bg-primary transition-all active:scale-[0.98] shadow-md flex items-center justify-center gap-2 no-underline btn-interact print:hidden">
                        <span class="material-symbols-outlined">payments</span>
                        Pay Now
                    </a>
                </div>
            }

        </div>
        
        <!-- Receipt Footer -->
        <div class="bg-surface-container-low px-8 py-6 text-center border-t border-outline-variant/30">
            <p class="text-xs text-on-surface-variant m-0">
                If you have any questions regarding this receipt, please contact <br/> <a href="mailto:support@sakanak.com" class="text-deep-teal underline font-medium">support@sakanak.com</a>
            </p>
        </div>
    </div>
</div>

<style>
    @@media print {
        body * {
            visibility: hidden;
        }
        .animate-slide-up, .animate-slide-up * {
            visibility: visible;
        }
        .animate-slide-up {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }
        .print\:hidden {
            display: none !important;
        }
    }
</style>
