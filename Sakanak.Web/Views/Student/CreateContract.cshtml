@model Sakanak.Web.Models.ViewModels.Student.CreateContractViewModel
@{
    ViewData["Title"] = Model.ContractId.HasValue ? "Resubmit Contract" : "Submit Contract";
    Layout = "_TailwindStudentLayout";
    var action = Model.ContractId.HasValue ? "EditContract" : "CreateContract";
}

<div class="animate-slide-up max-w-6xl mx-auto">
    <!-- Header Section -->
    <div class="mb-stack-lg flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <a asp-action="BookingDetails" asp-route-id="@Model.BookingId" class="flex items-center gap-1 text-on-surface-variant hover:text-deep-teal mb-2 transition-colors no-underline">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                <span class="text-label-sm font-label-sm">Back to Booking</span>
            </a>
            <h2 class="text-headline-h1 font-headline-h1 text-on-surface m-0 mb-1">@ViewData["Title"]</h2>
            <p class="text-body-base font-body-base text-on-surface-variant m-0">Upload a signed PDF contract and required documents for admin review.</p>
        </div>
    </div>

    <!-- Alert / Instructions -->
    <div class="bg-primary-container text-on-primary-container p-6 rounded-2xl flex flex-col sm:flex-row items-center gap-6 mb-8 shadow-sm">
        <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-[32px] text-white">description</span>
        </div>
        <div class="flex-1">
            <h3 class="font-bold text-lg mb-1 text-white m-0">Step 1: Sign the Contract</h3>
            <p class="text-on-primary-container text-sm leading-relaxed m-0 opacity-90">
                Download the pre-filled contract template, sign it with the landlord (digitally or physically), then upload the signed PDF and required ID photos below.
            </p>
        </div>
        <div class="shrink-0">
            <a asp-action="DownloadContractTemplate" asp-route-bookingId="@Model.BookingId" class="bg-white text-primary-container px-6 py-3 rounded-xl font-bold hover:bg-surface-student transition-colors flex items-center gap-2 shadow-sm no-underline btn-interact">
                <span class="material-symbols-outlined text-[20px]">download</span>
                Download Template
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
        <!-- Left Column: Form -->
        <div class="lg:col-span-8 space-y-gutter">
            <form asp-action="@action" asp-route-id="@Model.ContractId" method="post" enctype="multipart/form-data" class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-card-padding">
                <input asp-for="BookingId" type="hidden" />
                
                <div asp-validation-summary="ModelOnly" class="bg-danger-red/10 border border-danger-red/20 text-danger-red p-4 rounded-xl text-sm font-medium mb-6"></div>

                <div class="flex items-center gap-2 mb-6 pb-4 border-b border-outline-variant/30">
                    <span class="material-symbols-outlined text-deep-teal">date_range</span>
                    <h3 class="font-headline-h2 text-xl text-on-surface m-0">Lease Period</h3>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg mb-8">
                    <div class="space-y-2">
                        <label asp-for="StartDate" class="text-label-sm font-semibold text-on-surface-variant block m-0"></label>
                        <input asp-for="StartDate" type="date" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all text-on-surface" />
                        <span asp-validation-for="StartDate" class="text-danger-red text-xs font-medium"></span>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="EndDate" class="text-label-sm font-semibold text-on-surface-variant block m-0"></label>
                        <input asp-for="EndDate" type="date" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all text-on-surface" />
                        <span asp-validation-for="EndDate" class="text-danger-red text-xs font-medium"></span>
                    </div>
                </div>

                <div class="flex items-center gap-2 mb-6 pb-4 border-b border-outline-variant/30">
                    <span class="material-symbols-outlined text-deep-teal">upload_file</span>
                    <h3 class="font-headline-h2 text-xl text-on-surface m-0">Required Documents</h3>
                </div>

                <div class="space-y-6 mb-8">
                    <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant">
                        <label asp-for="ContractDocument" class="text-label-sm font-bold text-on-surface block m-0 mb-2">Signed Contract PDF <span class="text-danger-red">*</span></label>
                        <input asp-for="ContractDocument" type="file" accept=".pdf,application/pdf" class="w-full file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-teal-50 file:text-deep-teal hover:file:bg-teal-100 text-sm text-slate-500 mb-2 cursor-pointer" />
                        <p class="text-xs text-on-surface-variant m-0">PDF only, maximum 10MB.</p>
                        <span asp-validation-for="ContractDocument" class="text-danger-red text-xs font-medium block mt-1"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-surface-container-lowest p-4 rounded-xl border border-outline-variant">
                            <label asp-for="IdFrontPhoto" class="text-label-sm font-bold text-on-surface block m-0 mb-2">ID / Passport Front <span class="text-danger-red">*</span></label>
                            <input asp-for="IdFrontPhoto" type="file" accept=".jpg,.jpeg,.png" class="w-full file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200 text-xs text-slate-500 cursor-pointer" />
                            <span asp-validation-for="IdFrontPhoto" class="text-danger-red text-xs font-medium block mt-1"></span>
                        </div>
                        <div class="bg-surface-container-lowest p-4 rounded-xl border border-outline-variant">
                            <label asp-for="IdBackPhoto" class="text-label-sm font-bold text-on-surface block m-0 mb-2">ID / Passport Back <span class="text-danger-red">*</span></label>
                            <input asp-for="IdBackPhoto" type="file" accept=".jpg,.jpeg,.png" class="w-full file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200 text-xs text-slate-500 cursor-pointer" />
                            <span asp-validation-for="IdBackPhoto" class="text-danger-red text-xs font-medium block mt-1"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-surface-container-lowest p-4 rounded-xl border border-outline-variant">
                            <label asp-for="StudentIdCardPhoto" class="text-label-sm font-bold text-on-surface block m-0 mb-2">Student ID Card <span class="text-slate-400 font-normal">(Optional)</span></label>
                            <input asp-for="StudentIdCardPhoto" type="file" accept=".jpg,.jpeg,.png" class="w-full file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200 text-xs text-slate-500 cursor-pointer" />
                        </div>
                        <div class="bg-surface-container-lowest p-4 rounded-xl border border-outline-variant">
                            <label asp-for="SupportingDocuments" class="text-label-sm font-bold text-on-surface block m-0 mb-2">Supporting Documents <span class="text-slate-400 font-normal">(Optional)</span></label>
                            <input asp-for="SupportingDocuments" type="file" accept=".pdf,.jpg,.jpeg,.png" multiple class="w-full file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200 text-xs text-slate-500 cursor-pointer" />
                        </div>
                    </div>
                </div>

                <div class="bg-teal-50 border border-teal-100 p-4 rounded-xl mb-6">
                    <label class="flex items-start gap-3 cursor-pointer group">
                        <input asp-for="AcceptTerms" class="mt-1 w-5 h-5 text-deep-teal rounded border-teal-200 focus:ring-deep-teal focus:ring-offset-0" />
                        <div>
                            <span class="font-bold text-deep-teal m-0 block">I confirm these documents are genuine</span>
                            <span class="text-xs text-teal-700/80 m-0 leading-relaxed block mt-1">
                                By submitting this form, I agree that the contract and IDs provided are accurate and legally binding. Fraudulent submissions may result in account termination.
                            </span>
                        </div>
                    </label>
                    <span asp-validation-for="AcceptTerms" class="text-danger-red text-xs font-medium block mt-2 ml-8"></span>
                </div>

                <div class="pt-4 border-t border-outline-variant/30 flex justify-end">
                    <button type="submit" class="w-full md:w-auto px-10 py-4 bg-deep-teal text-white rounded-xl font-bold shadow-lg hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 btn-interact">
                        <span class="material-symbols-outlined">send</span>
                        <span>Submit for Review</span>
                    </button>
                </div>
            </form>
        </div>

        <!-- Right Column: Booking Summary -->
        <div class="lg:col-span-4">
            <aside class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-6 sticky top-24">
                <h3 class="font-headline-h2 text-xl text-primary m-0 mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-deep-teal">info</span>
                    Booking Summary
                </h3>
                
                @if (Model.Booking is not null)
                {
                    <div class="space-y-4">
                        <div>
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Apartment</p>
                            <p class="font-bold text-on-surface m-0">@Model.Booking.ApartmentAddress</p>
                            <p class="text-sm text-on-surface-variant m-0">@Model.Booking.ApartmentCity</p>
                        </div>
                        
                        <div class="pt-4 border-t border-outline-variant/30">
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Requested Dates</p>
                            <p class="text-sm font-bold text-on-surface m-0">@Model.Booking.RequestedStartDate.ToString("MMM dd, yyyy")</p>
                            <p class="text-xs text-on-surface-variant m-0">to @Model.Booking.RequestedEndDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        
                        <div class="pt-4 border-t border-outline-variant/30">
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Monthly Rent</p>
                            <p class="text-lg font-bold text-deep-teal m-0">@Model.Booking.PricePerMonth.ToString("C0") <span class="text-sm font-normal text-on-surface-variant">/ mo</span></p>
                        </div>

                        <div class="pt-4 border-t border-outline-variant/30">
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Landlord</p>
                            <p class="text-sm font-bold text-on-surface flex items-center gap-1 m-0">
                                <span class="material-symbols-outlined text-sm text-deep-teal">real_estate_agent</span>
                                @Model.Booking.LandlordName
                            </p>
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
