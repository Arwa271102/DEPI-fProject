@model Sakanak.BLL.DTOs.Apartment.StudentApartmentAssignmentDto
@{
    ViewData["Title"] = "My Apartment";
    Layout = "_TailwindStudentLayout";
}

<div class="animate-slide-up">
    @if (!Model.HasAssignment)
    {
        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-24 text-center bg-white rounded-3xl border border-slate-100 shadow-sm max-w-3xl mx-auto mt-8">
            <div class="w-24 h-24 bg-surface-container-high rounded-full flex items-center justify-center mb-6 text-deep-teal">
                <span class="material-symbols-outlined text-5xl">home_work</span>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-2">Current Rental</p>
            <h2 class="text-headline-h1 text-primary m-0 mb-4">No Active Apartment</h2>
            <p class="text-on-surface-variant max-w-sm mx-auto m-0 mb-8 leading-relaxed">Once your contract is approved and payment is completed, your apartment assignment and details will appear here.</p>
            <a asp-action="SearchApartments" class="px-8 py-4 bg-deep-teal text-white rounded-xl font-bold hover:opacity-90 transition-all no-underline btn-interact shadow-md flex items-center gap-2">
                <span class="material-symbols-outlined">search</span>
                Search Apartments
            </a>
        </div>
    }
    else
    {
        <!-- Header Section -->
        <div class="mb-stack-lg flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-2">My Current Rental</p>
                <h2 class="text-headline-h1 font-headline-h1 text-on-surface m-0 mb-1">@Model.Address</h2>
                <div class="flex items-center gap-3 text-on-surface-variant">
                    <span class="flex items-center gap-1 text-sm"><span class="material-symbols-outlined text-sm">location_on</span> @Model.City</span>
                    <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                    <span class="text-sm font-medium text-deep-teal">@Model.DaysRemaining days remaining</span>
                </div>
            </div>
            <div class="flex gap-3 shrink-0">
                <a asp-action="ContractDetails" asp-route-id="@Model.ContractId" class="bg-surface-container-high text-on-surface px-6 py-2.5 rounded-lg font-bold text-sm hover:bg-surface-variant transition-colors flex items-center gap-2 shadow-sm no-underline btn-interact">
                    <span class="material-symbols-outlined text-[18px]">description</span>
                    View Contract
                </a>
                @if (Model.PaymentId.HasValue)
                {
                    <a asp-action="PaymentDetails" asp-route-id="@Model.PaymentId" class="bg-deep-teal text-white px-6 py-2.5 rounded-lg font-bold text-sm hover:opacity-90 transition-opacity flex items-center gap-2 shadow-sm no-underline btn-interact">
                        <span class="material-symbols-outlined text-[18px]">receipt_long</span>
                        View Receipt
                    </a>
                }
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
            <!-- Left Column: Apartment Details -->
            <div class="lg:col-span-2 space-y-gutter">
                
                <!-- Photos & Amenities Panel -->
                <div class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-6">
                    <div class="mb-6">
                        <partial name="_ApartmentPhotoGallery" model="Model.PhotoUrls" />
                    </div>

                    <div class="mt-6 border-t border-outline-variant/30 pt-6">
                        <div class="flex justify-between items-end mb-4">
                            <h3 class="font-headline-h2 text-xl text-primary m-0">Apartment Details</h3>
                            <div class="text-right">
                                <p class="text-sm text-slate-500 m-0 mb-1">Occupancy</p>
                                <p class="text-sm font-bold text-deep-teal m-0">@Model.OccupiedSeats / @Model.TotalSeats Seats (@Model.OccupancyRate%)</p>
                            </div>
                        </div>
                        
                        <div class="w-full bg-slate-100 rounded-full h-2.5 mb-8 overflow-hidden">
                            <div class="bg-deep-teal h-2.5 rounded-full transition-all duration-1000" style="width: @Model.OccupancyRate%"></div>
                        </div>

                        <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-3">Amenities</p>
                        <div class="flex flex-wrap gap-2 mb-6">
                            @foreach (var amenity in Model.Amenities)
                            {
                                <span class="px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-600 font-medium">@amenity</span>
                            }
                            @if (!Model.Amenities.Any())
                            {
                                <span class="text-sm text-slate-400 italic">No amenities listed.</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.VirtualTourUrl))
                        {
                            <a href="@Model.VirtualTourUrl" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-deep-teal text-deep-teal rounded-xl font-bold hover:bg-teal-50 transition-colors no-underline">
                                <span class="material-symbols-outlined">play_circle</span>
                                Open Virtual Tour
                            </a>
                        }
                    </div>
                </div>

                <!-- Roommates Panel -->
                <div class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-6">
                    <h3 class="font-headline-h2 text-xl text-primary m-0 mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-deep-teal">groups</span>
                        Your Roommates
                    </h3>
                    
                    @if (Model.TotalSeats <= 1)
                    {
                        <div class="p-6 bg-slate-50 rounded-xl border border-slate-100 text-center">
                            <span class="material-symbols-outlined text-slate-400 text-3xl mb-2">person</span>
                            <p class="text-slate-500 font-medium m-0">Private apartment - no roommates.</p>
                        </div>
                    }
                    else if (Model.Roommates.Count == 0)
                    {
                        <div class="p-6 bg-teal-50/50 rounded-xl border border-teal-100 text-center">
                            <span class="material-symbols-outlined text-deep-teal/50 text-3xl mb-2">group_add</span>
                            <p class="text-deep-teal font-medium m-0">No roommates assigned yet.</p>
                            <p class="text-sm text-teal-700/70 m-0 mt-1">Available seats may still be filled later.</p>
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            @foreach (var roommate in Model.Roommates)
                            {
                                <div class="p-4 rounded-xl border border-outline-variant/50 hover:shadow-md transition-shadow bg-surface-container-lowest">
                                    <div class="flex justify-between items-start mb-3">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center text-slate-500">
                                                <span class="material-symbols-outlined">person</span>
                                            </div>
                                            <div>
                                                <h4 class="font-bold text-primary m-0 leading-tight">@roommate.Name</h4>
                                                <a href="mailto:@roommate.Email" class="text-xs text-deep-teal hover:underline m-0">@roommate.Email</a>
                                            </div>
                                        </div>
                                        <div class="bg-success-green/10 text-success-green px-2 py-1 rounded text-[10px] font-bold shrink-0">
                                            @roommate.CompatibilityScore% Match
                                        </div>
                                    </div>
                                    <div class="pt-3 border-t border-outline-variant/30">
                                        <p class="text-xs font-bold text-slate-600 m-0 mb-1 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-[14px]">school</span>
                                            @roommate.University • @roommate.Faculty
                                        </p>
                                        <p class="text-xs text-slate-500 m-0 line-clamp-2" title="@roommate.LifestyleSummary">@roommate.LifestyleSummary</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Info & Contact -->
            <div class="space-y-gutter">
                
                <!-- Rental Info Panel -->
                <div class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-6 sticky top-24">
                    <h3 class="font-headline-h2 text-lg text-primary m-0 mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-deep-teal">info</span>
                        Rental Information
                    </h3>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between items-center pb-4 border-b border-outline-variant/30">
                            <span class="text-sm text-on-surface-variant font-medium">Monthly Rent</span>
                            <span class="text-lg font-bold text-deep-teal">@Model.MonthlyRent.ToString("C0")</span>
                        </div>
                        
                        <div class="py-2">
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Move-in Date</p>
                            <p class="text-sm font-bold text-on-surface m-0">@Model.ContractStartDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                        
                        <div class="py-2">
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Move-out Date</p>
                            <p class="text-sm font-bold text-on-surface m-0">@Model.ContractEndDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                    
                    @if (Model.DaysUntilMoveIn > 0)
                    {
                        <div class="mt-6 bg-teal-50 text-deep-teal p-4 rounded-xl text-center border border-teal-100 font-bold text-sm shadow-sm">
                            @Model.DaysUntilMoveIn day(s) until move-in
                        </div>
                    }
                </div>

                <!-- Landlord Contact Panel -->
                <div class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-6">
                    <h3 class="font-headline-h2 text-lg text-primary m-0 mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-deep-teal">real_estate_agent</span>
                        Landlord Contact
                    </h3>
                    
                    <div class="space-y-4 mb-6">
                        <div>
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Name</p>
                            <p class="text-sm font-bold text-on-surface m-0">@Model.LandlordName</p>
                        </div>
                        <div>
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Email</p>
                            <a href="mailto:@Model.LandlordEmail" class="text-sm font-medium text-deep-teal hover:underline m-0">@Model.LandlordEmail</a>
                        </div>
                        <div>
                            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold m-0 mb-1">Phone</p>
                            <p class="text-sm font-medium text-on-surface m-0">@(Model.LandlordPhoneNumber ?? "Not provided")</p>
                        </div>
                    </div>
                    
                    <a asp-controller="Messages" asp-action="Index" asp-route-otherUserId="@Model.LandlordApplicationUserId" class="w-full bg-deep-teal text-white py-3 rounded-xl font-bold hover:bg-primary transition-all active:scale-[0.98] shadow-sm flex items-center justify-center gap-2 no-underline btn-interact">
                        <span class="material-symbols-outlined">chat</span>
                        Message Landlord
                    </a>
                </div>
            </div>
        </div>
    }
</div>
