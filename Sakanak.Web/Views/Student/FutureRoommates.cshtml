@model List<Sakanak.BLL.DTOs.Matching.RoommateMatchDto>
@{
    ViewData["Title"] = "Your Future Roommates";
    Layout = "_TailwindStudentLayout";
}

<div class="animate-slide-up max-w-5xl mx-auto">
    <!-- Header Section -->
    <div class="mb-stack-lg text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-success-green/10 text-success-green rounded-full mb-4">
            <span class="material-symbols-outlined text-[32px]">check_circle</span>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-success-green m-0 mb-2">Booking Approved!</p>
        <h2 class="font-headline-h1 text-headline-h1 text-primary m-0 mb-3">Meet Your Future Roommates</h2>
        <p class="font-body-base text-on-surface-variant max-w-2xl mx-auto m-0 leading-relaxed">
            Before proceeding to your contract, take a moment to review who you'll be living with. 
            These students are already assigned to this apartment.
        </p>
    </div>

    @if (Model.Count == 0)
    {
        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-20 text-center bg-surface-student rounded-2xl border border-outline-variant/50 shadow-sm mb-stack-lg">
            <div class="w-24 h-24 bg-teal-50 rounded-full flex items-center justify-center mb-6 text-deep-teal">
                <span class="material-symbols-outlined text-5xl">person_add</span>
            </div>
            <h3 class="text-headline-h2 text-primary m-0 mb-2">You'll be the first to move in!</h3>
            <p class="text-on-surface-variant max-w-sm mx-auto m-0 leading-relaxed">There are currently no other tenants in this apartment. Future tenants will be matched based on your lifestyle preferences.</p>
        </div>
    }
    else
    {
        <!-- Roommates Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter mb-stack-lg">
            @foreach (var roommate in Model)
            {
                var isHighlyCompatible = roommate.CompatibilityScore >= 80;
                var isModeratelyCompatible = roommate.CompatibilityScore >= 50 && roommate.CompatibilityScore < 80;
                
                var scoreColorClass = isHighlyCompatible ? "text-success-green bg-success-green/10" : 
                                      isModeratelyCompatible ? "text-warning-amber bg-warning-amber/10" : 
                                      "text-danger-red bg-danger-red/10";
                                      
                var scoreIcon = isHighlyCompatible ? "favorite" : 
                                isModeratelyCompatible ? "thumb_up" : 
                                "warning";

                <div class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-6 flex flex-col items-center text-center hover:shadow-md transition-shadow relative overflow-hidden">
                    
                    <div class="absolute top-4 right-4 px-3 py-1 rounded-full @scoreColorClass text-xs font-bold flex items-center gap-1 shadow-sm">
                        <span>@roommate.CompatibilityScore% Match</span>
                        <span class="material-symbols-outlined text-[14px]">@scoreIcon</span>
                    </div>

                    <div class="w-24 h-24 rounded-full border-4 border-white shadow-sm mb-4 mt-6 overflow-hidden bg-surface-container-high flex items-center justify-center text-slate-400">
                        @if (!string.IsNullOrEmpty(roommate.ProfilePhotoUrl))
                        {
                            <img src="@Url.Content(roommate.ProfilePhotoUrl)" alt="@roommate.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-4xl">person</span>
                        }
                    </div>

                    <h3 class="font-headline-h2 text-lg text-primary m-0 leading-tight mb-1">@roommate.Name</h3>
                    <p class="text-xs text-on-surface-variant m-0 mb-4 font-medium flex flex-col gap-1 items-center justify-center">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">school</span> @roommate.University</span>
                        <span class="text-slate-400">@roommate.Faculty</span>
                    </p>

                    <div class="mt-auto pt-4 border-t border-outline-variant/30 w-full text-left">
                        <p class="text-[10px] uppercase tracking-wider text-slate-400 font-bold m-0 mb-2">Lifestyle Summary</p>
                        <p class="text-xs text-slate-600 m-0 leading-relaxed italic flex items-start gap-2">
                            <span class="material-symbols-outlined text-deep-teal/50 text-[16px] mt-0.5 shrink-0">format_quote</span>
                            @roommate.LifestyleSummary
                        </p>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Action Card -->
    <div class="bg-surface-student rounded-2xl shadow-md border border-outline-variant/50 p-8 text-center max-w-3xl mx-auto relative overflow-hidden">
        <div class="absolute -right-12 -bottom-12 opacity-[0.03] text-primary pointer-events-none">
            <span class="material-symbols-outlined text-[200px]">contract_edit</span>
        </div>
        
        <div class="relative z-10">
            <h4 class="font-headline-h2 text-xl text-primary m-0 mb-6">Ready to proceed?</h4>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <form asp-action="ProceedToContract" method="post" class="w-full sm:w-auto">
                    <input type="hidden" name="bookingId" value="@ViewBag.BookingId" />
                    <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-deep-teal text-white rounded-xl font-bold shadow-lg hover:bg-primary active:scale-[0.98] transition-all flex items-center justify-center gap-2 btn-interact">
                        <span class="material-symbols-outlined text-[20px]">description</span>
                        Looks Great! Proceed to Contract
                    </button>
                </form>

                <form asp-action="CancelDueToIncompatibility" method="post" class="w-full sm:w-auto" onsubmit="return confirm('Are you sure you want to cancel this booking? This action cannot be undone.');">
                    <input type="hidden" name="bookingId" value="@ViewBag.BookingId" />
                    <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-white text-danger-red border border-danger-red/30 rounded-xl font-bold hover:bg-red-50 transition-colors flex items-center justify-center gap-2 btn-interact">
                        <span class="material-symbols-outlined text-[20px]">cancel</span>
                        Cancel Booking
                    </button>
                </form>
            </div>
            <p class="text-xs text-on-surface-variant m-0 mt-4 max-w-md mx-auto">If you feel you won't be compatible with these roommates, you can cancel your booking now without penalty.</p>
        </div>
    </div>
</div>
