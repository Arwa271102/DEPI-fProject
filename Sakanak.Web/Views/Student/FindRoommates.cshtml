@using Sakanak.BLL.DTOs.Matching
@model List<RoommateDiscoveryDto>
@{
    ViewData["Title"] = "Find Compatible Roommates";
    Layout = "_TailwindStudentLayout";
}

<div class="animate-slide-up">
    <!-- Header Section -->
    <div class="mb-stack-lg max-w-3xl">
        <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-2">Connect & Discover</p>
        <h2 class="font-headline-h1 text-headline-h1 text-primary m-0 mb-2">Find Compatible Roommates</h2>
        <p class="font-body-base text-on-surface-variant m-0 leading-relaxed">
            Discover students who match your lifestyle preferences. Connect with compatible roommates to find the perfect living arrangement.
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-24 text-center bg-white rounded-3xl border border-slate-100 shadow-sm max-w-3xl mx-auto mt-8">
            <div class="w-24 h-24 bg-surface-container-high rounded-full flex items-center justify-center mb-6 text-deep-teal">
                <span class="material-symbols-outlined text-5xl">people_outline</span>
            </div>
            <h3 class="text-headline-h2 text-primary m-0 mb-2">No matches yet</h3>
            <p class="text-on-surface-variant max-w-sm mx-auto m-0 leading-relaxed">More students will appear here as they complete their lifestyle questionnaires and match your preferences. Check back later!</p>
        </div>
    }
    else
    {
        <!-- Roommates Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
            @foreach (var student in Model)
            {
                var isHighlyCompatible = student.CompatibilityScore >= 80;
                var isModeratelyCompatible = student.CompatibilityScore >= 60 && student.CompatibilityScore < 80;
                
                var scoreColorClass = isHighlyCompatible ? "text-success-green bg-success-green/10" : 
                                      isModeratelyCompatible ? "text-warning-amber bg-warning-amber/10" : 
                                      "text-slate-500 bg-slate-100";
                
                var scoreBarClass = isHighlyCompatible ? "bg-success-green" : 
                                    isModeratelyCompatible ? "bg-warning-amber" : 
                                    "bg-slate-400";

                <div class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 overflow-hidden hover:shadow-md transition-all group flex flex-col h-full">
                    <!-- Top section with avatar & basic info -->
                    <div class="p-6 pb-0 relative">
                        <div class="absolute top-6 right-6 px-3 py-1 rounded-full @scoreColorClass text-xs font-bold flex items-center gap-1 shadow-sm">
                            <span>@student.CompatibilityScore%</span>
                            <span class="material-symbols-outlined text-[14px]">
                                @(isHighlyCompatible ? "favorite" : "thumb_up")
                            </span>
                        </div>
                        
                        <div class="flex items-center gap-4 mb-4">
                            @if (!string.IsNullOrEmpty(student.ProfilePhotoUrl))
                            {
                                <img src="@Url.Content(student.ProfilePhotoUrl)" alt="@student.Name" class="w-16 h-16 rounded-2xl object-cover border-2 border-white shadow-sm" />
                            }
                            else
                            {
                                <div class="w-16 h-16 rounded-2xl bg-surface-container-high flex items-center justify-center text-slate-400 border-2 border-white shadow-sm">
                                    <span class="material-symbols-outlined text-3xl">person</span>
                                </div>
                            }
                            <div>
                                <h3 class="font-headline-h2 text-lg text-primary m-0 leading-tight">@student.Name</h3>
                                <p class="text-xs text-on-surface-variant m-0 mt-1 line-clamp-1">@student.University</p>
                                <p class="text-xs text-on-surface-variant font-medium m-0">@student.Faculty</p>
                            </div>
                        </div>

                        <!-- Compatibility Bar -->
                        <div class="mt-4">
                            <div class="flex justify-between items-end mb-1">
                                <span class="text-[10px] uppercase tracking-wider text-slate-500 font-bold">Match Score</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                <div class="@scoreBarClass h-1.5 rounded-full" style="width: @student.CompatibilityScore%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Reasons -->
                    <div class="px-6 py-4 mt-2">
                        <div class="flex flex-wrap gap-2">
                            @foreach (var reason in student.CompatibilityReasons.Take(3))
                            {
                                <span class="px-2 py-1 bg-slate-50 border border-slate-100 rounded text-[11px] text-slate-600 font-medium flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px] text-deep-teal">check</span>
                                    @reason
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Housing Status & Actions -->
                    <div class="mt-auto p-6 pt-4 bg-surface-container-lowest border-t border-outline-variant/30">
                        @if (student.HousingStatus == StudentHousingStatus.HasApartment && student.ApartmentId.HasValue)
                        {
                            <div class="mb-4 bg-teal-50 p-3 rounded-xl border border-teal-100">
                                <p class="text-xs font-bold text-deep-teal m-0 mb-1 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">apartment</span>
                                    Has an Apartment
                                </p>
                                <p class="text-xs text-slate-600 m-0 line-clamp-1 mb-1">@student.ApartmentAddress</p>
                                <div class="flex justify-between items-center text-[11px] font-medium text-slate-500">
                                    <span>@student.AvailableSeats seat(s) available</span>
                                    <span>@student.ApartmentPrice?.ToString("C0")/mo</span>
                                </div>
                            </div>
                            
                            <div class="flex gap-2">
                                <a asp-action="ViewRoommateProfile" asp-route-studentId="@student.StudentId" class="flex-1 text-center py-2.5 border border-outline-variant text-on-surface-variant rounded-lg text-sm font-bold hover:bg-surface-container-low transition-colors no-underline">
                                    Profile
                                </a>
                                <a asp-action="ApartmentDetails" asp-route-id="@student.ApartmentId" class="flex-[2] text-center py-2.5 bg-deep-teal text-white rounded-lg text-sm font-bold hover:opacity-90 transition-opacity shadow-sm no-underline btn-interact">
                                    View Apartment
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="mb-4 flex items-center gap-2 text-slate-500">
                                <span class="material-symbols-outlined text-lg">search</span>
                                <p class="text-xs font-medium m-0">Searching for an apartment</p>
                            </div>
                            
                            <a asp-action="ViewRoommateProfile" asp-route-studentId="@student.StudentId" class="block w-full text-center py-2.5 bg-surface-container-high text-on-surface rounded-lg text-sm font-bold hover:bg-surface-variant transition-colors shadow-sm no-underline btn-interact">
                                View Profile
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
