@model Sakanak.Web.Models.ViewModels.Student.ApartmentDiscoveryDetailsViewModel
@{
    ViewData["Title"] = "Apartment Details";
    Layout = "_TailwindStudentLayout";
    var apartment = Model.Apartment;
}

<div class="animate-slide-up">
    <!-- Header Section -->
    <header class="mb-8 flex flex-col md:flex-row md:items-start justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-slate-500 mb-2">
                <a asp-action="SearchApartments" class="text-slate-400 hover:text-deep-teal flex items-center gap-1 no-underline transition-colors">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    <span class="font-label-sm text-xs">Back to Search</span>
                </a>
            </div>
            <h1 class="font-headline-h1 text-headline-h1 text-deep-teal tracking-tight mb-1">@apartment.Address</h1>
            <div class="flex items-center gap-2 text-slate-500 mt-1">
                <span class="material-symbols-outlined text-sm">location_on</span>
                <span class="font-body-base">@apartment.City</span>
            </div>
        </div>
        <div class="bg-teal-50 px-6 py-4 rounded-2xl border border-teal-100 text-right shrink-0">
            <p class="text-slate-500 font-label-sm text-label-sm uppercase tracking-wider m-0">Monthly Rent</p>
            <div class="flex items-baseline justify-end gap-1">
                <span class="text-3xl font-extrabold text-deep-teal">@apartment.PricePerMonth.ToString("C0")</span>
                <span class="text-slate-500 font-medium">/mo</span>
            </div>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left: Apartment Details -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Photo Gallery (Bento-style) -->
            <partial name="_ApartmentPhotoGallery" model="apartment.Photos.Select(p => p.Url).ToList()" />

            <!-- Quick Stats Row -->
            <div class="flex gap-3 overflow-x-auto scrollbar-hide pb-2">
                <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-slate-200 shadow-sm whitespace-nowrap shrink-0">
                    <span class="material-symbols-outlined text-deep-teal">group</span>
                    <span class="text-label-sm font-medium">@apartment.TotalSeats Total Seats</span>
                </div>
                <div class="flex items-center gap-2 @(apartment.AvailableSeats > 0 ? "bg-teal-50 border-teal-100" : "bg-red-50 border-red-100") px-4 py-2 rounded-full border shadow-sm whitespace-nowrap shrink-0">
                    <span class="material-symbols-outlined @(apartment.AvailableSeats > 0 ? "text-deep-teal" : "text-danger-red")" style="font-variation-settings: 'FILL' 1;">person_add</span>
                    <span class="text-label-sm font-bold @(apartment.AvailableSeats > 0 ? "text-deep-teal" : "text-danger-red")">
                        @(apartment.AvailableSeats > 0 ? $"{apartment.AvailableSeats} Seats Available" : "Fully Booked")
                    </span>
                </div>
            </div>

            <!-- Virtual Tour -->
            @if (!string.IsNullOrWhiteSpace(apartment.VirtualTourUrl))
            {
                <section class="bg-slate-900 rounded-3xl p-8 relative overflow-hidden group">
                    <div class="absolute inset-0 opacity-40 bg-gradient-to-r from-deep-teal/40 to-primary/40"></div>
                    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
                        <div class="space-y-2 text-center md:text-left">
                            <h3 class="text-white font-headline-h2 text-headline-h2 m-0">Take a Virtual Tour</h3>
                            <p class="text-teal-200 font-body-base m-0">Experience this space in 360° from anywhere.</p>
                        </div>
                        <a href="@apartment.VirtualTourUrl" target="_blank" rel="noreferrer" class="bg-white text-slate-900 px-6 py-3 rounded-full font-bold flex items-center gap-2 hover:scale-105 transition-transform no-underline shrink-0">
                            <span class="material-symbols-outlined">play_circle</span>
                            Start Tour
                        </a>
                    </div>
                </section>
            }

            <!-- Amenities -->
            <section class="space-y-4">
                <h3 class="font-headline-h2 text-headline-h2 text-deep-teal">Property Amenities</h3>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    @foreach (var amenity in apartment.Amenities)
                    {
                        <div class="p-4 rounded-2xl bg-white border border-slate-100 flex items-center gap-3 group hover:border-deep-teal transition-colors shadow-sm">
                            <span class="material-symbols-outlined text-deep-teal bg-teal-50 w-10 h-10 flex items-center justify-center rounded-xl shrink-0">check_circle</span>
                            <span class="font-medium text-sm text-slate-700">@amenity</span>
                        </div>
                    }
                    @if (apartment.Amenities.Count == 0)
                    {
                        <div class="col-span-full p-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-500 text-sm">
                            No amenities listed.
                        </div>
                    }
                </div>
            </section>

            <!-- Current Tenants & Compatibility -->
            @if (Model.CurrentRoommates.Any())
            {
                <section class="space-y-4">
                    <div class="flex justify-between items-center">
                        <h3 class="font-headline-h2 text-headline-h2 text-deep-teal m-0">Meet the Tenants</h3>
                        <span class="bg-success-green/10 text-success-green px-3 py-1 rounded-full text-xs font-bold flex items-center gap-1">
                            <span class="material-symbols-outlined text-xs">verified</span> Verified Student Community
                        </span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        @foreach (var roommate in Model.CurrentRoommates)
                        {
                            <div class="p-5 bg-white rounded-3xl border border-slate-100 flex items-center gap-4 hover:shadow-md transition-shadow">
                                <div class="w-16 h-16 rounded-2xl overflow-hidden relative bg-surface-container shrink-0 flex items-center justify-center text-deep-teal">
                                    <span class="material-symbols-outlined text-[32px]">person</span>
                                    <div class="absolute bottom-0 right-0 bg-success-green w-4 h-4 rounded-full border-2 border-white"></div>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-deep-teal m-0">@roommate.Name</h4>
                                    <p class="text-xs text-slate-500 m-0 mb-2">@roommate.University</p>
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                            <div class="h-full @(roommate.CompatibilityScore >= 80 ? "bg-success-green" : roommate.CompatibilityScore >= 50 ? "bg-warning-amber" : "bg-danger-red") rounded-full" style="width: @roommate.CompatibilityScore%;"></div>
                                        </div>
                                        <span class="text-xs font-extrabold @(roommate.CompatibilityScore >= 80 ? "text-success-green" : roommate.CompatibilityScore >= 50 ? "text-warning-amber" : "text-danger-red")">@roommate.CompatibilityScore% Match</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>

        <!-- Right: Booking Widget Sidebar -->
        <aside class="space-y-6">
            <div class="sticky top-24 space-y-6">
                <!-- Main Booking Card -->
                <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 p-6 space-y-6">
                    <div class="flex justify-between items-center pb-4 border-b border-slate-50">
                        <h4 class="font-headline-h2 text-headline-h2 text-deep-teal m-0">Reserve Now</h4>
                    </div>
                    
                    <div class="p-4 bg-teal-50/50 rounded-2xl space-y-2">
                        <div class="flex justify-between text-sm">
                            <span class="text-slate-500">Monthly Rent</span>
                            <span class="font-bold text-deep-teal">@apartment.PricePerMonth.ToString("C0")</span>
                        </div>
                    </div>
                    
                    <div class="space-y-3">
                        @if (apartment.AvailableSeats > 0)
                        {
                            <a asp-action="BookApartment" asp-route-id="@apartment.ApartmentId" class="w-full py-4 bg-deep-teal text-white rounded-2xl font-display-hero font-bold shadow-lg shadow-deep-teal/20 hover:scale-[1.02] active:scale-[0.98] transition-all no-underline block text-center btn-interact">
                                Book This Apartment
                            </a>
                        }
                        else
                        {
                            <button disabled class="w-full py-4 bg-slate-200 text-slate-500 rounded-2xl font-bold cursor-not-allowed">
                                Fully Booked
                            </button>
                        }
                        
                        <a asp-controller="Messages" asp-action="Index" asp-route-otherUserId="@apartment.LandlordApplicationUserId" class="w-full py-4 border-2 border-slate-100 text-slate-600 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-slate-50 transition-colors no-underline btn-interact">
                            <span class="material-symbols-outlined">mail</span>
                            Message Landlord
                        </a>
                    </div>
                    <p class="text-[11px] text-center text-slate-400 px-4 m-0">
                        By clicking 'Book This Apartment', you'll begin the secure booking process.
                    </p>
                </div>
                
                <!-- Landlord Info -->
                <div class="bg-white rounded-3xl border border-slate-100 p-6 space-y-4 shadow-sm">
                    <h5 class="text-xs font-bold text-slate-400 uppercase tracking-widest m-0">Managed By</h5>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-teal-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-deep-teal">real_estate_agent</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-deep-teal m-0 line-clamp-1">@apartment.LandlordName</h4>
                            <p class="text-xs text-slate-500 m-0">
                                @if (!string.IsNullOrWhiteSpace(apartment.LandlordPhoneNumber))
                                {
                                    @apartment.LandlordPhoneNumber
                                }
                                else
                                {
                                    <text>Phone hidden</text>
                                }
                            </p>
                        </div>
                        @if (apartment.LandlordVerified)
                        {
                            <div class="ml-auto" title="Verified Landlord">
                                <span class="material-symbols-outlined text-success-green text-[20px]">verified_user</span>
                            </div>
                        }
                    </div>
                </div>
                
                <!-- Safety Banner -->
                <div class="bg-teal-900 rounded-3xl p-5 text-white flex items-start gap-4 shadow-sm">
                    <span class="material-symbols-outlined text-teal-300">shield_lock</span>
                    <div class="space-y-1">
                        <h6 class="font-bold text-sm m-0">Sakanak Protection</h6>
                        <p class="text-xs text-teal-100 leading-relaxed m-0">Your data and communications are secure. All bookings require administrator approval.</p>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

<style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
