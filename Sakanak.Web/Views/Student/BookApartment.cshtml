@model Sakanak.Web.Models.ViewModels.Student.BookApartmentViewModel
@{
    ViewData["Title"] = "Book Apartment";
    Layout = "_TailwindStudentLayout";
    var apartment = Model.Apartment;
}

<div class="animate-slide-up max-w-6xl mx-auto">
    <!-- Header Section -->
    <div class="mb-stack-lg flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <a asp-action="ApartmentDetails" asp-route-id="@Model.ApartmentId" class="flex items-center gap-1 text-on-surface-variant hover:text-deep-teal mb-2 transition-colors no-underline">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                <span class="text-label-sm font-label-sm">Back to Apartment</span>
            </a>
            <h2 class="text-headline-h1 font-headline-h1 text-on-surface m-0 mb-1">Book Reservation</h2>
            <p class="text-body-base font-body-base text-on-surface-variant m-0">Complete your booking request for the landlord to review.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
        
        <!-- Left Column: Form -->
        <div class="lg:col-span-7 space-y-gutter">
            <form asp-action="BookApartment" method="post" class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-card-padding">
                <input asp-for="ApartmentId" type="hidden" />
                
                <div asp-validation-summary="ModelOnly" class="bg-danger-red/10 border border-danger-red/20 text-danger-red p-4 rounded-xl text-sm font-medium mb-6"></div>

                <div class="flex items-center gap-2 mb-6 pb-4 border-b border-outline-variant/30">
                    <span class="material-symbols-outlined text-deep-teal">date_range</span>
                    <h3 class="font-headline-h2 text-xl text-on-surface m-0">Lease Duration</h3>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg mb-8">
                    <div class="space-y-2">
                        <label asp-for="RequestedStartDate" class="text-label-sm font-semibold text-on-surface-variant block m-0"></label>
                        <input asp-for="RequestedStartDate" type="date" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all text-on-surface" />
                        <span asp-validation-for="RequestedStartDate" class="text-danger-red text-xs font-medium"></span>
                    </div>
                    
                    <div class="space-y-2">
                        <label asp-for="RequestedEndDate" class="text-label-sm font-semibold text-on-surface-variant block m-0"></label>
                        <input asp-for="RequestedEndDate" type="date" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all text-on-surface" />
                        <span asp-validation-for="RequestedEndDate" class="text-danger-red text-xs font-medium"></span>
                    </div>
                </div>

                <div class="flex items-center gap-2 mb-6 pb-4 border-b border-outline-variant/30">
                    <span class="material-symbols-outlined text-deep-teal">chat_bubble</span>
                    <h3 class="font-headline-h2 text-xl text-on-surface m-0">Message to Landlord</h3>
                </div>

                <div class="space-y-2 mb-8">
                    <label asp-for="Message" class="text-label-sm font-semibold text-on-surface-variant block m-0">Introduction (Optional)</label>
                    <textarea asp-for="Message" rows="5" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all resize-y text-on-surface" placeholder="Introduce yourself, mention your major, or specify any timing details..."></textarea>
                    <span asp-validation-for="Message" class="text-danger-red text-xs font-medium"></span>
                </div>

                <div class="bg-teal-50 border border-teal-100 p-4 rounded-xl flex gap-3 mb-8">
                    <span class="material-symbols-outlined text-deep-teal shrink-0">info</span>
                    <p class="text-sm text-teal-800 m-0 leading-relaxed">
                        <strong>Booking Requirements:</strong><br/>
                        • Start date must be at least 7 days from today.<br/>
                        • Lease duration must be between 3 and 12 months.
                    </p>
                </div>

                <div class="pt-4 border-t border-outline-variant/30">
                    <button type="submit" class="w-full py-4 bg-deep-teal text-white rounded-xl font-bold shadow-lg hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 btn-interact text-lg">
                        <span class="material-symbols-outlined">send</span>
                        <span>Send Booking Request</span>
                    </button>
                    <p class="text-xs text-center text-slate-400 m-0 mt-3">You won't be charged until the landlord approves and you sign the contract.</p>
                </div>
            </form>
        </div>

        <!-- Right Column: Apartment Summary -->
        <div class="lg:col-span-5">
            <aside class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 overflow-hidden sticky top-24">
                
                @if (apartment.Photos.Count > 0)
                {
                    <div class="h-48 w-full bg-slate-100">
                        <img src="@Url.Content(apartment.Photos.First().Url)" alt="Apartment photo" class="w-full h-full object-cover" />
                    </div>
                }
                else
                {
                    <div class="h-48 w-full bg-slate-100 flex items-center justify-center text-slate-400">
                        <span class="material-symbols-outlined text-5xl">apartment</span>
                    </div>
                }
                
                <div class="p-6">
                    <h3 class="font-headline-h2 text-xl text-primary m-0 mb-1 line-clamp-1">@apartment.Address</h3>
                    <p class="text-sm text-on-surface-variant flex items-center gap-1 m-0 mb-6">
                        <span class="material-symbols-outlined text-sm">location_on</span>
                        @apartment.City
                    </p>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between items-center pb-4 border-b border-outline-variant/30">
                            <span class="text-sm text-on-surface-variant font-medium">Monthly Rent</span>
                            <span class="text-xl font-bold text-deep-teal">@apartment.PricePerMonth.ToString("C0")</span>
                        </div>
                        
                        <div class="flex justify-between items-center pb-4 border-b border-outline-variant/30">
                            <span class="text-sm text-on-surface-variant font-medium">Available Seats</span>
                            <span class="text-sm font-bold text-on-surface">@apartment.AvailableSeats of @apartment.TotalSeats</span>
                        </div>
                        
                        <div class="flex justify-between items-center pb-4 border-b border-outline-variant/30">
                            <span class="text-sm text-on-surface-variant font-medium">Managed By</span>
                            <span class="text-sm font-bold text-on-surface flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm text-deep-teal">real_estate_agent</span>
                                @apartment.LandlordName
                            </span>
                        </div>
                    </div>

                    <div class="mt-6">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-3">Amenities Include</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var amenity in apartment.Amenities.Take(6))
                            {
                                <span class="px-2 py-1 bg-slate-50 border border-slate-200 rounded text-[11px] text-slate-600 font-medium">@amenity</span>
                            }
                            @if (apartment.Amenities.Count > 6)
                            {
                                <span class="px-2 py-1 bg-slate-50 border border-slate-200 rounded text-[11px] text-slate-600 font-medium">+@(apartment.Amenities.Count - 6) more</span>
                            }
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
