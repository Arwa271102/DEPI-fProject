@using Sakanak.Domain.Enums
@model Sakanak.Web.Models.ViewModels.Student.QuestionnaireViewModel
@{
    ViewData["Title"] = "Lifestyle Questionnaire";
    Layout = "_TailwindStudentLayout";
}

<div class="animate-slide-up max-w-4xl mx-auto">
    <!-- Header Section -->
    <div class="mb-stack-lg">
        <a asp-action="Profile" class="flex items-center gap-1 text-on-surface-variant hover:text-deep-teal mb-2 transition-colors no-underline">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            <span class="text-label-sm font-label-sm">Back to Profile</span>
        </a>
        <h2 class="text-headline-h1 font-headline-h1 text-on-surface m-0 mb-1">Lifestyle Questionnaire</h2>
        <p class="text-body-lg font-body-lg text-on-surface-variant m-0">These preferences are used to calculate compatibility scores and help you find the perfect roommate match.</p>
    </div>

    <form asp-action="Questionnaire" method="post" class="bg-surface-student rounded-2xl shadow-sm border border-outline-variant/50 p-card-padding">
        @Html.AntiForgeryToken()
        
        <div asp-validation-summary="ModelOnly" class="bg-danger-red/10 border border-danger-red/20 text-danger-red p-4 rounded-xl text-sm font-medium mb-6"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
            
            <!-- Sleep Schedule -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center text-deep-teal">
                        <span class="material-symbols-outlined text-[18px]">bedtime</span>
                    </div>
                    <label asp-for="SleepSchedule" class="text-label-sm font-bold text-on-surface m-0"></label>
                </div>
                <div class="relative">
                    <select asp-for="SleepSchedule" asp-items="Html.GetEnumSelectList<SleepSchedule>()" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all appearance-none cursor-pointer pr-10"></select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>

            <!-- Study Habits -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center text-deep-teal">
                        <span class="material-symbols-outlined text-[18px]">menu_book</span>
                    </div>
                    <label asp-for="StudyHabits" class="text-label-sm font-bold text-on-surface m-0"></label>
                </div>
                <div class="relative">
                    <select asp-for="StudyHabits" asp-items="Html.GetEnumSelectList<StudyHabits>()" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all appearance-none cursor-pointer pr-10"></select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>

            <!-- Social Preference -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center text-deep-teal">
                        <span class="material-symbols-outlined text-[18px]">groups</span>
                    </div>
                    <label asp-for="SocialPreference" class="text-label-sm font-bold text-on-surface m-0"></label>
                </div>
                <div class="relative">
                    <select asp-for="SocialPreference" asp-items="Html.GetEnumSelectList<SocialPreference>()" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all appearance-none cursor-pointer pr-10"></select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>

            <!-- Gender Preference -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center text-deep-teal">
                        <span class="material-symbols-outlined text-[18px]">wc</span>
                    </div>
                    <label asp-for="GenderPreference" class="text-label-sm font-bold text-on-surface m-0"></label>
                </div>
                <div class="relative">
                    <select asp-for="GenderPreference" asp-items="Html.GetEnumSelectList<GenderPreference>()" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all appearance-none cursor-pointer pr-10"></select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>

            <!-- Hygiene Level -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center text-deep-teal">
                        <span class="material-symbols-outlined text-[18px]">cleaning_services</span>
                    </div>
                    <label asp-for="HygieneLevel" class="text-label-sm font-bold text-on-surface m-0"></label>
                </div>
                <div class="relative">
                    <select asp-for="HygieneLevel" class="w-full bg-surface-container-lowest border border-outline-variant rounded-xl px-4 py-3 text-body-base focus:outline-none focus:border-deep-teal focus:ring-2 focus:ring-deep-teal/20 transition-all appearance-none cursor-pointer pr-10">
                        <option value="1">1 - Relaxed</option>
                        <option value="2">2</option>
                        <option value="3">3 - Balanced</option>
                        <option value="4">4</option>
                        <option value="5">5 - Very tidy</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>

            <!-- Smoking Status -->
            <div class="space-y-3 flex flex-col justify-center mt-2">
                <label class="flex items-center gap-3 p-4 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-colors bg-surface-container-lowest">
                    <input asp-for="IsSmoker" type="checkbox" class="w-5 h-5 text-deep-teal rounded border-outline-variant focus:ring-deep-teal focus:ring-offset-0" />
                    <div class="flex-1">
                        <p class="font-bold text-on-surface m-0">I smoke</p>
                        <p class="text-xs text-on-surface-variant m-0">This helps pair you with compatible roommates.</p>
                    </div>
                    <span class="material-symbols-outlined text-on-surface-variant">smoking_rooms</span>
                </label>
            </div>
        </div>

        <div class="mt-8 pt-6 border-t border-outline-variant/30 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div>
                @if (Model.LastUpdated.HasValue)
                {
                    <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 m-0 flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">history</span>
                        Last updated @Model.LastUpdated.Value.ToLocalTime().ToString("MMM dd, yyyy")
                    </p>
                }
            </div>
            
            <button type="submit" class="w-full sm:w-auto px-10 py-3 bg-deep-teal text-white rounded-xl font-bold shadow-lg hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 btn-interact">
                <span class="material-symbols-outlined">save</span>
                <span>Save Questionnaire</span>
            </button>
        </div>
    </form>
</div>
