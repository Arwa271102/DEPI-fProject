@model Sakanak.BLL.DTOs.Payment.PaymentDto
@{
    ViewData["Title"] = "Pay Contract";
    Layout = "_TailwindStudentLayout";
}

<div class="animate-slide-up flex flex-col items-center justify-center min-h-[70vh]">
    <div class="w-full max-w-xl bg-surface-student rounded-3xl shadow-lg border border-outline-variant/50 overflow-hidden relative">
        <!-- Decorative Header -->
        <div class="h-32 bg-primary relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-white opacity-10 rounded-full blur-xl"></div>
            <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-white opacity-10 rounded-full blur-xl"></div>
            
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white border border-white/30 shadow-sm">
                    <span class="material-symbols-outlined text-[32px]">credit_score</span>
                </div>
            </div>
        </div>

        <div class="p-8 pt-10 text-center">
            <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-2">Secure Checkout</p>
            <h2 class="font-headline-h1 text-2xl text-primary m-0 mb-2">Complete Your Payment</h2>
            <p class="text-on-surface-variant text-sm m-0 mb-8 max-w-sm mx-auto">Complete this payment to activate your approved contract for <strong class="text-deep-teal">@Model.ApartmentAddress</strong>.</p>
            
            <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/50 p-6 mb-8 text-left space-y-4 shadow-sm">
                <div class="flex justify-between items-center pb-4 border-b border-outline-variant/30">
                    <span class="text-sm font-bold text-slate-500 uppercase tracking-wider">Total Amount</span>
                    <span class="text-3xl font-extrabold text-deep-teal">@Model.Amount.ToString("C0")</span>
                </div>
                
                <div class="flex justify-between items-center">
                    <span class="text-sm text-on-surface-variant font-medium">Due Date</span>
                    <span class="text-sm font-bold text-on-surface">@Model.DueDate.ToString("MMM dd, yyyy")</span>
                </div>
                
                <div class="flex justify-between items-center">
                    <span class="text-sm text-on-surface-variant font-medium">Status</span>
                    @await Html.PartialAsync("_StatusBadgePartial", Model.Status)
                </div>
            </div>

            @if (Model.CanPay)
            {
                <form asp-action="InitiatePayment" asp-route-paymentId="@Model.PaymentId" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full py-4 bg-deep-teal text-white rounded-xl font-bold shadow-lg hover:bg-primary active:scale-[0.98] transition-all flex items-center justify-center gap-2 btn-interact text-lg relative overflow-hidden group">
                        <div class="absolute inset-0 w-1/4 h-full bg-white/20 skew-x-12 -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
                        <span class="material-symbols-outlined">payments</span>
                        Pay Now with Stripe
                    </button>
                </form>
                
                <div class="mt-6 flex items-start gap-2 text-left bg-blue-50 text-blue-800 p-4 rounded-xl border border-blue-100 text-xs leading-relaxed">
                    <span class="material-symbols-outlined text-[16px] mt-0.5 shrink-0">info</span>
                    <div>
                        <strong>Development Mode:</strong> You will be redirected to Stripe's secure checkout. Since this is in test mode, you can use the test card <code class="bg-white px-1.5 py-0.5 rounded text-blue-900 border border-blue-200">4242 4242 4242 4242</code> with any future expiration date and CVC.
                    </div>
                </div>
            }
            else
            {
                <div class="bg-teal-50 text-deep-teal p-4 rounded-xl font-bold text-sm mb-4">
                    This payment cannot be processed at this time.
                </div>
                <a asp-action="PaymentDetails" asp-route-id="@Model.PaymentId" class="block w-full py-3 border-2 border-outline-variant text-on-surface-variant rounded-xl font-bold hover:bg-surface-container-low transition-colors no-underline">
                    View Payment Details
                </a>
            }
        </div>
        
        <div class="bg-surface-container-low px-6 py-4 flex items-center justify-center gap-2 text-xs text-slate-500 font-medium">
            <span class="material-symbols-outlined text-[16px]">lock</span>
            Payments are processed securely via Stripe
        </div>
    </div>
</div>
